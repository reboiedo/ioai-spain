---
/**
 * SectionTitle — stacked display heading sized by `.font-display-l`.
 * Each line is its own block so we can scale-Y it independently on
 * scroll, anchored to its top edge.
 *
 *   <SectionTitle lines={["OUR", "APPROACH"]} />
 *   <SectionTitle lines={["OUR APPROACH"]} mobileLines={["OUR", "APPROACH"]} />
 *   <SectionTitle lines={["Apply"]} as="h3" />
 *
 *   // Optional handwritten eyebrow overlapping the title (used for
 *   // feature callouts, e.g. follow.art's "the" over "ART WORLD"):
 *   <SectionTitle lines={["ART WORLD"]} eyebrow="the" />
 *
 * `mobileLines` is optional — when omitted, `lines` is used at every
 * viewport. When present, a second variant is rendered in the DOM and
 * swapped via `@media (max-width: 767.98px)`. Breakpoint mirrors
 * `.split` in `src/styles/tenerife/utilities.css`.
 *
 * On mobile (<768px) the title is rendered via `HeroTitle`'s
 * fit-to-container SVG so each line spans the section's inner width
 * regardless of word length — short titles like "TRACKS" no longer
 * floor at the `font-display-l` clamp's lower bound.
 */

import HeroTitle from '@/components/tenerife/HeroTitle.astro';

export interface Props {
  as?: 'h1' | 'h2' | 'h3' | 'div';
  class?: string;
  /** Desktop (≥768px) lines. Also used on mobile if `mobileLines` omitted. */
  lines: string[];
  /** Optional mobile (<768px) line breakdown. */
  mobileLines?: string[];
  /** Optional max-width for the title (any CSS length, e.g. "20ch", "40rem"). */
  width?: string;
  /**
   * Optional handwritten "eyebrow" word(s). Use 1–2 short words —
   * longer text will overflow the title bounds. Defaults to
   * undefined (no eyebrow rendered).
   *
   * Override the colour per call site by setting the CSS custom
   * property `--section-title-eyebrow-color` on the title or any
   * ancestor. Default is `--primary` (the section theme's brand
   * accent).
   */
  eyebrow?: string;
  /**
   * Where the eyebrow sits relative to the title.
   *
   *   - `'overlap'` (default): absolute positioned over the
   *     upper-left of the title (e.g. "learning" over "TRACKS").
   *     Heading reads as `"{eyebrow} {lines}"`.
   *   - `'between'`: rendered as a block between line 1 and
   *     line 2 (requires `lines.length >= 2`). Use for
   *     two-word headings like "SAFETY ⟨always⟩ FIRST" where
   *     the eyebrow connects the two title words. Heading
   *     reads as `"{line1} {eyebrow} {line2…}"`.
   */
  eyebrowPosition?: 'overlap' | 'between';
}

const {
  as: Tag = 'h2',
  class: extraClass = '',
  lines = [],
  mobileLines,
  width,
  eyebrow,
  eyebrowPosition = 'overlap',
} = Astro.props as Props;

// `between` only makes sense with at least 2 lines — fall back to
// `overlap` if the caller mis-pairs them, so we never end up with
// a stray block-eyebrow at the top of a single-line title.
const eyebrowPos: 'overlap' | 'between' =
  eyebrowPosition === 'between' && lines.length >= 2 ? 'between' : 'overlap';

const mobile: string[] | null =
  Array.isArray(mobileLines) && mobileLines.length > 0 ? mobileLines : null;

// The mobile SVG path uses whichever line breakdown is most natural
// for narrow viewports — `mobileLines` if provided, otherwise the
// same `lines` as desktop.
const mobileSvgLines = mobile ?? lines;
---

<Tag
  class:list={['section-title', 'font-display-l', extraClass]}
  style={width ? `max-width: ${width}` : undefined}
  data-eyebrow-position={eyebrow ? eyebrowPos : undefined}
>
  <!-- OVERLAP eyebrow: renders FIRST so the heading's textContent
       reads "{eyebrow} {lines}" (e.g. "learning TRACKS"). Visually
       absolutely-positioned over the title's upper-left. -->
  {eyebrow && eyebrowPos === 'overlap' && (
    <span class="section-title__eyebrow section-title__eyebrow--overlap">
      {eyebrow}{' '}
    </span>
  )}

  <!-- Desktop / default path: CSS-rendered text with line-level
       scroll-driven scaleY animation. The semantic source for
       screen readers. The eyebrow is inserted INLINE between
       line 1 and line 2 when `eyebrowPos === 'between'` so the
       reading order is "{line1} {eyebrow} {line2}". -->
  <span
    class="section-title__lines section-title__lines--desktop"
    aria-hidden={mobile ? 'true' : undefined}
    data-stl
  >
    {lines.map((line, i) => (
      <>
        <span class="section-title__line">{line}</span>
        {eyebrow && eyebrowPos === 'between' && i === 0 && (
          <span class="section-title__eyebrow section-title__eyebrow--between">
            {eyebrow}{' '}
          </span>
        )}
      </>
    ))}
  </span>

  {mobile && (
    <span class="section-title__lines section-title__lines--mobile" data-stl>
      {mobile.map((line) => (
        <span class="section-title__line">{line}</span>
      ))}
    </span>
  )}

  <!-- Mobile path: each line as a HeroTitle SVG that fits the
       container's width (no per-letter jitter — `noStretch`).
       Marked `aria-hidden` because the desktop path above is the
       semantic copy for assistive tech; this one is purely a
       visual presentation swap. -->
  <span
    class="section-title__lines section-title__lines--mobile-svg"
    aria-hidden="true"
  >
    {mobileSvgLines.map((line) => (
      <HeroTitle as="span" noStretch class="section-title__svg-line">
        {line}
      </HeroTitle>
    ))}
  </span>

  <!-- Mobile-only overlay eyebrow for `between` mode. The
       desktop path renders the eyebrow inline (between line 1
       and line 2 of a horizontal row). On mobile the lines
       stack vertically via the SVG path, so we show this
       absolute-positioned overlay instead — sitting on top of
       the title without taking layout space.
       `aria-hidden` because the desktop inline copy above is
       already the semantic source for screen readers. -->
  {eyebrow && eyebrowPos === 'between' && (
    <span
      class="section-title__eyebrow section-title__eyebrow--mobile-overlay"
      aria-hidden="true"
    >
      {eyebrow}
    </span>
  )}
</Tag>

<style>
  @property --scroll-sy {
    syntax: '<number>';
    inherits: false;
    initial-value: 1;
  }

  .section-title {
    margin: 0;
    /* `position: relative` provides the containing block for the
     * absolutely-positioned `.section-title__eyebrow`. */
    position: relative;
    /* Inherit the section's foreground colour. Each theme's
     * `--foreground` resolves per `data-theme` so the title reads
     * cleanly against the section's background. */
    color: var(--foreground);
  }

  .section-title__lines {
    display: block;
    transform-origin: 0 0;
    transform: scaleY(var(--scroll-sy, 1));
    will-change: transform;
  }

  .section-title__line {
    display: block;
  }

  /* Mobile-line variants are hidden by default; the media query at
   * the bottom flips visibility. The `--mobile-svg` variant is
   * always present in the DOM but display: none on desktop. */
  .section-title__lines--mobile,
  .section-title__lines--mobile-svg {
    display: none;
  }

  /* Each SVG line takes its row in the mobile path; container
   * width drives glyph size. `display: block` so multi-line stacks
   * lay out vertically. */
  .section-title__svg-line {
    display: block;
    width: 100%;
  }

  /* Override `HeroTitle`'s default `font-size: clamp(4rem, 16vw, 18rem)`
   * fallback so the pre-render text size matches `font-display-l` more
   * closely while the SVG is being built. Once the SVG renders the
   * font-size is irrelevant — the SVG sizes off width. */
  .section-title__lines--mobile-svg :global(.hero-title__text) {
    font-size: var(--type-step-7);
  }

  @media (max-width: 767.98px) {
    /* Desktop CSS path off, mobile SVG path on. The
     * `.section-title__lines--mobile` CSS-text variant stays off
     * because the SVG path now handles mobile rendering. The
     * extra `[data-eyebrow-position='between']` selector mirrors
     * the desktop flex-row rule's specificity so this `display:
     * none` actually wins on mobile (CSS cascade, not source
     * order — without the matching specificity the flex-row
     * rule beats the bare class selector). */
    .section-title__lines--desktop,
    .section-title:has(.section-title__lines--mobile)
      .section-title__lines--desktop,
    .section-title[data-eyebrow-position='between']
      .section-title__lines--desktop {
      display: none;
    }
    .section-title__lines--mobile-svg {
      display: block;
    }
  }

  /* ── Eyebrow ───────────────────────────────────────────────
   *
   * Two layout variants share the script-font + tilt + colour
   * styling and differ only in placement:
   *
   *   `--overlap`  : `position: absolute` over the title's
   *                  upper-left (e.g. "learning" over "TRACKS").
   *   `--between`  : in-flow block sitting between line 1 and
   *                  line 2 (e.g. "always" between "SAFETY" and
   *                  "FIRST"). No absolute positioning so it
   *                  doesn't depend on knowing the line gap. */
  .section-title__eyebrow {
    font-family: var(--font-script);
    font-weight: var(--weight-regular);
    line-height: 1;
    letter-spacing: var(--tracking-normal);
    pointer-events: none;
    /* Defaults to `--primary` (the section theme's brand
     * accent). Override per call site via
     * `--section-title-eyebrow-color`. */
    color: var(--section-title-eyebrow-color, var(--primary));
    z-index: 1;
  }

  .section-title__eyebrow--overlap {
    position: absolute;
    /* Slightly above the cap line so the script's descenders
     * overlap the typeset glyphs. */
    top: -0.05em;
    /* Hand-placed annotation, offset from the left edge. */
    left: 8%;
    font-size: clamp(2rem, 4.5vw, 4rem);
    /* Counter-clockwise tilt, pivoting at the bottom-left so the
     * script's baseline anchors naturally onto the title. */
    transform: rotate(-6deg);
    transform-origin: bottom left;
  }

  /* `between` mode keeps the title HORIZONTAL on desktop:
   * line 1, eyebrow, line 2 sit in a flex row, baseline-
   * aligned, with the eyebrow inline-block at ~half the
   * title's font-size and a slight rotation.
   *
   * The font-size override + flex-row layout are scoped to
   * `@media (min-width: 768px)` so on mobile the desktop path
   * is fully hidden by the mobile media-query rules and only
   * the SVG-fit path + the absolute overlay eyebrow remain. */
  @media (min-width: 768px) {
    .section-title[data-eyebrow-position='between'] {
      font-size: clamp(var(--type-step-5), 7.5vw, var(--type-step-7));
      line-height: var(--leading-tight);
    }

    .section-title[data-eyebrow-position='between']
      .section-title__lines--desktop {
      display: flex;
      flex-wrap: wrap;
      align-items: baseline;
      column-gap: 0.25em;
    }

    .section-title[data-eyebrow-position='between'] .section-title__line {
      display: inline-block;
    }
  }

  .section-title__eyebrow--between {
    display: inline-block;
    /* Sized relative to the title so the script proportions
     * track the `font-display-l` clamp at every breakpoint. */
    font-size: 0.5em;
    align-self: center;
    transform: rotate(-6deg);
    transform-origin: center;
  }

  /* Mobile overlay eyebrow for `between` mode. Absolute over
   * the H2 so it doesn't take a row of layout. On desktop it's
   * hidden — the inline `--between` eyebrow above is the
   * visible variant there. */
  .section-title__eyebrow--mobile-overlay {
    display: none;
  }

  @media (max-width: 767.98px) {
    .section-title__eyebrow--mobile-overlay {
      display: inline-block;
      position: absolute;
      top: -0.1em;
      left: 6%;
      font-size: clamp(2rem, 6vw, 4rem);
      transform: rotate(-6deg);
      transform-origin: bottom left;
    }
  }
</style>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  let tweens: gsap.core.Tween[] = [];

  function renderAll() {
    tweens.forEach((t) => t.scrollTrigger?.kill());
    tweens.forEach((t) => t.kill());
    tweens = [];

    const lines = document.querySelectorAll<HTMLElement>('[data-stl]');
    lines.forEach((line) => {
      tweens.push(
        gsap.fromTo(
          line,
          { '--scroll-sy': 0.6 },
          {
            '--scroll-sy': 1,
            ease: 'none',
            immediateRender: true,
            scrollTrigger: {
              trigger: line,
              start: 'top bottom',
              end: 'center center',
              scrub: true,
              invalidateOnRefresh: true,
            },
          },
        ),
      );
    });

    ScrollTrigger.refresh();
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', renderAll, { once: true });
  } else {
    renderAll();
  }

  document.addEventListener('astro:page-load', renderAll);
</script>
