---
/**
 * SectionDayInLife — "A DAY AT TENERIFE" scene.
 *
 * Layout (desktop, ≥768px):
 *   ┌──────────────────────────────┬───────────────────────────────┐
 *   │  Sticky                      │  Intro paragraph              │
 *   │   ╔══════════════╗           │  ──────────────────           │
 *   │   ║   A DAY AT   ║           │  Slot 1 (time, title, desc)   │
 *   │   ║              ║           │  ──────────────────           │
 *   │   ║  ┌────────┐  ║           │  Slot 2 …                     │
 *   │   ║  │ photo  │  ║           │  ──────────────────           │
 *   │   ║  │ tilted │  ║           │  Slot 3 …                     │
 *   │   ║  └────────┘  ║           │     …                         │
 *   │   ║   TENERIFE   ║           │                               │
 *   │   ╚══════════════╝           │                               │
 *   └──────────────────────────────┴───────────────────────────────┘
 *
 * Left column mirrors the SectionStory pattern: a big two-line
 * `HeroTitleStack` with a tilted asset positioned absolutely
 * between/over the title. Here the asset is a photo cross-fader
 * — every slot photo is mounted in the same box; only the
 * active one is at opacity 1. JS toggles `data-active` based on
 * which slot row is currently in the right column's reading band.
 *
 * Mobile (<768px): title + intro stack vertically, then a
 * horizontal-scroll of slot cards.
 *
 * Photos: drop images into `src/assets/tenerife/day-in-life/`
 * (named `01-…`, `02-…`, etc.) and they'll be picked up
 * automatically. Falls back to the activities photo set if the
 * folder is empty so the layout reads correctly during dev.
 */

import { Image, type ImageMetadata } from "astro:assets";
import HeroTitleStack from "@/components/tenerife/HeroTitleStack.astro";
import SectionTitle from "@/components/tenerife/SectionTitle.astro";
import HScrollMobile from "@/components/tenerife/HScrollMobile.astro";

export interface Props {
  /** Tenerife theme palette to apply via `data-theme`. */
  theme?: "orange" | "blue" | "yellow" | "neutral";
}

const { theme = "yellow" } = Astro.props;

interface Slot {
  time: string;
  title: string;
  description: string;
}

const slots: Slot[] = [
  {
    time: "7:00am – 9:00am",
    title: "Early rise",
    description:
      "The day starts with a morning workout, a quick clean-up, and the day's announcements. Then a generous breakfast to power through the first lecture block.",
  },
  {
    time: "9:30am – 11:00am",
    title: "1st period",
    description:
      "Students pick up the day's coding skills through a mix of lectures, hands-on practice, and short quizzes that keep the room awake and accountable.",
  },
  {
    time: "11:00am – 11:30am",
    title: "Snack time",
    description:
      "A short break to recharge with something nutritious. Energy back up, attention reset, ready for the next block.",
  },
  {
    time: "11:30am – 1:00pm",
    title: "2nd period",
    description:
      "The second teaching block leans into individual practice — the instructor circulates while students build their own small projects from the morning's material.",
  },
  {
    time: "1:30pm – 4:00pm",
    title: "Lunch",
    description:
      "A long, well-balanced lunch on site. Time to eat, talk, and rest before the afternoon programme picks up.",
  },
  {
    time: "4:00pm – 7:00pm",
    title: "Activities",
    description:
      "The full afternoon goes to the extracurricular programme — beach sports, hikes, cultural walks, surfing, the workshops, the day trips. See the previous section for the day-by-day plan.",
  },
  {
    time: "7:00pm – 8:00pm",
    title: "Dinner",
    description:
      "Dinner together as a cohort — fresh seafood, Mediterranean staples, and locally-sourced produce on a rotating menu.",
  },
  {
    time: "8:00pm – 10:00pm",
    title: "Wind down",
    description:
      "The last hours of the day are deliberately unstructured — chill time, an optional movie, occasional quizzes or stargazing on the terrace, then lights out for an early start.",
  },
];

// Photo set. Prefer dedicated `day-in-life/` images when present;
// otherwise borrow from `activities/` so the layout has content
// during dev. Sorted by filename so order maps to slot index 1:1.
const dayInLifeModules = import.meta.glob<{ default: ImageMetadata }>(
  "@/assets/tenerife/day-in-life/*.{png,jpg,jpeg,webp,avif}",
  { eager: true },
);
const activityModules = import.meta.glob<{ default: ImageMetadata }>(
  "@/assets/tenerife/activities/*.{png,jpg,jpeg,webp,avif}",
  { eager: true },
);
const sourceModules =
  Object.keys(dayInLifeModules).length > 0
    ? dayInLifeModules
    : activityModules;
const photos: ImageMetadata[] = Object.entries(sourceModules)
  .sort(([a], [b]) => a.localeCompare(b))
  .map(([, mod]) => mod.default)
  .slice(0, slots.length);
---

<div class="scene" data-scene data-scene-index="8">
  <section
    class="section split scene__layer scene__layer--tilt day-in-life"
    data-theme={theme}
  >
    <!-- DESKTOP layout (≥768px). Hidden on mobile via the
         `.day__desktop` rule below. -->
    <div class="day__desktop">
      <!-- LEFT (sticky): big two-line HeroTitleStack with the
           tilted photo poster positioned between the lines.
           Same pattern as `SectionStory`'s right column. -->
      <div class="day__left">
        <div class="day__title">
          <HeroTitleStack
            lines={[
              // Top line stays flat — multi-line stretch on every
              // line reads as noise. The bottom line carries the
              // scroll-driven per-letter scaleY animation.
              { text: "A DAY AT", noStretch: true },
              { text: "TENERIFE" },
            ]}
            defaultAlign="left"
            gap="var(--space-s)"
            maxWidth="100%"
          />
        </div>

        <!-- Photo trail. Same mechanism as the CTA section
             (`.image-trail`): a ring buffer of N photos with the
             newest snapping in at its slot's deterministic
             position, predecessors demoting to smaller scales,
             oldest fading out. Triggered by scroll (active slot
             change) instead of the cursor. -->
        <div class="day__trail" data-day-trail>
          {photos.map((photo, i) => (
            <div
              class="day__trail-photo"
              data-day-trail-photo
              data-day-trail-index={String(i)}
            >
              <Image
                src={photo}
                alt=""
                width={320}
                height={400}
                widths={[240, 360, 480]}
                sizes="(min-width: 768px) 18vw, 50vw"
                loading={i < 2 ? "eager" : "lazy"}
              />
            </div>
          ))}
        </div>
      </div>

      <!-- Vertical centreline divider — same convention as the
           other split sections. -->
      <div class="day__divider" aria-hidden="true"></div>

      <!-- RIGHT: intro paragraph (flows with the content) +
           list of timeslot rows. No opacity dimming on inactive
           rows — every slot reads at full strength. -->
      <div class="day__right">
        <p class="font-body-l day__intro">
          Every day at the camp follows the same rhythm — morning
          learning blocks, an unhurried lunch, the afternoon programme
          on the island, dinner together, and a deliberately quiet
          evening before the next early start. Here's how a typical
          day breaks down.
        </p>

        <ol class="day__list">
          {slots.map((s, i) => (
            <li
              class="day-row"
              data-day-index={String(i)}
              data-active={i === 0 ? "true" : undefined}
            >
              <p class="font-caption day-row__time">{s.time}</p>
              <h3 class="font-h3 day-row__title">{s.title}</h3>
              <p class="font-body day-row__description">{s.description}</p>
            </li>
          ))}
        </ol>
      </div>
    </div>

    <!-- MOBILE layout (<768px). Title + intro stacked, then a
         horizontal scroll of slot cards. Hidden on desktop. -->
    <div class="day__mobile">
      <SectionTitle lines={["A DAY AT TENERIFE"]} />
      <p class="font-body-l day__mobile-intro">
        Every day at the camp follows the same rhythm — morning
        learning blocks, an unhurried lunch, the afternoon programme
        on the island, dinner together, and a deliberately quiet
        evening before the next early start. Here's how a typical day
        breaks down.
      </p>

      <HScrollMobile itemWidth="min(80%, 320px)">
        {slots.map((s) => (
          <article class="day-card">
            <p class="font-caption day-card__time">{s.time}</p>
            <h3 class="font-h3 day-card__title">{s.title}</h3>
            <p class="font-body-s day-card__description">{s.description}</p>
          </article>
        ))}
      </HScrollMobile>
    </div>
  </section>
</div>

<style>
  /* ── Desktop / mobile layout swap ───────────────────────────────
   * Same `display: contents` trick as the other split sections so
   * the section's own `.split` grid sees the desktop subtree's
   * children directly. */
  .day__desktop {
    display: contents;
  }

  .day__mobile {
    display: none;
  }

  @media (max-width: 767.98px) {
    .day__desktop {
      display: none;
    }
    .day__mobile {
      display: grid;
      gap: var(--space-l);
    }
    .day-in-life {
      display: block;
    }
  }

  .day__mobile-intro {
    margin: 0;
    max-width: 52ch;
  }

  .day-in-life {
    align-items: start;
  }

  /* Centreline divider — hidden by default (mobile collapses to
   * single column); revealed at ≥768px as its own grid track. */
  .day__divider {
    display: none;
  }

  @media (min-width: 768px) {
    .day-in-life {
      grid-template-columns: minmax(0, 1fr) auto minmax(0, 1fr);
      column-gap: var(--space-xl);
    }
    .day__divider {
      display: block;
      width: 1px;
      background: var(--border);
      align-self: stretch;
    }
  }

  /* LEFT — sticky big-title + tilted photo poster.
   *
   * `position: relative` makes this the containing block for the
   * absolutely-positioned photo poster. Everything inside it
   * (the title) flows normally; the poster is `position: absolute`
   * and overlays. */
  .day__left {
    position: relative;
  }

  @media (min-width: 768px) {
    .day__left {
      position: sticky;
      top: var(--sticky-top);
      align-self: start;
      max-height: calc(100lvh - var(--sticky-top));
    }
  }

  .day__title {
    display: block;
  }

  /* Photo trail container. Sits between/over the two title
   * lines like the SectionStory video, but larger so the trail's
   * 2–3 visible photos all fit. Each photo inside is absolutely
   * positioned at a deterministic (x, y, rotate) — see the
   * `data-day-trail-index` attributes; positions are written by
   * JS at init time from a fixed table. */
  .day__trail {
    position: absolute;
    inset: 8% 4% 8% 4%;
    z-index: 2;
    /* Capture pointer events on the trail container so hover
     * advances the photo stack like the CTA. Individual photos
     * keep `pointer-events: none` (set below) so they never
     * intercept the cursor. Touch devices skip the hover
     * interaction via the `(hover: hover)` query at the bottom. */
    pointer-events: auto;
    overflow: visible;
  }

  /* Touch / no-hover: the trail stays scroll-driven only. */
  @media (hover: none), (pointer: coarse) {
    .day__trail {
      pointer-events: none;
    }
  }

  .day__trail-photo {
    position: absolute;
    top: 0;
    left: 0;
    /* Each photo is roughly 4:5 polaroid-shaped so it reads as a
     * picture rather than a square chip. Width clamps so the
     * trail stays legible from tablet portrait up. */
    width: clamp(8rem, 16vw, 14rem);
    aspect-ratio: 4 / 5;
    overflow: hidden;
    border-radius: 4px;
    background: var(--card);
    box-shadow: 0 14px 36px rgba(0, 0, 0, 0.22);
    /* GSAP owns transform + opacity. Seeded at scale 0.4 / opacity
     * 0 in JS so the first paint never flashes the photos. The
     * photos themselves never intercept the cursor — the
     * `.day__trail` container catches all the pointer events. */
    pointer-events: none;
    will-change: transform, opacity;
    opacity: 0;
    transform-origin: center center;
  }

  .day__trail-photo :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* RIGHT — intro paragraph + timeslot list. */
  .day__right {
    display: flex;
    flex-direction: column;
  }

  .day__intro {
    margin: 0;
    max-width: 52ch;
    /* Generous space below so the first slot row lands well into
     * the reading band rather than hugging the intro. */
    padding-block-end: 25vh;
  }

  .day__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
  }

  /* Timeslot row. All rows render at the same opacity — the left
   * column's photo carries the "where am I in the day" signal. */
  .day-row {
    display: grid;
    gap: var(--space-s);
    padding-block: var(--space-l);
    border-block-start: 1px solid var(--border);
  }

  .day-row:first-child {
    padding-block-start: var(--space-l);
  }

  .day-row:last-child {
    padding-block-end: 30vh;
  }

  .day-row__time {
    margin: 0;
    opacity: 0.6;
  }

  .day-row__title,
  .day-row__description {
    margin: 0;
  }

  .day-row__description {
    opacity: 0.85;
    max-width: 60ch;
  }

  /* Mobile timeslot card — uses the design-system `--surface`
   * token so it picks up the section theme's brand surface
   * colour. */
  .day-card {
    width: 100%;
    aspect-ratio: 4 / 5;
    padding: var(--space-l) var(--space-m);
    background: var(--surface);
    color: var(--foreground);
    border-radius: 4px;
    display: flex;
    flex-direction: column;
    gap: var(--space-s);
    overflow-y: auto;
    overscroll-behavior: contain;
  }

  .day-card__time {
    margin: 0;
    opacity: 0.6;
  }

  .day-card__title {
    margin: 0;
    line-height: 1.15;
  }

  .day-card__description {
    margin: 0;
    opacity: 0.85;
  }

  @media (prefers-reduced-motion: reduce) {
    .day__photo-img {
      transition: none;
    }
  }
</style>

<script>
  /**
   * Day-in-life photo trail.
   *
   * Same shape as the CTA's image-trail (`.image-trail`), but
   * scroll-driven instead of cursor-driven. As the user scrolls
   * past slot rows on the right, each new "active" slot pops
   * its photo in at its designated position; the previous
   * photo demotes to a smaller scale; the one before demotes
   * further; older still fade out. Net effect: a small trail
   * of the last few slots stays visible, with the newest most
   * prominent.
   *
   * Photo positions and rotations are deterministic per index
   * (drawn from POSITIONS) so the layout is stable across
   * renders but feels organic.
   */
  import { gsap } from 'gsap';

  type TrailState = {
    rank: number; // 0 = newest, 1, 2 visible, >=3 hidden
    isSet: boolean;
    x: number;
    y: number;
  };

  // Per-slot deterministic placement within `.day__trail`. Values
  // are fractions of the container (x, y) plus a rotation in
  // degrees. Tweak by feel — the goal is variety without any one
  // photo overlapping another's centre. 8 entries match the slot
  // count; if more slots are added, the array wraps modulo length.
  const POSITIONS: Array<{ x: number; y: number; r: number }> = [
    { x: 0.20, y: 0.18, r: -6 },
    { x: 0.62, y: 0.10, r: 5 },
    { x: 0.30, y: 0.55, r: 8 },
    { x: 0.70, y: 0.50, r: -7 },
    { x: 0.15, y: 0.82, r: 4 },
    { x: 0.55, y: 0.78, r: -3 },
    { x: 0.40, y: 0.30, r: 7 },
    { x: 0.78, y: 0.74, r: -5 },
  ];

  const RANK_SCALE = [1, 0.78, 0.62];
  const TRANSITION = 0.55;
  const EASE = 'power3.out';

  function install() {
    if ((window as any).__dayInLifeHooked) return;
    (window as any).__dayInLifeHooked = true;

    const rows = document.querySelectorAll<HTMLElement>('[data-day-index]');
    const trail = document.querySelector<HTMLElement>('[data-day-trail]');
    const photos = trail
      ? Array.from(
          trail.querySelectorAll<HTMLElement>('[data-day-trail-photo]'),
        )
      : [];
    if (rows.length === 0 || photos.length === 0 || !trail) return;

    // Default position for each photo when no cursor is driving
    // the trail (scroll-only mode). Reads from POSITIONS as a
    // fraction of the trail container's current size.
    function defaultPosition(i: number) {
      const rect = trail!.getBoundingClientRect();
      const pos = POSITIONS[i % POSITIONS.length];
      return { x: rect.width * pos.x, y: rect.height * pos.y };
    }

    // Seed each photo: invisible, parked at its default spot,
    // pre-rotated. GSAP owns `transform` + `opacity` from here on.
    function placePhotos() {
      photos.forEach((el, i) => {
        const { x, y } = defaultPosition(i);
        const pos = POSITIONS[i % POSITIONS.length];
        gsap.set(el, {
          x,
          y,
          xPercent: -50,
          yPercent: -50,
          rotate: pos.r,
          scale: 0.4,
          opacity: 0,
        });
      });
    }
    placePhotos();
    window.addEventListener('resize', placePhotos);

    const state: TrailState[] = photos.map(() => ({
      rank: -1,
      isSet: false,
      x: 0,
      y: 0,
    }));
    let currentIndex = -1;

    /**
     * Show slot `i` at position (x, y).
     *  - If x,y omitted → use the slot's default POSITIONS spot.
     *    Used by the scroll observer.
     *  - If x,y given → snap the newest photo to the cursor.
     *    Used by hover. Older photos stay at their last
     *    position (their previous cursor coordinates), so the
     *    visible trail follows the cursor's recent path.
     */
    function showSlot(i: number, x?: number, y?: number) {
      const dx = x !== undefined && y !== undefined;
      if (i === currentIndex && !dx) return;
      currentIndex = i;

      const next =
        x !== undefined && y !== undefined ? { x, y } : defaultPosition(i);

      // Demote whatever was previously set — every set entry
      // walks back one rank. Anything past `RANK_SCALE.length`
      // fades out in render().
      state.forEach((s) => {
        if (s.isSet) s.rank += 1;
      });
      state[i] = { rank: 0, isSet: true, x: next.x, y: next.y };
      render();

      rows.forEach((row) => {
        const idx = Number(row.dataset.dayIndex);
        row.setAttribute('data-active', idx === i ? 'true' : 'false');
      });
    }

    function render() {
      state.forEach((p, i) => {
        const el = photos[i];
        if (!p.isSet) return;
        el.style.zIndex = String(POSITIONS.length - p.rank);

        if (p.rank === 0) {
          // Newest: snap to its (potentially cursor-driven)
          // position, then fade in + scale up.
          gsap.killTweensOf(el);
          gsap.set(el, { x: p.x, y: p.y, scale: 0.4, opacity: 0 });
          gsap.to(el, {
            scale: RANK_SCALE[0],
            opacity: 1,
            duration: TRANSITION,
            ease: EASE,
          });
        } else if (p.rank < RANK_SCALE.length) {
          // Visible older entries — stay where they last were
          // (their `p.x` / `p.y`), just shrink.
          gsap.to(el, {
            scale: RANK_SCALE[p.rank],
            opacity: 1,
            duration: TRANSITION,
            ease: EASE,
            overwrite: 'auto',
          });
        } else {
          // Past the visible window — fade out.
          gsap.to(el, {
            opacity: 0,
            duration: TRANSITION,
            ease: EASE,
            overwrite: 'auto',
          });
        }
      });
    }

    // Pick the active slot row the same way the cross-fader did
    // — top-heavy IntersectionObserver band so the row that's
    // just above the viewport centre wins. We also remember the
    // *scroll-driven* index separately so the trail can fall back
    // to it when the cursor leaves the trail area.
    let scrollIndex = 0;
    const ratios = new Map<number, number>();
    const io = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          const idx = Number((entry.target as HTMLElement).dataset.dayIndex);
          ratios.set(idx, entry.intersectionRatio);
        }
        let bestIdx = -1;
        let bestRatio = -1;
        ratios.forEach((r, i) => {
          if (r > bestRatio) {
            bestRatio = r;
            bestIdx = i;
          }
        });
        if (bestIdx >= 0 && bestRatio > 0) {
          scrollIndex = bestIdx;
          showSlot(bestIdx);
        }
      },
      {
        rootMargin: '-40% 0px -20% 0px',
        threshold: [0, 0.5, 1],
      },
    );
    rows.forEach((row) => io.observe(row));

    // Hover-driven trail. The newest photo SNAPS to the cursor;
    // older photos stay at their last position (their previous
    // cursor coordinates), so the visible trail follows the
    // cursor's recent path — same shape as the CTA's image trail.
    //
    // The slot index advances sequentially per move so each
    // pop-in is a different photo from the day. On `pointerleave`
    // we re-show the scroll-active slot at its default position
    // so the trail returns to "the photo for what you're reading".
    const HOVER_THRESHOLD_SQ = 80 * 80;
    let lastHoverX = -Infinity;
    let lastHoverY = -Infinity;
    let hoverHead = 0;

    function onPointerMove(e: PointerEvent) {
      const rect = trail!.getBoundingClientRect();
      const x = e.clientX - rect.left;
      const y = e.clientY - rect.top;
      const dx = x - lastHoverX;
      const dy = y - lastHoverY;
      if (dx * dx + dy * dy < HOVER_THRESHOLD_SQ) return;
      lastHoverX = x;
      lastHoverY = y;
      hoverHead = (hoverHead + 1) % photos.length;
      showSlot(hoverHead, x, y);
    }

    let leaveTimeout: number | undefined;
    function onPointerLeave() {
      window.clearTimeout(leaveTimeout);
      // Small grace period — quick out-and-back hovers don't
      // strobe the trail back to the scroll state and forward
      // again.
      leaveTimeout = window.setTimeout(() => {
        // Force a re-show by clearing currentIndex first, in
        // case scrollIndex matches the last hover-shown slot
        // (which would otherwise short-circuit showSlot's
        // dedupe). This re-promotes the scroll-active photo
        // to head and demotes the cursor-trail photos behind
        // it.
        currentIndex = -1;
        showSlot(scrollIndex);
      }, 180);
    }
    function onPointerEnter() {
      window.clearTimeout(leaveTimeout);
    }

    const supportsHover = window.matchMedia(
      '(hover: hover) and (pointer: fine)',
    ).matches;
    if (supportsHover) {
      trail.addEventListener('pointermove', onPointerMove, { passive: true });
      trail.addEventListener('pointerleave', onPointerLeave);
      trail.addEventListener('pointerenter', onPointerEnter);
    }

    // Show slot 0 immediately so the first paint has something
    // visible (otherwise the trail stays blank until the user
    // scrolls past the first row).
    requestAnimationFrame(() => showSlot(0));
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', install, { once: true });
  } else {
    install();
  }
  document.addEventListener('astro:page-load', () => {
    (window as any).__dayInLifeHooked = false;
    install();
  });
</script>
