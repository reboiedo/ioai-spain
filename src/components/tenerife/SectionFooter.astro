---
/**
 * SectionFooter — short terminating band at the bottom of the
 * Tenerife camp page.
 *
 * Placed AFTER `SectionApply` (the final scene) without a
 * `[data-scene]` wrapper so it isn't pinned. As the user scrolls
 * past the apply scene's pin window, this footer rises naturally
 * into view and the StickyJoinCta lifts up to stay above it
 * (see StickyJoinCta.astro for the lift logic — driven by an
 * IntersectionObserver on `[data-camp-footer]`).
 *
 * Currently 80px tall, themed to match whichever section came
 * before (passed via `theme` prop), with a 1px top rule.
 */

import { getRelativeLocaleUrl } from "astro:i18n";
import { LANGUAGES, useTranslations } from "@/i18n";
import type { Language } from "@/i18n";
import Dropdown from "@/components/ui/Dropdown.astro";

export interface Props {
  /** Theme palette to apply via `data-theme`. Defaults to orange to
   *  match the SectionApply scene above. */
  theme?: "orange" | "blue" | "yellow" | "neutral";
}

const { theme = "orange" } = Astro.props;

// Mirror Navigation.astro's locale-switcher option list so the
// footer Dropdown picks the right URL when the user changes the
// language.
const currentLocale = (Astro.currentLocale || "en") as Language;
const t = useTranslations(currentLocale);
const currentPath = Astro.url.pathname;
const pathWithoutLocale =
  currentLocale === "en" ? currentPath : currentPath.replace(`/${currentLocale}`, "") || "/";
const languageOptions = LANGUAGES.map((code) => ({
  value: getRelativeLocaleUrl(code, pathWithoutLocale),
  label: code === "en" ? "EN" : "ES",
  selected: currentLocale === code,
}));
---

<footer class="camp-footer" data-theme={theme} data-camp-footer>
  <p class="camp-footer__copy">
    © {new Date().getFullYear()} IOAI Spain · Tenerife Camp
  </p>
  <div class="camp-footer__lang">
    <Dropdown
      options={languageOptions}
      size="small"
      ariaLabel={t.ui.nav.selectLanguage}
      onChange="window.location.href = this.value"
    />
  </div>
</footer>

<style>
  .camp-footer {
    position: relative;
    /* 80px keeps the band visually small — just enough to host a
     * single line of text plus a touch of breathing room. The
     * theme's `--background` / `--foreground` carry through via
     * `data-theme`, matching the section directly above. */
    min-height: 80px;
    padding: var(--space-m) var(--section-inline);
    border-block-start: 1px solid var(--border);
    background: var(--background);
    color: var(--foreground);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-m);
    /* Above the sticky scene-stack so the footer paints over the
     * previously-sticky Pricing / Apply layers as it rises into view.
     * Must beat the highest [data-scene-index] z-index used in the
     * scene-stack ladder (currently 12 = Apply). */
    z-index: 20;
  }

  .camp-footer__copy {
    margin: 0;
    font-family: var(--font-body);
    font-size: 0.875rem;
    opacity: 0.7;
  }

  /* Borderless language switcher in the footer — mirrors the v2
   * nav variant, paints text/chevron in the section's
   * `--foreground` (white on coloured backgrounds). */
  .camp-footer__lang :global(.dropdown) {
    border: none;
  }
  .camp-footer__lang :global(.dropdown:hover) {
    border: none;
  }
  .camp-footer__lang :global(.dropdown:focus-within) {
    box-shadow: none;
  }
  .camp-footer__lang :global(.dropdown__text) {
    color: var(--foreground);
  }
  /* The chevron asset is a static SVG; this filter pair paints any
   * opaque source white, matching the nav variant. */
  .camp-footer__lang :global(.dropdown__icon) {
    filter: brightness(0) invert(1);
  }
</style>
