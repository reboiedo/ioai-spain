---
/**
 * TeamCard — a coach cell whose picture area doubles as a bio panel.
 *
 *   - collapsed: square portrait at the top, name (always 2 lines),
 *     role (always 1 line). No bio visible — the card stays short.
 *   - expanded: the same square area swaps the portrait for the bio
 *     text. Name and role stay put. Nothing else on the card moves.
 *
 * Only the square face animates between states (portrait → bio).
 * Card outer dimensions are identical in both states, so every
 * sibling card holds its position on click.
 *
 *   <TeamCard initials="VA" name="Vladimir Arkhipov" bio="…" />
 */

import { Picture, type ImageMetadata } from "astro:assets";

export interface Props {
  initials: string;
  name: string;
  role?: string;
  bio: string;
  /** Optional portrait. When omitted, the initials placeholder is shown. */
  image?: ImageMetadata;
}

const { initials, name, role, bio, image } = Astro.props;

/*
 * Split the name into the first token and the remainder so the
 * display always hard-wraps after the first name. That gives every
 * card a two-line name regardless of column width — no reliance on
 * natural wrap, no risk of "Ivan Zagorulko" sitting on one line
 * while "Alberto Leyva Guerra" sits on three.
 */
const spaceIndex = name.indexOf(" ");
const nameFirst = spaceIndex === -1 ? name : name.slice(0, spaceIndex);
const nameRest = spaceIndex === -1 ? "" : name.slice(spaceIndex + 1);
---

<button class="team-card" type="button" aria-expanded="false" data-team-card>
  <!-- The square face — both portrait and bio layer here, absolutely
       positioned, swapped on click. The container owns the 1:1 box.
       The corner signifier (plus/x) lives on top of both layers so
       it's always visible. -->
  <div class="team-card__face">
    <div class="team-card__portrait" data-initials={initials} data-team-portrait>
      {image && (
        <Picture
          class="team-card__photo"
          src={image}
          alt={`Portrait of ${name}`}
          formats={["avif", "webp"]}
          widths={[240, 360, 480, 640]}
          sizes="(min-width: 768px) 22vw, 45vw"
          loading="lazy"
        />
      )}
    </div>
    <div class="team-card__bio" data-team-bio>
      <p class="font-body-s team-card__bio-text">{bio}</p>
    </div>
    <span class="team-card__cue" aria-hidden="true"></span>
  </div>

  <h3 class="font-h3 team-card__name">
    <span class="team-card__name-line">{nameFirst}</span>
    <span class="team-card__name-line">{nameRest || "\u00A0"}</span>
  </h3>
  <p class="font-body-s team-card__role">{role ?? ""}</p>
</button>

<style>
  .team-card {
    /* Button reset so the whole cell is one click target without
     * the default UA chrome. */
    appearance: none;
    background: transparent;
    border: none;
    color: inherit;
    font: inherit;
    margin: 0;
    padding: 0;
    text-align: left;
    cursor: pointer;
    /* Kill the iOS/Android tap-highlight grey flash on click. */
    -webkit-tap-highlight-color: transparent;
    /* Disable double-tap-zoom on mobile (the click triggers the
     * portrait↔bio swap, no zoom expected) and remove the 300ms
     * synthetic-click delay. */
    touch-action: manipulation;
    /* Some mobile browsers translate the button by 1px on :active,
     * which makes the name + role text below the face nudge on
     * tap. Force a stable transform so the text stays put. */
    transform: translateZ(0);

    display: grid;
    gap: var(--space-s);
  }

  .team-card:active,
  .team-card:focus {
    transform: translateZ(0);
  }

  .team-card:focus-visible {
    outline: 2px solid var(--foreground);
    outline-offset: 4px;
  }

  /* Square face — the swapping surface. Portrait and bio stack
   * inside via `position: absolute`, so toggling which one is
   * visible can't change the card's height. Uses the theme's
   * lighter surface tint as the placeholder fill so missing
   * portraits read as on-theme. */
  .team-card__face {
    position: relative;
    width: 100%;
    aspect-ratio: 1 / 1;
    border-radius: 4px;
    overflow: hidden;
    background: var(--surface);
  }

  .team-card__portrait,
  .team-card__bio {
    position: absolute;
    inset: 0;
  }

  /* Portrait layer. Initials are placeholder content until real
   * photography lands. */
  .team-card__portrait {
    display: grid;
    place-items: center;
  }

  /* Initials fallback — only shown when no real photo is present.
   * `:empty` doesn't quite work because the <Image> renders into the
   * portrait container, so we instead suppress the pseudo when a
   * `.team-card__photo` exists via `:has()`. */
  .team-card__portrait::after {
    content: attr(data-initials);
    font-family: var(--font-headings);
    font-weight: 600;
    font-size: clamp(1.5rem, 3vw, 2.5rem);
    letter-spacing: -0.02em;
    color: var(--foreground-muted);
  }

  .team-card__portrait:has(.team-card__photo)::after {
    display: none;
  }

  /* Real photo fills the square face, cropped to centre. */
  .team-card__photo {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
  }

  /* Bio layer. Long bios are allowed to scroll inside the square
   * so the card never grows. `overscroll-behavior: contain` keeps
   * that scroll from bubbling to the page when we're reading a
   * card's full bio. */
  .team-card__bio {
    padding: var(--space-m);
    overflow-y: auto;
    overscroll-behavior: contain;
    opacity: 0;
    pointer-events: none;
    /* Soft fade at the edges so long bios don't get hard-cut against
     * the card's bottom edge when they overflow. Same pattern as the
     * polaroid cards in SectionActivities: `--m-top` is 0 by default
     * (top reads flush); JS bumps it once the user scrolls. `--m-bottom`
     * is on by default to telegraph "more below"; JS clears it at the
     * end of the scroll. Both vars also collapse when the bio fits
     * without overflow (`data-overflow="false"`). */
    --m-top: 0px;
    --m-bottom: 2.75rem;
    mask-image: linear-gradient(
      to bottom,
      transparent 0,
      #000 var(--m-top),
      #000 calc(100% - var(--m-bottom)),
      transparent 100%
    );
    -webkit-mask-image: linear-gradient(
      to bottom,
      transparent 0,
      #000 var(--m-top),
      #000 calc(100% - var(--m-bottom)),
      transparent 100%
    );
  }
  .team-card__bio[data-scrolled="true"] {
    --m-top: 2.75rem;
  }
  .team-card__bio[data-at-bottom="true"] {
    --m-bottom: 0px;
  }
  .team-card__bio[data-overflow="false"] {
    --m-top: 0px;
    --m-bottom: 0px;
  }

  .team-card__bio-text {
    margin: 0;
  }

  /* Corner signifier — a two-line plus that rotates into an × when
   * the card is expanded. Lives above both layers so it's always
   * visible. Purely decorative; the whole card is the hit target. */
  .team-card__cue {
    position: absolute;
    top: var(--space-s);
    right: var(--space-s);
    width: 1.25rem;
    height: 1.25rem;
    pointer-events: none;
    color: var(--foreground-muted);
  }

  .team-card__cue::before,
  .team-card__cue::after {
    content: '';
    position: absolute;
    inset: 50% 0 auto 0;
    height: 1.5px;
    background: currentColor;
    transform-origin: center;
    transition: transform 220ms ease;
  }

  .team-card__cue::after {
    transform: rotate(90deg);
  }

  .team-card[aria-expanded="true"] .team-card__cue::before {
    transform: rotate(45deg);
  }

  .team-card[aria-expanded="true"] .team-card__cue::after {
    transform: rotate(-45deg);
  }

  /* Cue colour flips to card-foreground contrast when the bio
   * layer is showing (bio panel uses the card's background tint). */
  .team-card[aria-expanded="true"] .team-card__cue {
    color: var(--foreground);
  }

  /* Expanded state — swap the two layers' visibility. The actual
   * crossfade is driven by GSAP in the <script> below so we can
   * control the timing / easing centrally; these rules are the
   * resting end-states for each side. */
  .team-card[aria-expanded="true"] .team-card__portrait {
    opacity: 0;
    pointer-events: none;
  }

  .team-card[aria-expanded="true"] .team-card__bio {
    opacity: 1;
    pointer-events: auto;
  }

  /* Name — always two lines. Each `.team-card__name-line` is a
   * block-level span, and the template hard-splits the string at
   * the first space so `Ivan` / `Zagorulko` stacks reliably no
   * matter how wide the column is. If a card has only a single-
   * word name the second span renders a non-breaking space so the
   * 2-line height is still reserved. */
  .team-card__name {
    margin: 0;
  }

  .team-card__name-line {
    display: block;
  }

  /* Role — always 1 line of reserved space, even when absent.
   * Negative `margin-block-start` offsets the parent's `gap:
   * var(--space-s)` so the role sits tighter to the name above —
   * the wider gap remains between portrait and name. */
  .team-card__role {
    margin: 0;
    margin-block-start: calc(var(--space-s) * -0.66);
    opacity: 0.7;
    min-height: 1lh;
  }
</style>

<script>
  /**
   * Crossfade the square face between portrait and bio on click.
   *
   * The card's outer dimensions never change, so no Flip is
   * needed — a simple opacity + subtle scale tween on the two
   * absolutely-positioned layers. One delegated listener covers
   * every card and survives Astro view transitions.
   */
  import { gsap } from 'gsap';

  /* Drive top/bottom fade masks based on the bio's scroll position
   * — same pattern as the polaroid cards. Cheap getter on each scroll
   * tick; only writes the dataset when the value changes. */
  function updateBioMask(bio: HTMLElement) {
    const overflow = bio.scrollHeight > bio.clientHeight + 1;
    const next = overflow ? 'true' : 'false';
    if (bio.dataset.overflow !== next) bio.dataset.overflow = next;
    if (!overflow) return;
    const scrolled = bio.scrollTop > 4 ? 'true' : 'false';
    if (bio.dataset.scrolled !== scrolled) bio.dataset.scrolled = scrolled;
    const atBottom =
      bio.scrollTop + bio.clientHeight >= bio.scrollHeight - 2
        ? 'true'
        : 'false';
    if (bio.dataset.atBottom !== atBottom) bio.dataset.atBottom = atBottom;
  }

  function install() {
    if ((window as any).__teamCardHooked) return;
    (window as any).__teamCardHooked = true;

    // Attach a scroll listener to every bio panel so the masks
    // update as the user reads. Listener is on the bio element
    // itself (not delegated) because `scroll` doesn't bubble.
    document.querySelectorAll<HTMLElement>('[data-team-bio]').forEach((bio) => {
      bio.addEventListener('scroll', () => updateBioMask(bio), { passive: true });
    });

    document.addEventListener('click', (e) => {
      const card = (e.target as HTMLElement | null)?.closest<HTMLButtonElement>(
        '[data-team-card]',
      );
      if (!card) return;

      const portrait = card.querySelector<HTMLElement>('[data-team-portrait]');
      const bio = card.querySelector<HTMLElement>('[data-team-bio]');
      if (!portrait || !bio) return;

      const isOpen = card.getAttribute('aria-expanded') === 'true';
      const willOpen = !isOpen;
      card.setAttribute('aria-expanded', String(willOpen));

      const [entering, leaving] = willOpen ? [bio, portrait] : [portrait, bio];

      // Kill any in-flight tween on the same layers so rapid clicks
      // don't stack animations.
      gsap.killTweensOf([entering, leaving]);

      gsap
        .timeline()
        .to(leaving, {
          opacity: 0,
          scale: 0.96,
          duration: 0.25,
          ease: 'power2.in',
        })
        .fromTo(
          entering,
          { opacity: 0, scale: 1.04 },
          {
            opacity: 1,
            scale: 1,
            duration: 0.3,
            ease: 'power2.out',
            clearProps: 'scale',
          },
          '-=0.1',
        );

      // After opening, run the mask check once layout settles. The
      // bio's `clientHeight` is the same in both states (the face is
      // a fixed square), but `scrollTop` resets to 0 on open, which
      // we want reflected immediately so the top fade clears.
      if (willOpen) {
        requestAnimationFrame(() => updateBioMask(bio));
      }
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', install, { once: true });
  } else {
    install();
  }
  document.addEventListener('astro:page-load', () => {
    (window as any).__teamCardHooked = false;
    install();
  });
</script>
