---
/**
 * SectionStory — narrative scene inspired by follow.art's "Our Story".
 *
 * Layout (desktop):
 *   ┌──────────────────────────────────────┬──────────────────────────┐
 *   │  Item 1                              │                          │
 *   │  ─────────────────                   │   ╔══════════════╗        │
 *   │  Item 2                              │   ║  HUGE LINE 1 ║        │
 *   │  ─────────────────                   │   ║              ║        │
 *   │  Item 3                              │   ║  ┌────────┐  ║        │
 *   │  ─────────────────                   │   ║  │ video  │  ║        │
 *   │  …                                   │   ║  │ poster │  ║        │
 *   │                                      │   ║  └────────┘  ║        │
 *   │                                      │   ║  HUGE LINE 2 ║        │
 *   │                                      │   ╚══════════════╝        │
 *   └──────────────────────────────────────┴──────────────────────────┘
 *
 * Right column is sticky — the giant 2-line title and the overlapping
 * tilted video poster stay in view while the user scrolls past the
 * left column's items.
 *
 * Mobile: title on top (still 2 stacked lines, sized down), video
 * tile below it, item list flows underneath.
 *
 * Items are a content-only stub for now — replace as copy lands.
 */

import HeroTitleStack from "@/components/tenerife/HeroTitleStack.astro";
import HScrollMobile from "@/components/tenerife/HScrollMobile.astro";
import { Image, type ImageMetadata } from "astro:assets";
import harbourLogo from "@/assets/harbour-space-logo.svg";
import leaguesLogo from "@/assets/icons/leagues-logo.svg";

export interface Props {
  /** Tenerife theme palette to apply via `data-theme`. */
  theme?: "orange" | "blue" | "yellow" | "neutral";
  /** Two-line stacked title. */
  titleLines?: [string, string];
  /** Optional video poster image (any aspect). */
  posterImage?: ImageMetadata;
  /** URL the video tile links to / opens. */
  videoUrl?: string;
}

interface Item {
  label: string;
  body: string;
}

const {
  theme = "blue",
  titleLines = ["ABOUT", "US"],
  posterImage,
  videoUrl,
} = Astro.props;

// Approach pillars — content lifted from the (now-removed) Approach
// scene. Lives here so the Story scene carries the camp's full
// narrative on a single page.
const items: Item[] = [
  {
    label: "The academics and the summer are both real",
    body: "The learning program and the extracurricular program are built with equal care. Mornings go deep into AI. Afternoons go to Tenerife's beaches, trails, and historic towns. Neither half is filler, and you don't have to sacrifice one to get the other.",
  },
  {
    label: "Two tracks, one community",
    body: "Foundations and applied ML run in parallel, plus a team research sprint that cuts across both. Mornings you're in your track; afternoons and evenings the whole cohort is together — meals, labs, problem sets, hikes.",
  },
  {
    label: "The highest level is in the room",
    body: "Students selected from the IOAI Spain qualifier, taught by researchers who publish at NeurIPS and ICML, with industry mentors from Barcelona's AI labs. Ambition is the baseline.",
  },
];

// Quick-facts trio shown right under the lede paragraph. The
// `Dates` value is a placeholder — swap once the calendar is set.
const facts: { label: string; value: string }[] = [
  { label: "Language", value: "English" },
  { label: "Ages", value: "14–18" },
  { label: "Dates", value: "TBD" },
];
---

<div class="scene" data-scene>
  <section
    class="section scene__layer scene__layer--tilt story"
    data-theme={theme}
  >
    <div class="story__layout">
      <!-- LEFT — scrollable list of items. Plain block flow on
           desktop so it scrolls with the page; the right column is
           sticky and stays in view as the user passes by. The big
           lede paragraph sits above the item list. -->
      <div class="story__items">
        <!-- Intro block — lede + sponsors sit together as one
             opening statement. The lede caps at 70ch; the sponsors
             below are three equal cards (label + two logos) on the
             theme's `--surface` surface so they read as a distinct
             credit strip while staying in the same visual block. -->
        <div class="story__intro">
          <p class="font-body-l story__lede">
            For over a decade behind the scenes of olympiad coaching and
            AI research, we've watched ambitious students chase the same
            handful of opportunities — and noticed how rarely those
            opportunities reach beyond a familiar inner circle. The
            Tenerife camp exists to widen that circle.
          </p>

          <div class="story__sponsors">
            <p class="font-caption story__sponsors-label">Powered by</p>
            <a
              class="story__sponsors-cell"
              href="https://harbour.space"
              target="_blank"
              rel="noopener noreferrer"
              aria-label="Harbour.Space"
            >
              <Image
                src={harbourLogo}
                alt="Harbour.Space"
                class="story__sponsors-logo story__sponsors-logo--harbour"
              />
            </a>
            <a
              class="story__sponsors-cell"
              href="https://leaguesofcodes.com"
              target="_blank"
              rel="noopener noreferrer"
              aria-label="Leagues of Code"
            >
              <Image
                src={leaguesLogo}
                alt="Leagues of Code"
                class="story__sponsors-logo story__sponsors-logo--leagues"
              />
            </a>
          </div>
        </div>

        <!-- Quick facts row — three label/value pairs sat horizontally
             beneath the intro block. Framed by horizontal rules so it
             reads as a distinct section. -->
        <ul class="story__facts">
          {facts.map((f) => (
            <li class="story-fact">
              <span class="font-body-s story-fact__label">{f.label}</span>
              <span class="font-h4 story-fact__value">{f.value}</span>
            </li>
          ))}
        </ul>

        <!-- Approach pillars — horizontal scroll of surface cards.
             Each pillar carries title + body on its own card; the
             user swipes through them. `HScrollMobile` handles the
             edge-bleed + progress bar + scroll-snap. -->
        <HScrollMobile itemWidth="min(80%, 360px)">
          {items.map((it, i) => (
            <article class="story-item" data-story-item-index={i}>
              <h3 class="font-h4 story-item__label">{it.label}</h3>
              <p class="font-body story-item__body">{it.body}</p>
            </article>
          ))}
        </HScrollMobile>
      </div>

      <!-- Vertical centreline divider. Lives in its own grid track
           between the two content columns and `align-self: stretch`
           so it spans the WHOLE section height — the items column
           (much taller than the sticky right column) sets the row
           height, so the divider always reaches the section's
           bottom regardless of the sticky element's max-height. -->
      <div class="story__divider" aria-hidden="true"></div>

      <!-- RIGHT — sticky big-title + overlapping tilted video poster.
           `HeroTitleStack` sizes each line so the shorter line's
           letters match the longer line's height (right-anchored). -->
      <div class="story__right">
        <div class="story__title">
          <HeroTitleStack
            lines={[
              // Top line stays flat — only the bottom line carries
              // the scroll-driven per-letter scaleY animation so
              // the stretch reads as intent rather than noise.
              { text: titleLines[0], noStretch: true },
              { text: titleLines[1] },
            ]}
            defaultAlign="right"
            gap="var(--space-s)"
            maxWidth="80%"
          />
        </div>

        <!-- Video poster — tilted, sits between the two title lines
             (overlapping both visually). Click to play (currently
             links out — wire to inline player later). -->
        <a
          class="story__video"
          href={videoUrl ?? "#"}
          aria-label="Play story video"
        >
          {posterImage ? (
            <Image
              class="story__video-img"
              src={posterImage}
              alt=""
              widths={[480, 720, 960]}
              sizes="(min-width: 768px) 30vw, 70vw"
              loading="lazy"
            />
          ) : (
            <div class="story__video-placeholder" aria-hidden="true"></div>
          )}
          <span class="story__video-play" aria-hidden="true">▶</span>
        </a>
      </div>
    </div>
  </section>
</div>

<style>
  /* The section is intentionally tall — long enough for the user
   * to scroll through the whole item list while the right column
   * stays pinned. `min-height` is a sensible floor; the natural
   * height grows with the item count. */
  .story {
    min-height: 100lvh;
  }

  /* Three-column grid on desktop; single-column stack on mobile.
   * Mobile order is overridden so the title + video block appears
   * FIRST (above the lede + items) — DOM order has items first
   * for desktop layout, but mobile flips it via grid order. */
  .story__layout {
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    gap: var(--space-2xl);
  }

  @media (max-width: 767.98px) {
    .story__items {
      order: 2;
    }
    .story__divider {
      order: 1;
      /* Already display: none on mobile — order is a no-op but
       * harmless if the divider ever becomes visible later. */
    }
    .story__right {
      order: 0;
    }
  }

  @media (min-width: 768px) {
    /* Both content columns equal (`1fr / 1fr`) — matches the
     * half-and-half split used by every other section. The divider
     * is `auto` (1px) between them. */
    .story__layout {
      grid-template-columns: minmax(0, 1fr) auto minmax(0, 1fr);
      column-gap: var(--space-2xl);
    }
  }

  .story__divider {
    display: none;
  }

  @media (min-width: 768px) {
    /* Vertical line between the columns. `align-self: stretch` makes
     * it fill the full grid row, which is sized by the (much taller)
     * left items column — so the divider runs the entire section
     * height regardless of the right column's sticky max-height. */
    .story__divider {
      display: block;
      width: 1px;
      background: var(--border);
      align-self: stretch;
    }
  }

  /* ── LEFT: lede + scrollable items ──────────────────────────── */
  .story__items {
    display: flex;
    flex-direction: column;
  }

  /* Intro block — lede + sponsors share a single visual block,
   * capped at 70ch. `gap` controls space ABOVE the sponsors group
   * (between the lede and "POWERED BY"). The bottom margin
   * controls space BELOW the sponsors group before the facts row. */
  .story__intro {
    display: flex;
    flex-direction: column;
    gap: var(--space-xl);
    max-width: 70ch;
    margin: 0 0 var(--space-xl);
  }

  .story__lede {
    margin: 0;
  }

  /* Facts list. Mobile: Apple-store-style vertical rows (label
   * left, value right) separated by thin rules. Desktop: reverts
   * to a 3-column horizontal grid via the media query below.
   * `margin-block-end` adds breathing room before the pillar
   * cards below so the closing rule isn't kissing them. */
  .story__facts {
    list-style: none;
    margin: 0 0 var(--space-l);
    padding: 0;
    display: flex;
    flex-direction: column;
    border-block-start: 1px solid var(--border);
  }

  .story-fact {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--space-m);
    padding-block: var(--space-m);
    border-block-end: 1px solid var(--border);
  }


  .story-fact__label {
    opacity: 0.7;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .story-fact__value {
    margin: 0;
    text-align: right;
  }

  @media (min-width: 768px) {
    /* Three columns side-by-side, tighter framing — top border
     * only (the first pillar below provides its own border-top
     * which doubles as the facts row's bottom rule). No bottom
     * padding or margin: the pillar's own padding-block-start
     * carries the visual separation. */
    .story__facts {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: var(--space-m);
      padding-block: var(--space-l);
      margin-block-end: 0;
    }
    .story-fact {
      display: flex;
      flex-direction: column;
      align-items: flex-start;
      justify-content: flex-start;
      gap: var(--space-2xs, 0.25rem);
      padding-block: 0;
      border-block-end: none;
    }
    .story-fact__value {
      text-align: left;
    }
  }

  /* Sponsors row — three cells: "POWERED BY" label, then the two
   * logos. Mobile: 2-column grid. The label spans BOTH columns on
   * row 1; the two logos sit side-by-side on row 2 (left-anchored).
   * Desktop: 3 equal columns via the media query below. */
  .story__sponsors {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    /* Tight gap between label and logos so the group reads as one
     * unit (the spacing AROUND the group is bigger via the
     * `.story__intro` gap + margin). */
    gap: var(--space-2xs, 0.5rem);
  }

  .story__sponsors-label {
    grid-column: 1 / -1;
  }

  @media (min-width: 768px) {
    .story__sponsors {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
    .story__sponsors-label {
      grid-column: auto;
    }
  }

  /* Sponsor cell — clickable wrapper around each logo. Mobile:
   * transparent (blends with section bg, no padding) and
   * left-anchored so the logos line up flush with the "POWERED
   * BY" label above. Desktop: surface card with centred logo via
   * the media query below. */
  .story__sponsors-cell {
    background: var(--background);
    color: var(--foreground);
    padding: 0;
    border-radius: 4px;
    display: flex;
    align-items: center;
    justify-content: flex-start;
    min-height: 4rem;
    text-decoration: none;
    transition: transform 220ms ease, opacity 220ms ease;
  }

  @media (min-width: 768px) {
    .story__sponsors-cell {
      background: var(--surface);
      padding: var(--space-m);
      justify-content: center;
    }
  }

  .story__sponsors-cell:hover {
    transform: translateY(-2px);
    opacity: 0.92;
  }

  /* Plain-text label (no card background) — sits in column 1 of the
   * sponsors row, vertically centred against the logo cards. */
  .story__sponsors-label {
    margin: 0;
    align-self: center;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    opacity: 0.7;
  }

  .story__sponsors-logo {
    height: 2.25rem;
    width: auto;
    /* Logos ship in their brand colour; flatten to white so they
     * read against any of the section themes' surface colours. */
    filter: brightness(0) invert(1);
  }

  /* Pillar — mobile: surface card inside the horizontal scroll.
   * Desktop: reverts to vertical row with internal label/body
   * grid via the media query below. */
  .story-item {
    background: var(--surface);
    color: var(--foreground);
    padding: var(--space-l);
    border-radius: 4px;
    display: flex;
    flex-direction: column;
    gap: var(--space-s);
    align-self: stretch;
  }

  .story-item__label {
    margin: 0;
  }

  .story-item__body {
    margin: 0;
    opacity: 0.85;
  }

  @media (min-width: 768px) {
    /* Strip the card chrome — desktop pillars are full-width rows
     * with horizontal rules between, label left, body right. */
    .story-item {
      background: transparent;
      color: inherit;
      padding: 0;
      border-radius: 0;
      padding-block: var(--space-xl);
      border-block-start: 1px solid var(--border);
      display: grid;
      grid-template-columns: minmax(0, 14rem) minmax(0, 1fr) minmax(0, 36ch);
      column-gap: 0;
      align-items: start;
      align-self: auto;
    }

    .story-item:last-child {
      border-block-end: 1px solid var(--border);
    }

    .story-item__body {
      grid-column: 3;
      max-width: 36ch;
    }
  }

  /* ── RIGHT: sticky title + tilted video ─────────────────────── */
  .story__right {
    /* `position: relative` makes this the containing block for the
     * absolutely-positioned video below. Video uses % units
     * relative to this column for both size and offset, so it
     * scales proportionally with the column at every viewport. */
    position: relative;
  }

  @media (min-width: 768px) {
    .story__right {
      position: sticky;
      top: var(--sticky-top);
      align-self: start;
      /* Cap the sticky height to a single viewport so the title
       * + video block always fits within the visible area when
       * stuck. */
      max-height: calc(100lvh - var(--sticky-top));
    }
  }

  /* Wrapper around `HeroTitleStack`. The stack handles its own
   * line layout / width math; we just give it room to breathe. */
  .story__title {
    display: block;
  }

  /* Tilted video poster — fixed 4:5 aspect ratio, sized as a % of
   * its containing block. Same `-8deg` tilt on every viewport so
   * the visual matches across breakpoints. Anchored absolute on
   * desktop (overlapping the title); falls back to normal flow,
   * centred under the title on mobile. */
  .story__video {
    display: block;
    /* `position: absolute` on every viewport — placed inside
     * `.story__right` which is the relative containing block.
     * Both size and offset are pure % of the column, so the
     * video's relationship to the title scales identically on
     * mobile and desktop. */
    position: absolute;
    width: 35%;
    bottom: 6%;
    left: 18%;
    aspect-ratio: 4 / 5;
    margin: 0;
    transform: rotate(-8deg);
    z-index: 2;
    border-radius: 4px;
    overflow: hidden;
    box-shadow: 0 12px 32px rgba(0, 0, 0, 0.22);
    text-decoration: none;
    color: inherit;
    background: var(--card);
  }


  .story__video-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .story__video-placeholder {
    width: 100%;
    height: 100%;
    background:
      linear-gradient(
        135deg,
        color-mix(in oklab, var(--foreground) 22%, transparent) 0%,
        color-mix(in oklab, var(--foreground) 6%, transparent) 100%
      );
  }

  /* Play button overlay — centred, soft glass disc with a triangle
   * glyph. Pointer-events on the parent <a> so the whole tile is
   * clickable; this glyph is purely decorative. */
  .story__video-play {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 3rem;
    height: 3rem;
    border-radius: 999px;
    display: grid;
    place-items: center;
    background: rgba(0, 0, 0, 0.55);
    color: #fff;
    font-size: 1rem;
    backdrop-filter: blur(4px);
    pointer-events: none;
  }

  .story__video:hover .story__video-play {
    background: rgba(0, 0, 0, 0.7);
  }
</style>
