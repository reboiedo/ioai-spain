---
/**
 * SectionStory — narrative scene inspired by follow.art's "Our Story".
 *
 * Layout (desktop):
 *   ┌──────────────────────────────────────┬──────────────────────────┐
 *   │  Item 1                              │                          │
 *   │  ─────────────────                   │   ╔══════════════╗        │
 *   │  Item 2                              │   ║  HUGE LINE 1 ║        │
 *   │  ─────────────────                   │   ║              ║        │
 *   │  Item 3                              │   ║  ┌────────┐  ║        │
 *   │  ─────────────────                   │   ║  │ video  │  ║        │
 *   │  …                                   │   ║  │ poster │  ║        │
 *   │                                      │   ║  └────────┘  ║        │
 *   │                                      │   ║  HUGE LINE 2 ║        │
 *   │                                      │   ╚══════════════╝        │
 *   └──────────────────────────────────────┴──────────────────────────┘
 *
 * Right column is sticky — the giant 2-line title and the overlapping
 * tilted video poster stay in view while the user scrolls past the
 * left column's items.
 *
 * Mobile: title on top (still 2 stacked lines, sized down), video
 * tile below it, item list flows underneath.
 *
 * Items are a content-only stub for now — replace as copy lands.
 */

import HeroTitleStack from "@/components/tenerife/HeroTitleStack.astro";
import HScrollMobile from "@/components/tenerife/HScrollMobile.astro";
import { Image, Picture } from "astro:assets";
import type { ImageMetadata } from "astro";
import harbourLogo from "@/assets/harbour-space-logo.svg";
import leaguesLogo from "@/assets/icons/leagues-logo.svg";
import spikes from "@/assets/tenerife/story/spikes.svg";
import { useTenerifeTranslations, type Language } from "@/i18n/tenerife";

// Auto-discover the rotating poster set. Filenames must follow the
// `reel-N.jpg` pattern (e.g. `reel-1.jpg`, `reel-2.jpg`, …) so the
// glob can pick them up cleanly without sweeping in unrelated
// images that happen to live in the same folder (the legacy
// `01-placeholder.jpg` set is kept around for now but excluded).
const storyPosters: ImageMetadata[] = Object.entries(
  import.meta.glob<{ default: ImageMetadata }>(
    "@/assets/tenerife/story/reel-*.{jpg,jpeg,png,webp,avif}",
    { eager: true },
  ),
)
  .sort(([a], [b]) => a.localeCompare(b))
  .map(([, mod]) => mod.default);

export interface Props {
  /** Locale for this render. */
  locale: Language;
  /** Tenerife theme palette to apply via `data-theme`. */
  theme?: "orange" | "blue" | "yellow" | "neutral";
  /** Two-line stacked title. Falls back to translated values. */
  titleLines?: [string, string];
  /** Optional video poster image (any aspect). */
  posterImage?: ImageMetadata;
  /** Mux playback ID for the camp story video. */
  muxPlaybackId?: string;
  /** Metadata title sent with Mux Data analytics. Defaults to a
   *  generic placeholder; override per-page once the real cut lands. */
  muxVideoTitle?: string;
  /** Aspect ratio of the source video, as a CSS `aspect-ratio` value
   *  (e.g. `"9 / 16"` for vertical, `"16 / 9"` for horizontal). Drives
   *  the overlay frame's shape so the player sits flush with no
   *  letter/pillarboxing in the modal. Defaults to vertical since
   *  the current camp story video is shot 9:16. */
  muxAspect?: string;
}

const {
  locale,
  theme = "blue",
  titleLines,
  posterImage,
  muxPlaybackId = "1y00ba9KsVZQmIFVHZ501fYzWV005yM467bY1Ae006AIdnQ",
  muxVideoTitle = "Sample day",
  muxAspect = "9 / 16",
} = Astro.props;

const t = useTenerifeTranslations(locale);
const resolvedTitleLines: [string, string] =
  titleLines ?? [t.story.titleLine1, t.story.titleLine2];
const items = t.story.items;
const facts = t.story.facts;

// Sponsor logos — keyed by name so the data-driven sponsor list
// from translations can pick the right asset by index.
const sponsorLogos = [harbourLogo, leaguesLogo];
---

<div class="scene" data-scene data-scene-index="2">
  <section
    class="section scene__layer scene__layer--tilt story"
    data-theme={theme}
  >
    <div class="story__layout">
      <!-- LEFT — scrollable list of items. Plain block flow on
           desktop so it scrolls with the page; the right column is
           sticky and stays in view as the user passes by. The big
           lede paragraph sits above the item list. -->
      <div class="story__items">
        <!-- Intro block — lede only. The sponsor logos used to sit
             here as a credit strip; they now live under the first
             item ("Backed by Harbour.Space and Leagues of Code")
             where they're directly tied to the copy that names
             them. -->
        <div class="story__intro">
          <p class="font-body-l story__lede">{t.story.lede}</p>
        </div>

        <!-- Quick facts row — three label/value pairs sat horizontally
             beneath the intro block. Framed by horizontal rules so it
             reads as a distinct section. -->
        <ul class="story__facts">
          {facts.map((f) => (
            <li class="story-fact">
              <span class="font-body-s story-fact__label">{f.label}</span>
              <span class="font-h4 story-fact__value">{f.value}</span>
            </li>
          ))}
        </ul>

        <!-- Approach pillars — horizontal scroll of surface cards.
             Each pillar carries title + body on its own card; the
             user swipes through them. `HScrollMobile` handles the
             edge-bleed + progress bar + scroll-snap. -->
        <HScrollMobile itemWidth="min(86%, 380px)">
          {items.map((it, i) => (
            <article class="story-item" data-story-item-index={i}>
              <h2 class="font-h4 story-item__label">{it.label}</h2>
              <p class="font-body story-item__body">{it.body}</p>
              {/* First pillar names Harbour.Space + Leagues of Code,
                  so the sponsor logos sit directly under its body
                  instead of as a separate credit strip. The block
                  is grid-placed in column 3 on desktop so it lines
                  up with the body text above it. */}
              {i === 0 && (
                <div class="story__sponsors">
                  <div class="story__sponsors-logos">
                    {t.story.sponsors.map((sponsor, si) => (
                      <a
                        class="story__sponsors-cell"
                        href={sponsor.href}
                        target="_blank"
                        rel="noopener noreferrer"
                        aria-label={sponsor.name}
                      >
                        <Image
                          src={sponsorLogos[si]}
                          alt={sponsor.name}
                          class={`story__sponsors-logo story__sponsors-logo--${sponsor.name.toLowerCase().replace(/[^a-z]+/g, '-')}`}
                        />
                      </a>
                    ))}
                  </div>
                </div>
              )}
            </article>
          ))}
        </HScrollMobile>
      </div>

      <!-- Vertical centreline divider. Lives in its own grid track
           between the two content columns and `align-self: stretch`
           so it spans the WHOLE section height — the items column
           (much taller than the sticky right column) sets the row
           height, so the divider always reaches the section's
           bottom regardless of the sticky element's max-height. -->
      <div class="story__divider" aria-hidden="true"></div>

      <!-- RIGHT — sticky big-title + overlapping tilted video poster.
           `HeroTitleStack` sizes each line so the shorter line's
           letters match the longer line's height (right-anchored). -->
      <div class="story__right" data-locale={locale}>
        <div class="story__title">
          <HeroTitleStack
            lines={[
              // Top line stays flat — only the bottom line carries
              // the scroll-driven per-letter scaleY animation so
              // the stretch reads as intent rather than noise.
              { text: resolvedTitleLines[0], noStretch: true },
              { text: resolvedTitleLines[1] },
            ]}
            defaultAlign="right"
            gap="var(--space-s)"
            maxWidth="80%"
          />
        </div>

        <!-- Video + spikes wrapper. Wrap is the single positioned
             element on the column; spikes are nested INSIDE so they
             travel with the video tile if its position is tweaked
             (e.g. Spanish locale needs a different anchor to clear
             the longer title). -->
        <div class="story__video-wrap">
        <!-- Decorative spikes — anchored so the bottom-right corner
             sits at the top-left corner of the video tile (with a
             small gap). Same stepped tilt animation as the
             testimonials chat bubble and the SAFETY icon. -->
        <img
          class="story__spikes"
          src={spikes.src}
          width={spikes.width}
          height={spikes.height}
          alt=""
          aria-hidden="true"
          loading="lazy"
          decoding="async"
        />

        <!-- Video poster — tilted, sits between the two title lines.
             Click opens the Mux player overlay below. -->
        <button
          type="button"
          class="story__video"
          aria-label={t.story.videoAriaLabel}
          data-story-video-trigger
        >
          {posterImage ? (
            <Picture
              class="story__video-img"
              src={posterImage}
              alt=""
              formats={["avif", "webp"]}
              widths={[160, 240, 320, 480]}
              sizes="(min-width: 768px) 240px, 35vw"
              loading="lazy"
            />
          ) : storyPosters.length > 0 ? (
            <div class="story__video-stack" data-story-stack>
              {storyPosters.map((src, i) => (
                <Picture
                  class="story__video-img story__video-img--stacked"
                  src={src}
                  alt=""
                  formats={["avif", "webp"]}
                  widths={[160, 240, 320, 480]}
                  sizes="(min-width: 768px) 240px, 35vw"
                  loading={i === 0 ? "eager" : "lazy"}
                  data-story-frame
                  data-active={i === 0 ? "true" : undefined}
                />
              ))}
            </div>
          ) : (
            <div class="story__video-placeholder" aria-hidden="true"></div>
          )}
          <span class="story__video-play" aria-hidden="true">▶</span>
        </button>
        </div>
      </div>

      <!-- Mux player overlay. Hidden until the trigger above is
           clicked. The mux-player web component is registered by
           the inline `<script>` below; until then the overlay is
           inert (display: none + aria-hidden). Closes on:
             - The X button
             - Backdrop click (anywhere outside the player)
             - Escape key
           Each close path also pauses the player so audio doesn't
           keep playing in the background. -->
      <div
        class="story__overlay"
        data-story-overlay
        data-playback-id={muxPlaybackId}
        data-video-title={muxVideoTitle}
        aria-hidden="true"
        inert
        style={`--overlay-aspect: ${muxAspect};`}
      >
        <div class="story__overlay-backdrop" data-story-overlay-backdrop></div>
        <div class="story__overlay-frame" role="dialog" aria-modal="true" aria-label={t.story.videoAriaLabel}>
          <button
            type="button"
            class="story__overlay-close"
            data-story-overlay-close
            aria-label="Close video"
          >
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <path d="M5 5 L19 19 M19 5 L5 19" />
            </svg>
          </button>
          <!-- Mux player mount point — empty until first user click.
               The `import '@mux/mux-player'` below registers the
               custom element early, but we only inject the actual
               <mux-player> tag on `open()`. With no element in the
               DOM, the player can't run thumbnail probes, audio-
               context init, or background work that occasionally
               surfaced as "video starts when I click random
               things". After the first open it stays in the DOM
               (paused on close) so re-opens are instant. The
               playback-id and metadata title are read off the
               overlay's data-* attributes so the markup stays
               declarative and props-driven. -->
          <div class="story__overlay-player"></div>
        </div>
      </div>
    </div>
  </section>
</div>

<style>
  /* The section is intentionally tall — long enough for the user
   * to scroll through the whole item list while the right column
   * stays pinned. `min-height` is a sensible floor; the natural
   * height grows with the item count. */
  .story {
    min-height: 100lvh;
  }

  /* Three-column grid on desktop; single-column stack on mobile.
   * Mobile order is overridden so the title + video block appears
   * FIRST (above the lede + items) — DOM order has items first
   * for desktop layout, but mobile flips it via grid order. */
  .story__layout {
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    gap: var(--space-2xl);
  }

  @media (max-width: 767.98px) {
    .story__items {
      order: 2;
    }
    .story__divider {
      order: 1;
      /* Already display: none on mobile — order is a no-op but
       * harmless if the divider ever becomes visible later. */
    }
    .story__right {
      order: 0;
    }
  }

  @media (min-width: 768px) {
    /* Both content columns equal (`1fr / 1fr`) — matches the
     * half-and-half split used by every other section. The divider
     * is `auto` (1px) between them. */
    .story__layout {
      grid-template-columns: minmax(0, 1fr) auto minmax(0, 1fr);
      column-gap: var(--space-2xl);
    }
  }

  .story__divider {
    display: none;
  }

  @media (min-width: 768px) {
    /* Vertical line between the columns. `align-self: stretch` makes
     * it fill the full grid row, which is sized by the (much taller)
     * left items column — so the divider runs the entire section
     * height regardless of the right column's sticky max-height. */
    .story__divider {
      display: block;
      width: 1px;
      background: var(--border);
      align-self: stretch;
    }
  }

  /* ── LEFT: lede + scrollable items ──────────────────────────── */
  .story__items {
    display: flex;
    flex-direction: column;
  }

  /* Intro block — lede + sponsors share a single visual block,
   * capped at 70ch. `gap` controls space ABOVE the sponsors group
   * (between the lede and "POWERED BY"). The bottom margin
   * controls space BELOW the sponsors group before the facts row. */
  .story__intro {
    display: flex;
    flex-direction: column;
    gap: var(--space-xl);
    max-width: 70ch;
    margin: 0 0 var(--space-xl);
  }

  .story__lede {
    margin: 0;
  }

  /* Facts list. Mobile: Apple-store-style vertical rows (label
   * left, value right) separated by thin rules. Desktop: reverts
   * to a 3-column horizontal grid via the media query below.
   * `margin-block-end` adds breathing room before the pillar
   * cards below so the closing rule isn't kissing them. */
  .story__facts {
    list-style: none;
    margin: 0 0 var(--space-l);
    padding: 0;
    display: flex;
    flex-direction: column;
    border-block-start: 1px solid var(--border);
  }

  .story-fact {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--space-m);
    padding-block: var(--space-m);
    border-block-end: 1px solid var(--border);
  }


  .story-fact__label {
    opacity: 0.7;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .story-fact__value {
    margin: 0;
    text-align: right;
  }

  @media (min-width: 768px) {
    /* Three columns side-by-side, tighter framing — top border
     * only (the first pillar below provides its own border-top
     * which doubles as the facts row's bottom rule). No bottom
     * padding or margin: the pillar's own padding-block-start
     * carries the visual separation. */
    .story__facts {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: var(--space-m);
      padding-block: var(--space-l);
      margin-block-end: 0;
    }
    .story-fact {
      display: flex;
      flex-direction: column;
      align-items: flex-start;
      justify-content: flex-start;
      gap: var(--space-2xs, 0.25rem);
      padding-block: 0;
      border-block-end: none;
    }
    .story-fact__value {
      text-align: left;
    }
  }

  /* Sponsors block — sits directly under the FIRST pillar's body
   * ("Backed by Harbour.Space and Leagues of Code"). Stacked
   * label + logo row, no card chrome around the cells (the pillar
   * row above is the visual frame). On desktop the block lands in
   * column 3 of the `.story-item` grid so it lines up beneath the
   * body text; on mobile it just stacks naturally inside the
   * scroll card. */
  .story__sponsors {
    display: flex;
    flex-direction: column;
    gap: var(--space-2xs, 0.5rem);
    margin-block-start: var(--space-m);
  }

  /* Two logos side-by-side, sharing the row equally. Each cell
   * gets `flex: 1` so the row never overflows; the logos inside
   * use `max-width: 100%` + `height: auto` so they scale down
   * proportionally to fit whatever width their cell ends up at. */
  .story__sponsors-logos {
    display: flex;
    flex-wrap: nowrap;
    column-gap: var(--space-l);
    align-items: center;
  }

  /* Sponsor cell — clickable wrapper around each logo. Transparent
   * background; the logo is the entire visual element. Each cell
   * gets `flex: 1` so the two cells share the row equally; the
   * logo inside scales to fit. `min-width: 0` so the cell can
   * shrink below its content's intrinsic width when needed. */
  .story__sponsors-cell {
    background: transparent;
    color: var(--foreground);
    padding: 0;
    flex: 1 1 0;
    min-width: 0;
    display: flex;
    align-items: center;
    justify-content: flex-start;
    text-decoration: none;
    transition: transform 220ms ease, opacity 220ms ease;
  }

  .story__sponsors-cell:hover {
    transform: translateY(-2px);
    opacity: 0.92;
  }

  /* Plain-text "POWERED BY" label above the logo row. */
  .story__sponsors-label {
    margin: 0;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    opacity: 0.7;
  }

  @media (min-width: 768px) {
    /* Desktop: place the sponsors block in column 3 of the
     * `.story-item` grid (same column as the body) so it sits
     * directly beneath the body copy. */
    .story-item .story__sponsors {
      grid-column: 3;
    }
  }

  /* Logo sizes by max-height (visual cap) and max-width: 100% so
   * the SVG scales DOWN to fit its cell when the row is narrow,
   * but never grows past 2.25rem tall on a roomy desktop column.
   * `width: auto` + `height: auto` let the natural aspect drive
   * whichever dimension isn't pinned. `object-fit: contain` is a
   * belt-and-braces guard for any non-SVG that lands here. */
  .story__sponsors-logo {
    max-height: 2.25rem;
    max-width: 100%;
    width: auto;
    height: auto;
    object-fit: contain;
    /* Logos ship in their brand colour; flatten to white so they
     * read against any of the section themes' surface colours. */
    filter: brightness(0) invert(1);
  }

  /* Pillar — mobile: surface card inside the horizontal scroll.
   * Desktop: reverts to vertical row with internal label/body
   * grid via the media query below. */
  .story-item {
    background: var(--surface);
    color: var(--foreground);
    padding: var(--space-l);
    border-radius: 4px;
    display: flex;
    flex-direction: column;
    gap: var(--space-s);
    align-self: stretch;
  }

  .story-item__label {
    margin: 0;
  }

  .story-item__body {
    margin: 0;
    opacity: 0.85;
  }

  @media (min-width: 768px) {
    /* Strip the card chrome — desktop pillars are full-width rows
     * with horizontal rules between, label left, body right. */
    .story-item {
      background: transparent;
      color: inherit;
      padding: 0;
      border-radius: 0;
      padding-block: var(--space-xl);
      border-block-start: 1px solid var(--border);
      display: grid;
      grid-template-columns: minmax(0, 14rem) minmax(var(--space-l), 1fr) minmax(0, 68ch);
      column-gap: 0;
      align-items: start;
      align-self: auto;
    }

    .story-item:last-child {
      border-block-end: 1px solid var(--border);
    }

    .story-item__body {
      grid-column: 3;
      max-width: 68ch;
    }
  }

  /* ── RIGHT: sticky title + tilted video ─────────────────────── */
  .story__right {
    /* `position: relative` makes this the containing block for the
     * absolutely-positioned video below. Video uses % units
     * relative to this column for both size and offset, so it
     * scales proportionally with the column at every viewport. */
    position: relative;
  }

  @media (min-width: 768px) {
    .story__right {
      position: sticky;
      top: var(--sticky-top);
      align-self: start;
      /* Cap the sticky height to a single viewport so the title
       * + video block always fits within the visible area when
       * stuck. */
      max-height: calc(100lvh - var(--sticky-top));
    }
  }

  /* Wrapper around `HeroTitleStack`. The stack handles its own
   * line layout / width math; we just give it room to breathe. */
  .story__title {
    display: block;
  }

  /* Wrap — the single positioned anchor that holds BOTH the video
   * tile and the spikes. By making the wrap the absolute element,
   * any locale-specific position tweak (e.g. Spanish nudges below)
   * carries the spikes along automatically — they don't need their
   * own per-locale rule.
   *
   * Defaults match the previous video position (`left:18%;
   * bottom:6%; width:35%; aspect-ratio:4/5`) so nothing visually
   * shifts for English.
   *
   * `--video-left` / `--video-bottom` are CSS custom props so a
   * locale-scoped rule below can override them with one line. */
  .story__video-wrap {
    position: absolute;
    width: var(--video-width, 35%);
    aspect-ratio: 4 / 5;
    left: var(--video-left, 18%);
    bottom: var(--video-bottom, 6%);
    z-index: 2;
  }

  /* Spanish title ("NUESTRA / HISTORIA") fills far more horizontal
   * space than English ("ABOUT / US"), and the video at the default
   * left:18% covers the second line. Push the wrap further left and
   * down so it tucks under the title rather than over it. The
   * spikes ride along because they're positioned relative to the
   * wrap, not the column. */
  .story__right[data-locale="es"] {
    --video-left: 4%;
    --video-width: 28%;
  }
  .story__right[data-locale="es"] .story__video-wrap {
    bottom: auto;
    top: -4%;
  }

  /* Spikes — anchored to the wrap (i.e. to the video). Bottom-right
   * corner of the spikes sits just outside the top-left corner of
   * the video tile with a small gap. Stays put if the video moves.
   * Stepped tilt loop matches the testimonials / SAFETY icon. */
  .story__spikes {
    position: absolute;
    right: 100%;
    bottom: 100%;
    margin-right: -2%;
    margin-bottom: -18%;
    width: clamp(5rem, 11vw, 9rem);
    height: auto;
    transform-origin: 100% 100%;
    animation: story-spikes-tilt 2s steps(6) infinite;
    pointer-events: none;
    z-index: 3;
    color: var(--foreground);
  }

  @keyframes story-spikes-tilt {
    0%, 100% { transform: rotate(-4deg); }
    50% { transform: rotate(3deg); }
  }

  @media (prefers-reduced-motion: reduce) {
    .story__spikes {
      animation: none;
      transform: rotate(-2deg);
    }
  }

  @media (max-width: 767.98px) {
    .story__spikes {
      width: clamp(3.5rem, 16vw, 6rem);
    }
  }

  /* Tilted video poster — now positioned RELATIVE inside the wrap
   * so the wrap controls layout and the tile fills it. `-8deg`
   * tilt is unchanged. */
  .story__video {
    display: block;
    position: relative;
    width: 100%;
    height: 100%;
    margin: 0;
    transform: rotate(-8deg);
    border-radius: 4px;
    overflow: hidden;
    box-shadow: 0 12px 32px rgba(0, 0, 0, 0.22);
    text-decoration: none;
    color: inherit;
    background: var(--card);
  }


  .story__video-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* Fading poster stack — every frame absolutely fills the tile;
   * only the one with `data-active="true"` is visible. CSS
   * transitions handle the crossfade; a small script flips the
   * active frame every 4s. */
  .story__video-stack {
    position: absolute;
    inset: 0;
  }

  .story__video-img--stacked {
    position: absolute;
    inset: 0;
    opacity: 0;
    transition: opacity 900ms ease;
  }

  .story__video-img--stacked[data-active="true"] {
    opacity: 1;
  }

  @media (prefers-reduced-motion: reduce) {
    .story__video-img--stacked {
      transition: none;
    }
  }

  .story__video-placeholder {
    width: 100%;
    height: 100%;
    background:
      linear-gradient(
        135deg,
        var(--foreground-muted) 0%,
        var(--foreground-muted) 100%
      );
  }

  /* Play button overlay — centred, soft glass disc with a triangle
   * glyph. Pointer-events on the parent <a> so the whole tile is
   * clickable; this glyph is purely decorative. */
  .story__video-play {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 3rem;
    height: 3rem;
    border-radius: 999px;
    display: grid;
    place-items: center;
    background: rgba(0, 0, 0, 0.55);
    color: #fff;
    font-size: 1rem;
    backdrop-filter: blur(4px);
    pointer-events: none;
  }

  .story__video:hover .story__video-play {
    background: rgba(0, 0, 0, 0.7);
  }

  /* `.story__video` is now a `<button>` (was an `<a>`) — strip the
   * default UA chrome so it visually behaves like the original tile. */
  button.story__video {
    appearance: none;
    border: 0;
    margin: 0;
    font: inherit;
    cursor: pointer;
  }

  /* ── Mux player overlay ─────────────────────────────────────────
   * Fixed full-screen modal that holds the lazy-mounted Mux player.
   *
   * IMPORTANT: This element is **portaled to `document.body`** on
   * init by the JS below. It HAS to be rendered as a direct child
   * of body — the section it's authored inside lives under
   * `.scene__layer--tilt`, which receives a GSAP-driven `transform`
   * on scroll. A transformed ancestor traps `position: fixed`
   * children, so without the portal the overlay would scroll with
   * the section AND get clipped to the section's stacking context
   * (where the nav at `z-index: 1000` and StickyJoinCta at `z: 50`
   * paint on top of it).
   *
   * `z-index: 9999` puts the overlay decisively above the nav
   * (`z: 1000`) and any other floating chrome.
   *
   * Hidden by default via `aria-hidden="true"` — the rule below
   * keys off that attribute so we don't fight specificity later. */
  .story__overlay {
    position: fixed;
    inset: 0;
    z-index: 9999;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: var(--space-l);
    /* Closed state: invisible + non-interactive. Stays in the DOM
     * so JS can flip aria-hidden to open without re-rendering. */
    opacity: 0;
    pointer-events: none;
    transition: opacity 220ms ease;
  }

  .story__overlay[aria-hidden="false"] {
    opacity: 1;
    pointer-events: auto;
  }

  .story__overlay-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.85);
    /* Slight backdrop-filter blur for a subtle "stage lights down"
     * effect on the page underneath. Behind a flag because not all
     * browsers support it; CSS gracefully falls back to the solid bg. */
    backdrop-filter: blur(8px);
  }

  /* Frame sizes itself to whatever aspect ratio the source video
   * ships in (set via the `--overlay-aspect` custom property on
   * `.story__overlay`). Width starts at 100% and aspect-ratio
   * computes the height; if that height exceeds `max-height: 88vh`
   * the browser clamps height AND proportionally shrinks width so
   * the aspect ratio is preserved. `max-width: 1100px` caps very
   * wide desktop horizontal videos.
   *
   * This depends on aspect-ratio + max-height interacting correctly
   * (Chrome 88+, Firefox 89+, Safari 15+). The previous
   * `width: auto; height: auto` pattern was bugged: with no primary
   * axis defined, flex layout resolved both to 0 → frame collapsed
   * and the player rendered invisibly. */
  .story__overlay-frame {
    position: relative;
    aspect-ratio: var(--overlay-aspect, 9 / 16);
    width: 100%;
    max-width: 1100px;
    max-height: 88vh;
    background: #000;
    border-radius: 8px;
    overflow: hidden;
    box-shadow: 0 24px 64px rgba(0, 0, 0, 0.5);
  }

  .story__overlay-player {
    width: 100%;
    height: 100%;
  }

  /* The lazy-mounted `<mux-player>` fills its parent. Custom
   * elements default to `display: inline` — without overriding to
   * `block`, `width: 100%` and `height: 100%` resolve against the
   * inline box and the player effectively renders at 0×0. The
   * `:global` opt-out is needed because the custom element's tag
   * isn't scoped by Astro's `data-astro-cid-*` rewriter. */
  .story__overlay-player :global(mux-player) {
    display: block;
    width: 100%;
    height: 100%;
    min-height: 100%;
    --controls-backdrop-color: rgba(0, 0, 0, 0.4);
  }

  .story__overlay-close {
    position: absolute;
    top: var(--space-s);
    right: var(--space-s);
    z-index: 2;
    width: 2.5rem;
    height: 2.5rem;
    padding: 0;
    appearance: none;
    border: 0;
    border-radius: 999px;
    background: rgba(0, 0, 0, 0.6);
    color: #fff;
    cursor: pointer;
    display: grid;
    place-items: center;
    transition: background 180ms ease, transform 180ms ease;
  }

  .story__overlay-close:hover {
    background: rgba(0, 0, 0, 0.85);
    transform: scale(1.05);
  }

  .story__overlay-close svg {
    width: 1.25rem;
    height: 1.25rem;
    fill: none;
    stroke: currentColor;
    stroke-width: 2;
    stroke-linecap: round;
  }

  /* When the overlay is open, lock the body scroll so the video
   * stays the focal point. JS toggles `data-story-overlay-open` on
   * the html element to scope this. */
  :global(html[data-story-overlay-open="true"]) {
    overflow: hidden;
  }
</style>

<script>
  /**
   * Story poster stack — crossfades through frames every 4s.
   * Pure DOM: toggles `data-active` on the next frame; CSS handles
   * the opacity transition.
   */
  function initStoryStack() {
    const stacks = document.querySelectorAll<HTMLElement>('[data-story-stack]');
    stacks.forEach((stack) => {
      const frames = Array.from(
        stack.querySelectorAll<HTMLElement>('[data-story-frame]'),
      );
      if (frames.length < 2) return;
      let i = 0;
      const tick = () => {
        frames[i].removeAttribute('data-active');
        i = (i + 1) % frames.length;
        frames[i].setAttribute('data-active', 'true');
      };
      const id = window.setInterval(tick, 4000);
      // Stop the interval if the section is removed (Astro view
      // transitions). Re-init runs on `astro:page-load`.
      stack.dataset.storyStackTimer = String(id);
    });
  }

  function cleanupStoryStack() {
    document.querySelectorAll<HTMLElement>('[data-story-stack]').forEach((s) => {
      const id = Number(s.dataset.storyStackTimer);
      if (id) window.clearInterval(id);
      delete s.dataset.storyStackTimer;
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initStoryStack, { once: true });
  } else {
    initStoryStack();
  }
  document.addEventListener('astro:before-swap', cleanupStoryStack);
  document.addEventListener('astro:page-load', initStoryStack);

  /**
   * Story video overlay — Mux Player web component + open/close.
   *
   * Following the canonical pattern from
   * https://www.mux.com/docs/guides/mux-player-web — the side-effect
   * import registers the `<mux-player>` custom element. We keep the
   * static import (vs. a lazy dynamic one): the dynamic path worked
   * in dev but the prod bundle race produced a "Source Not
   * Supported / DEMUXER_ERROR_COULD_NOT_PARSE" intermittently, and
   * shipping a 250 kB unused chunk to LCP is a smaller cost than a
   * broken video. We still get most of the perf win because the
   * <mux-player> element itself isn't mounted in the DOM until the
   * first user click on the poster (see `ensurePlayer`) — no
   * thumbnail probes, no Cast SDK init while idle. */
  import '@mux/mux-player';

  function initStoryOverlay() {
    const overlay = document.querySelector<HTMLElement>('[data-story-overlay]');
    if (!overlay || overlay.dataset.hooked === '1') return;
    overlay.dataset.hooked = '1';

    // Portal to body. The overlay is authored inside `.scene__layer
    // --tilt`, which gets a GSAP-driven `transform` on scroll —
    // transformed ancestors trap fixed children, so without this
    // move the overlay would scroll with the section, get clipped
    // by the section's stacking context (nav + StickyJoinCta paint
    // on top of it), and ignore the viewport entirely. Lifting it
    // to body decouples it from all that. Astro's scoped-CSS
    // `data-astro-cid-*` attributes ride along with the element so
    // the styles still apply post-move.
    if (overlay.parentElement !== document.body) {
      document.body.appendChild(overlay);
    }

    const trigger = document.querySelector<HTMLElement>('[data-story-video-trigger]');
    const closeBtn = overlay.querySelector<HTMLElement>('[data-story-overlay-close]');
    const backdrop = overlay.querySelector<HTMLElement>('[data-story-overlay-backdrop]');
    const playerMount = overlay.querySelector<HTMLElement>('.story__overlay-player');
    if (!trigger || !closeBtn || !backdrop || !playerMount) return;

    // Read the playback id + metadata title once from data-* attrs.
    // The overlay element carries them so the surrounding markup
    // stays declarative even though the <mux-player> is created
    // imperatively on first open.
    const playbackId = overlay.dataset.playbackId ?? '';
    const videoTitle = overlay.dataset.videoTitle ?? '';

    // Lazily-created singleton — we only create the <mux-player>
    // element after the first user click on the poster, so until
    // then there is literally no mux-player in the DOM, which
    // means no thumbnail probes, no Cast SDK init, no possibility
    // of a stray click somewhere on the page upgrading the player
    // and starting the video.
    //
    // We build the element with `innerHTML` rather than
    // `createElement` + per-attribute `setAttribute`. The HTML
    // parser path lets the custom element pick up every attribute
    // in a single upgrade pass; the imperative path raced against
    // mux-player's upgrade and produced a "Source Not Supported /
    // DEMUXER_ERROR_COULD_NOT_PARSE" once playback-id arrived
    // after the element had already started fetching.
    function escAttr(v: string): string {
      return v.replace(/&/g, '&amp;').replace(/"/g, '&quot;');
    }
    let player: HTMLElement | null = null;
    function ensurePlayer(): HTMLElement {
      if (player) return player;
      playerMount!.innerHTML = `
        <mux-player
          data-story-overlay-player
          playback-id="${escAttr(playbackId)}"
          stream-type="on-demand"
          accent-color="#ffffff"
          metadata-video-title="${escAttr(videoTitle)}"
          video-title="${escAttr(videoTitle)}"
          preload="none"
          style="width: 100%; height: 100%;"
        ></mux-player>
      `;
      player = playerMount!.querySelector<HTMLElement>('mux-player');
      return player!;
    }

    function open() {
      overlay!.setAttribute('aria-hidden', 'false');
      // `inert` makes the overlay's children unreachable via tab,
      // matching the aria-hidden state. We toggle it together.
      overlay!.removeAttribute('inert');
      document.documentElement.setAttribute('data-story-overlay-open', 'true');
      // Stop Lenis. CSS `overflow: hidden` doesn't suffice — Lenis
      // intercepts wheel/touch events and continues scrolling the
      // page underneath. The page-init script listens for this
      // event and calls `lenis.stop()`.
      window.dispatchEvent(new CustomEvent('tenerife:lock-scroll'));
      const el = ensurePlayer();
      // mux-player exposes the underlying media-element API on the
      // custom element itself — `.play()` is a real method. Most
      // browsers allow autoplay on user-initiated click; if the
      // browser refuses (rare on a click), the user just sees the
      // pre-load poster and can hit play.
      try {
        (el as any).play?.();
      } catch (_) {
        /* user can hit play manually */
      }
    }

    function close() {
      overlay!.setAttribute('aria-hidden', 'true');
      overlay!.setAttribute('inert', '');
      document.documentElement.removeAttribute('data-story-overlay-open');
      window.dispatchEvent(new CustomEvent('tenerife:unlock-scroll'));
      if (player) {
        try {
          (player as any).pause?.();
        } catch (_) {}
      }
    }

    trigger.addEventListener('click', (e) => {
      e.preventDefault();
      open();
    });
    closeBtn.addEventListener('click', close);
    backdrop.addEventListener('click', close);

    // Escape closes only when the overlay is open.
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && overlay!.getAttribute('aria-hidden') === 'false') {
        close();
      }
    });
  }

  function cleanupStoryOverlay() {
    const overlay = document.querySelector<HTMLElement>('[data-story-overlay]');
    if (!overlay) return;
    overlay.removeAttribute('data-hooked');
    overlay.setAttribute('aria-hidden', 'true');
    overlay.setAttribute('inert', '');
    document.documentElement.removeAttribute('data-story-overlay-open');
    const player = overlay.querySelector<HTMLElement>('[data-story-overlay-player]');
    if (player) {
      try { (player as any).pause?.(); } catch (_) {}
    }
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initStoryOverlay, { once: true });
  } else {
    initStoryOverlay();
  }
  document.addEventListener('astro:page-load', initStoryOverlay);
  document.addEventListener('astro:before-swap', cleanupStoryOverlay);
</script>
