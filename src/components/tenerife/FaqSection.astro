---
/**
 * FaqSection — the "FAQ" scene.
 *
 * Same shape as TracksSection: title + intro on the sticky left,
 * a scrollable list of expandable drawers on the right with line
 * separators and a `+` / `×` toggle icon.
 *
 * Each drawer uses the same animated `<details>` pattern as
 * Course (grid-template-rows: 0fr → 1fr trick + GSAP Flip on
 * toggle), but kept inline here so this section doesn't pull in
 * the Course-specific scroll-reserve plumbing meant for the
 * tracks scene.
 */

import SectionTitle from "@/components/tenerife/SectionTitle.astro";

export interface Props {
  /** Tenerife theme palette to apply via `data-theme`. */
  theme?: "orange" | "blue" | "yellow" | "neutral";
}

const { theme = "yellow" } = Astro.props;

interface Faq {
  question: string;
  answer: string;
}

const faqs: Faq[] = [
  {
    question: "Who is the camp for?",
    answer:
      "Curious students aged 14–18, with or without prior coding experience. Beginners pick the Beginner track and work up from zero; more advanced students pick the Advanced track and dive straight into olympiad-level material. Everyone shares the extracurricular programme.",
  },
  {
    question: "Do you need prior coding experience?",
    answer:
      "Not for the Beginner tracks. Python, AI, Game Development and Design all start from zero — the goal is to build real intuition, not throw students in the deep end. The Advanced tracks (Mathematics, Algorithms, AI) assume comfort with the basics and move fast.",
  },
  {
    question: "What's included in the price?",
    answer:
      "Two weeks of academic programme (35 hours across one chosen track), the full extracurricular programme (excursions, sports, workshops, cultural visits), a 4-star shared-room hotel stay with all meals included, transport between activities, and camp insurance.",
  },
  {
    question: "What language is the camp in?",
    answer:
      "Everything happens in English — academic sessions, group activities, and day-to-day camp life. For most students this becomes a genuine language immersion alongside the technical learning.",
  },
  {
    question: "Where do students stay?",
    answer:
      "At a 4-star hotel in Puerto de la Cruz on the northern coast of Tenerife, two minutes from Martiánez beach. Rooms are shared between three campers, with breakfast, lunch and dinner included on site every day.",
  },
  {
    question: "How is supervision handled?",
    answer:
      "Nineteen dedicated supervisors are on the ground at all times, plus eight coaches who are accessible for help with anything — learning, activities, or in between. All staff are trained to be attentive to individual needs and age groups.",
  },
  {
    question: "What do students need to bring?",
    answer:
      "A laptop is required for the academic programme. Beyond that: comfortable summer clothing for two weeks, swimwear, sunscreen, sturdy shoes for hikes, and a refillable water bottle. A full packing list is sent two weeks before camp.",
  },
  {
    question: "How does travel work?",
    answer:
      "Tenerife North and Tenerife South airports are both well-connected to mainland Europe. Group transfers between the airport and the hotel are organised on the published arrival and departure days; outside that window, transfers can be arranged for a small fee.",
  },
];
---

<div class="scene" data-scene>
  <section
    class="section scene__layer scene__layer--tilt faq"
    data-theme={theme}
  >
    <div class="split faq__grid">
      <!-- Left: title + intro paragraph in a single sticky block. -->
      <div class="faq__intro">
        <SectionTitle lines={["FAQ"]} />
        <p class="font-body section-copy faq__intro-copy">
          Most parents and students arrive with the same handful of
          questions. Here's the short version. If you're left with
          something specific, write to us — the team replies within
          a working day.
        </p>
      </div>

      <!-- Right: stacked list of <details> drawers. -->
      <div class="faq__list">
        {faqs.map((f) => (
          <details class="faq-item">
            <summary class="faq-item__summary">
              <span class="font-h4 faq-item__question">{f.question}</span>
              <span class="faq-item__icon" aria-hidden="true"></span>
            </summary>
            <div class="faq-item__body-wrap">
              <div class="faq-item__body">
                <p class="font-body-s faq-item__answer">{f.answer}</p>
              </div>
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>
</div>

<style>
  /* Left column — same sticky intro pattern as Tracks. */
  .faq__intro {
    display: flex;
    flex-direction: column;
    gap: var(--space-l);
  }

  .faq__intro-copy {
    margin: 0;
  }

  @media (min-width: 768px) {
    .faq__intro {
      position: sticky;
      top: var(--sticky-top);
      align-self: start;
    }
  }

  /* Right column — stack of drawer rows.
   *
   * `--faq-extra` is set once on mount (see <script> below) to
   * the tallest answer's measured height, then reserved as
   * `padding-block-end`. The scene's pin sees a stable, worst-
   * case scene height from the start, so opening any drawer
   * doesn't clip into the next scene. */
  .faq__list {
    display: grid;
    padding-block-end: var(--faq-extra, 0px);
  }

  .faq-item {
    border-block-start: 1px solid var(--border);
  }

  .faq-item:last-of-type {
    border-block-end: 1px solid var(--border);
  }

  .faq-item__summary {
    cursor: pointer;
    list-style: none;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-m);
    padding-block: var(--space-l);
  }

  .faq-item__summary::-webkit-details-marker {
    display: none;
  }

  .faq-item__question {
    margin: 0;
  }

  /* `+` / `×` icon — two pseudo-element strokes, rotated to form
   * a cross when the row is open. */
  .faq-item__icon {
    position: relative;
    flex: none;
    width: 1.5rem;
    height: 1.5rem;
  }

  .faq-item__icon::before,
  .faq-item__icon::after {
    content: '';
    position: absolute;
    inset: 50% 0 auto 0;
    height: 1.5px;
    background: currentColor;
    transform-origin: center;
    transition: transform 220ms ease;
  }

  .faq-item__icon::after {
    transform: rotate(90deg);
  }

  .faq-item[open] .faq-item__icon::before {
    transform: rotate(45deg);
  }

  .faq-item[open] .faq-item__icon::after {
    transform: rotate(-45deg);
  }

  /* Animated body wrapper — same grid-template-rows trick as
   * Course. Override the UA hide so the wrapper stays in flow
   * when closed (otherwise the row collapse can't animate). */
  .faq-item:not([open]) .faq-item__body-wrap,
  .faq-item__body-wrap {
    display: grid;
    grid-template-rows: 0fr;
    transition: grid-template-rows 280ms cubic-bezier(0.2, 0.9, 0.25, 1);
  }

  .faq-item[open] .faq-item__body-wrap {
    grid-template-rows: 1fr;
  }

  .faq-item__body {
    overflow: hidden;
    min-height: 0;
  }

  .faq-item__answer {
    margin: 0;
    padding-block: 0 var(--space-l);
    padding-inline-end: var(--space-2xl);
    opacity: 0.85;
    max-width: 60ch;
    white-space: pre-line;
  }

  @media (prefers-reduced-motion: reduce) {
    .faq-item__body-wrap,
    .faq-item__icon::before,
    .faq-item__icon::after {
      transition: none;
    }
  }
</style>

<!--
  Scroll-reserve. Same idea as Course: this scene gets the
  scene-stack 1-viewport pin, so when an answer expands the
  bottom of the stack would otherwise clip into the next scene.
  Reserve trailing room equal to the tallest answer's measured
  height, set once on mount, so ScrollTrigger sees a stable
  worst-case scene height and any drawer can open without the
  next section overlapping.
-->
<script>
  const DEBOUNCE_MS = 150;

  function applyReserve() {
    const bodies = document.querySelectorAll<HTMLElement>(
      '.faq-item .faq-item__body',
    );
    let max = 0;
    bodies.forEach((b) => {
      if (b.scrollHeight > max) max = b.scrollHeight;
    });
    document.querySelectorAll<HTMLElement>('.faq__list').forEach((list) => {
      list.style.setProperty('--faq-extra', `${max}px`);
    });
  }

  function install() {
    if ((window as any).__faqHooked) return;
    (window as any).__faqHooked = true;

    applyReserve();

    let resizeTimer: number | null = null;
    window.addEventListener('resize', () => {
      if (resizeTimer !== null) clearTimeout(resizeTimer);
      resizeTimer = window.setTimeout(() => {
        resizeTimer = null;
        applyReserve();
      }, DEBOUNCE_MS);
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', install, { once: true });
  } else {
    install();
  }
  document.addEventListener('astro:page-load', () => {
    (window as any).__faqHooked = false;
    install();
  });
</script>
