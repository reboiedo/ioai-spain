---
/**
 * HeroTitle — full-width SVG display type with per-letter
 * scroll-scrub and mouse-proximity shrink.
 *
 * Use for the biggest "hero" moments where the title should fill its
 * container edge-to-edge AND animate per-glyph (TENERIFE-style).
 * Everywhere else, prefer `<DisplayTitle>` (token-sized, per-line
 * scaleY only — much lighter).
 *
 * Rendering pipeline:
 *   1. At runtime, opentype.js loads
 *      `/fonts/PPNeueCorp-CondensedUltrabold.woff` and converts each
 *      character in the slot text to an `<svg><path>`.
 *   2. The SVG auto-fits its parent width (CSS `width: 100%`); the
 *      `viewBox` is computed from the generated text's natural
 *      bounding box plus stretch headroom, so the title fills
 *      whatever container you drop it into without JS measurement.
 *   3. Two ScrollTrigger-driven CSS custom properties are layered:
 *        --scroll-sy   each path scrubs from a per-letter start
 *                      scale to a per-letter end scale over the
 *                      title's entry window. Start/end are sampled
 *                      from a sine wave + pseudo-random jitter so
 *                      the row has organic height variation at the
 *                      end of the scroll.
 *        --mouse-sy    each path measures the horizontal distance
 *                      from the cursor and SHRINKS (inverted) when
 *                      the cursor is nearby, with `gsap.quickTo`
 *                      smoothing so it doesn't twitch.
 *      Final `scaleY = --scroll-sy × --mouse-sy` via a registered
 *      `@property` so calc() composition works.
 *
 * Font file: `/fonts/PPNeueCorp-CondensedUltrabold.woff` (NOT the
 * WOFF2 variant — opentype.js does not decode WOFF2). If you ever
 * swap the display font, update both this URL and the @font-face
 * declaration in `tenerife-camp-v2.css`.
 *
 * Component API:
 *   <HeroTitle>TENERIFE</HeroTitle>
 *   <HeroTitle as="h2" class="custom">FOLLOW</HeroTitle>
 *
 * Multi-line is NOT supported here (would require synchronised
 * sizing across lines + per-line mouse/scroll state — worth it only
 * if a real use case comes up). Use a `<br>` inside `<DisplayTitle>`
 * for stacked titles.
 */

import { buildHeroTitleSvg } from '@/lib/heroTitleSvg';

export interface Props {
  as?: 'h1' | 'h2' | 'h3' | 'div';
  class?: string;
  /** Optional centered eyebrow text rendered as an <h3> above the title. */
  eyebrow?: string;
  /**
   * When true, the per-letter scroll-stretch + jitter is skipped — every
   * glyph keeps its natural height. Use for titles where uniform letter
   * size matters (e.g. the "anchor" line in a multi-line stacked title).
   */
  noStretch?: boolean;
  /**
   * Multiplier for the per-letter stretch amplitude. 1 = the existing
   * behaviour (letters end at ~natural cap height, max 1.0). Values > 1
   * widen both the start and end scale ranges AND skip the normalization
   * cap, so letters can grow visibly taller than the cap line — useful
   * for "wild" lines (e.g. the second line of a stacked hero title).
   */
  stretchScale?: number;
}

const {
  as: Tag = 'h1',
  class: extraClass = '',
  eyebrow,
  noStretch = false,
  stretchScale = 1,
} = Astro.props;

// Build the SVG at request/build time. The slot's text content drives
// glyph generation, so we render the slot to a string first.
const slotText = (await Astro.slots.render('default'))
  .replace(/<[^>]*>/g, '')
  .trim();
const svgMarkup = slotText
  ? buildHeroTitleSvg({ text: slotText, noStretch, stretchScale })
  : '';
---

{eyebrow ? (
  <div class:list={['hero-title-group', extraClass]}>
    <h3 class="hero-title__eyebrow font-h4">{eyebrow}</h3>
    <Tag
      class="hero-title"
      data-hero-title
      data-rendered="1"
      data-no-stretch={noStretch ? '1' : undefined}
      data-stretch-scale={stretchScale !== 1 ? String(stretchScale) : undefined}
      aria-label={slotText}
      set:html={svgMarkup}
    />
  </div>
) : (
  <Tag
    class:list={['hero-title', extraClass]}
    data-hero-title
    data-rendered="1"
    data-no-stretch={noStretch ? '1' : undefined}
    data-stretch-scale={stretchScale !== 1 ? String(stretchScale) : undefined}
    aria-label={slotText}
    set:html={svgMarkup}
  />
)}

<style is:global>
  /* `is:global` because the SVG + its <path>s are created at runtime
   * via `document.createElementNS`, and Astro's default scoped styles
   * only target template-declared elements. Everything is namespaced
   * under `.hero-title` to avoid leakage. */

  /* Register the two custom properties as <number> so the `calc()`
   * composition in the path rule below is valid. Without @property
   * the browser treats them as opaque strings and rejects the multiply. */
  @property --scroll-sy {
    syntax: '<number>';
    inherits: false;
    initial-value: 1;
  }
  @property --mouse-sy {
    syntax: '<number>';
    inherits: false;
    initial-value: 1;
  }

  .hero-title-group {
    display: flex;
    flex-direction: column;
    align-items: stretch;
    gap: var(--space-s, 0.5rem);
    min-width: 0;
  }

  .hero-title__eyebrow {
    margin: 0;
    text-align: center;
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide, 0.02em);
  }

  .hero-title {
    margin: 0;
    /* Keep grid/flex ancestors from inflating to the fallback text's
     * nowrap content width before SVG takes over. */
    min-width: 0;
    display: block;
    line-height: 0;
  }

  /* SVG fills container width at natural aspect ratio — glyphs are
   * NOT distorted. The condensed font has a naturally wide aspect
   * for a full word like TENERIFE (~3–4:1), so width: 100% + height:
   * auto produces a row sized proportionally to the container width.
   * `overflow: visible` lets scaled-up letters paint outside the
   * viewBox without clipping. */
  .hero-title svg {
    display: block;
    width: 100%;
    height: auto;
    transform-origin: 0 0;
    overflow: visible;
  }

  /* Per-letter transform. Scale composes two sources:
   *   --scroll-sy  scroll-driven, start (~0.6) → end (~1.5) with
   *                sine-wave + jitter per letter
   *   --mouse-sy   mouse-proximity, 1 far → (1 − amplitude) at cursor
   *   final scaleY = --scroll-sy × --mouse-sy
   * `transform-box: fill-box` makes `transform-origin: 0 0` anchor at
   * each glyph's own top-left rather than at the SVG's origin. */
  .hero-title svg path {
    transform-box: fill-box;
    transform-origin: 0 0;
    fill: currentColor;
    transform: scaleY(calc(var(--scroll-sy, 1) * var(--mouse-sy, 1)));
    /* `position: relative` is necessary for z-index to take effect on
     * SVG path children in some browsers — the per-glyph inline
     * z-index in the generator places half of them in front of and
     * half behind the wave-strip. */
    position: relative;
  }
</style>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  // SVGs are inlined at build time by `src/lib/heroTitleSvg.ts`. This
  // script only wires up:
  //   - per-letter scroll-driven scaleY (`--scroll-sy`)
  //   - mouse-proximity shrink (`--mouse-sy`)
  // No font load, no DOM construction — paths exist on first paint.

  let stretchTweens: gsap.core.Tween[] = [];

  // Mouse tracking shared across all HeroTitles on the page.
  let mouseX: number | null = null;
  let mouseRafId: number | null = null;
  const mouseTrackedPaths: SVGPathElement[] = [];
  const mouseQuickTos: Map<SVGPathElement, (value: number) => void> = new Map();
  const MOUSE_REACH = 0.4;
  const MOUSE_AMPLITUDE = 0.25;
  const MOUSE_EASE_DURATION = 0.5;

  function onMouseMove(e: MouseEvent) {
    mouseX = e.clientX;
    if (mouseRafId === null) {
      mouseRafId = requestAnimationFrame(updateMouseScale);
    }
  }

  function updateMouseScale() {
    mouseRafId = null;
    if (mouseX === null) return;
    const reach = window.innerWidth * MOUSE_REACH;
    for (const path of mouseTrackedPaths) {
      const rect = path.getBoundingClientRect();
      const center = rect.left + rect.width / 2;
      const distance = Math.abs(mouseX - center);
      const normalized = Math.min(distance / reach, 1);
      const effect = 1 - (1 - normalized) * MOUSE_AMPLITUDE;
      const qto = mouseQuickTos.get(path);
      if (qto) qto(effect);
      else path.style.setProperty('--mouse-sy', effect.toFixed(3));
    }
  }

  function attachScrollStretch(container: HTMLElement, paths: SVGPathElement[]) {
    const commonTrigger = {
      trigger: container,
      start: 'top bottom',
      end: 'center center',
      scrub: true,
      invalidateOnRefresh: true,
    } as const;

    paths.forEach((path) => {
      const start = parseFloat(path.dataset.startScaleY || '0.6');
      const end = parseFloat(path.dataset.endScaleY || '1.5');
      path.style.setProperty('--scroll-sy', start.toFixed(3));
      path.style.setProperty('--mouse-sy', '1');
      mouseTrackedPaths.push(path);

      mouseQuickTos.set(
        path,
        gsap.quickTo(path, '--mouse-sy', {
          duration: MOUSE_EASE_DURATION,
          ease: 'power2.out',
        }),
      );

      stretchTweens.push(
        gsap.fromTo(
          path,
          { '--scroll-sy': start },
          {
            '--scroll-sy': end,
            ease: 'none',
            immediateRender: true,
            scrollTrigger: commonTrigger,
          },
        ),
      );
    });
  }

  function renderAll() {
    stretchTweens.forEach((t) => t.scrollTrigger?.kill());
    stretchTweens.forEach((t) => t.kill());
    stretchTweens = [];
    mouseTrackedPaths.length = 0;
    mouseQuickTos.clear();
    window.removeEventListener('mousemove', onMouseMove);

    const titles = document.querySelectorAll<HTMLElement>('[data-hero-title]');
    if (!titles.length) return;

    titles.forEach((title) => {
      const paths = Array.from(title.querySelectorAll<SVGPathElement>('svg path'));
      if (!paths.length) return;
      // `data-no-stretch` titles ship without scaleY data attrs — skip
      // ScrollTrigger wiring, paths render at natural height.
      if (title.dataset.noStretch !== '1') {
        attachScrollStretch(title, paths);
      }
    });

    if (mouseTrackedPaths.length > 0) {
      window.addEventListener('mousemove', onMouseMove, { passive: true });
    }

    ScrollTrigger.refresh();
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', renderAll, { once: true });
  } else {
    renderAll();
  }

  document.addEventListener('astro:page-load', renderAll);
</script>
