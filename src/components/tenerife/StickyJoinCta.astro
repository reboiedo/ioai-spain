---
/**
 * StickyJoinCta — global "Join now" button fixed to the bottom-right
 * of the viewport for the duration of the Tenerife camp v2 page.
 *
 * Always visible — there are no in-page Join CTAs on the page now,
 * so this sticky button is the only Join action and shouldn't hide.
 *
 * Pointer events are kept on the button only; the rest of the page
 * scrolls and clicks normally underneath.
 */

export interface Props {
  /** Where the CTA links to. */
  href?: string;
}

const { href = "/form/tenerife-camp/" } = Astro.props;
---

<a class="sticky-join-cta" href={href} data-sticky-join-cta>
  <span class="sticky-join-cta__label">Join now</span>
  <span class="sticky-join-cta__arrow" aria-hidden="true">→</span>
</a>

<style>
  .sticky-join-cta {
    position: fixed;
    right: clamp(1rem, 3vw, 2rem);
    /* `--cta-lift` is written from JS as the page footer rises
     * into the viewport — it's added to `bottom` directly (not
     * via transform) so the lift is *not* eased and tracks
     * scroll 1:1. The CSS `transition` only applies to
     * `transform`, which is reserved for the hover micro-lift. */
    --cta-lift: 0px;
    bottom: calc(clamp(1rem, 3vw, 2rem) + var(--cta-lift));
    z-index: 50; /* above the nav-bar's prev-bg (lower) and any scenes */
    display: inline-flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-2xl);
    padding: var(--space-m) var(--space-l);
    background: var(--primary);
    color: var(--primary-foreground);
    text-decoration: none;
    border-radius: 0.25rem;
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.18);
    transition:
      transform 220ms ease,
      opacity 280ms ease,
      visibility 0s linear 280ms;
  }


  .sticky-join-cta:hover {
    transform: translateY(-2px);
  }

  /* Mobile: anchor the button to BOTH sides with `--cta-inset` of
   * margin so it reads as a wide bar rather than a corner pill —
   * but with breathing room on the sides + bottom (not edge-to-
   * edge). `env(safe-area-inset-bottom)` keeps the button clear of
   * the iOS home-indicator strip. */
  @media (max-width: 767.98px) {
    .sticky-join-cta {
      left: var(--cta-inset);
      right: var(--cta-inset);
      bottom: calc(
        var(--cta-inset)
          + env(safe-area-inset-bottom, 0px)
          + var(--cta-lift)
      );
      justify-content: space-between;
    }
  }

  .sticky-join-cta__label {
    font-family: var(--font-body);
    font-weight: 500;
  }

  .sticky-join-cta__arrow {
    font-size: 1.25em;
    line-height: 1;
  }

</style>

<script>
  /**
   * Lift the sticky Join CTA above the camp footer.
   *
   * The footer lives at the very bottom of the document. As the
   * user scrolls past the apply section's pin window the footer
   * rises into the viewport. Without intervention it overlaps
   * the fixed CTA pill. This script measures how much of the
   * footer has entered from the bottom on each frame and writes
   * that overlap into `--cta-lift`, so the CTA's transform stays
   * tucked just above it. CSS handles the hover-lift separately
   * via `--cta-hover` — the two compose in the transform.
   */
  function installCtaFooterLift() {
    const cta = document.querySelector<HTMLElement>('[data-sticky-join-cta]');
    const footer = document.querySelector<HTMLElement>('[data-camp-footer]');
    if (!cta || !footer) return;

    let raf = 0;
    function update() {
      raf = 0;
      const r = footer!.getBoundingClientRect();
      // Only count overlap that's actually in the viewport. A
      // small extra `gap` keeps the CTA hovering above the
      // footer's top edge rather than kissing it.
      const gap = 16;
      const overlap = Math.max(0, window.innerHeight - r.top + gap);
      cta!.style.setProperty('--cta-lift', `${overlap}px`);
    }
    function schedule() {
      if (raf) return;
      raf = requestAnimationFrame(update);
    }
    update();
    window.addEventListener('scroll', schedule, { passive: true });
    window.addEventListener('resize', schedule);
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', installCtaFooterLift, {
      once: true,
    });
  } else {
    installCtaFooterLift();
  }
  document.addEventListener('astro:page-load', installCtaFooterLift);
</script>
