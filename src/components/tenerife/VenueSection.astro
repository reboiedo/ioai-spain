---
/**
 * VenueSection — the "VENUE" scene.
 *
 * Layout:
 *   1. Split header on top — title on the left, intro sentence on
 *      the right (body-l). Same shape as the Coaches / Approach
 *      section headers.
 *   2. Two zig-zag rows below — Hotel (text left, photo right),
 *      Classrooms (photo left, text right). Each is a `.split`
 *      with the photo half forced to a specific column via
 *      `order` so the alternation reads as designed.
 *
 * Photo content is a placeholder asset frame for now; swap each
 * `.venue-row__media` for an `<img>` when photography lands.
 */

import SectionTitle from "@/components/tenerife/SectionTitle.astro";

export interface Props {
  /** Tenerife theme palette to apply via `data-theme`. */
  theme?: "orange" | "blue" | "yellow" | "neutral";
}

const { theme = "yellow" } = Astro.props;

interface Venue {
  title: string;
  body: string;
  /** Where the photo sits in the split. */
  side: "left" | "right";
}

const venues: Venue[] = [
  {
    title: "The hotel",
    body: "Campers stay at a 4-star property in Puerto de la Cruz, two minutes on foot from Martiánez beach. Rooms are shared between three campers, with all meals — breakfast, lunch and dinner — included on site. The northern coast keeps a mild climate even at the height of summer, so the hotel terrace becomes a second living room.",
    side: "right",
  },
  {
    title: "The classrooms",
    body: "Teaching happens in a dedicated block of four classrooms plus a larger seminar hall — flexible enough for a morning lecture and an afternoon hackathon. Wi-fi is fast, wired desks are available for heavier workloads, and a small library and outdoor shaded terrace round out the spaces students gravitate to between sessions.",
    side: "left",
  },
];
---

<div class="scene" data-scene>
  <section
    class="section scene__layer scene__layer--tilt venue"
    data-theme={theme}
  >
    <div class="venue__layout">
      <!-- Split header — title left, intro sentence right (body-l). -->
      <div class="split venue__header">
        <SectionTitle lines={["VENUE"]} />
        <p class="font-body-l venue__header-copy">
          Two weeks on the northern coast of Tenerife — a 4-star hotel
          two minutes from the beach, dedicated classrooms a short walk
          away, and the rest of the island within easy reach for the
          afternoon programme.
        </p>
      </div>

      <!-- Zig-zag rows. Each row is a `.split` with a media block on
           one side and a text block on the other; `order` swaps the
           sides per row so the layout reads as a zig-zag. -->
      {venues.map((v) => (
        <div class={`split venue-row venue-row--${v.side}`}>
          <div class="venue-row__text stack-m">
            <h3 class="font-h2 venue-row__title">{v.title}</h3>
            <p class="font-body venue-row__body">{v.body}</p>
          </div>

          <div class="venue-row__media" aria-hidden="true">
            <span class="venue-row__media-label">{v.title}</span>
          </div>
        </div>
      ))}
    </div>
  </section>
</div>

<style>
  .venue__layout {
    display: grid;
    gap: var(--space-3xl);
  }

  .venue__header-copy {
    margin: 0;
    /* Cap the intro at a comfortable measure rather than letting
     * it run the full half-column. */
    max-width: 48ch;
  }

  .venue-row__title,
  .venue-row__body {
    margin: 0;
  }

  /* Body copy gets a measure too so it stays readable when the
   * column gets wide on big viewports. */
  .venue-row__body {
    max-width: 44ch;
  }

  /* Photo placeholder. Wide-ish landscape aspect; swap for an
   * <img> later. Theme-derived colour tint so each scene's image
   * still picks up its data-theme. */
  .venue-row__media {
    width: 100%;
    aspect-ratio: 4 / 3;
    border-radius: 8px;
    background:
      linear-gradient(
        135deg,
        color-mix(in oklab, var(--foreground) 14%, transparent) 0%,
        color-mix(in oklab, var(--foreground) 6%, transparent) 100%
      );
    display: grid;
    place-items: center;
    color: color-mix(in oklab, var(--foreground) 60%, transparent);
  }

  .venue-row__media-label {
    font-family: var(--font-headings);
    font-weight: 600;
    font-size: clamp(1.25rem, 2vw, 1.75rem);
    letter-spacing: -0.02em;
  }

  /* Each row gets a top border. The very last row also gets a
   * bottom border so the stack reads as a framed block — top and
   * bottom rules wrapping the zig-zag. Padding gives the borders
   * breathing room from the row content. */
  .venue-row {
    border-block-start: 1px solid var(--border);
    padding-block: var(--space-2xl);
  }

  .venue-row:last-of-type {
    border-block-end: 1px solid var(--border);
  }

  /* Zig-zag — `.split` already gives 1fr / 1fr at ≥768px. Only
   * desktop needs the order swap; on narrow viewports the column
   * collapses and we want text-then-photo regardless of `side`. */
  @media (min-width: 768px) {
    /* `--side: left` → photo in the left column. Text is the first
     * DOM child (so screen-reader order is title first); we use
     * `order` to put it on the right. */
    .venue-row--left .venue-row__text {
      order: 2;
    }
    .venue-row--left .venue-row__media {
      order: 1;
    }
    /* `--side: right` is already the natural DOM order — text
     * left, photo right. No overrides needed. */

    /* Vertically centre text against the media block so titles
     * sit beside the picture rather than stacking against the
     * top edge. */
    .venue-row {
      align-items: center;
    }

    /* Push the text block to the centreline of the row so it
     * always sits *next to* the photo rather than against the
     * outer section edge.
     *
     *   side="right" (text in left cell, photo in right cell)
     *     → text hugs the right side of its cell.
     *   side="left"  (photo in left cell, text in right cell)
     *     → text is already at the left of its cell, naturally
     *       beside the photo. No override needed.
     */
    .venue-row--right .venue-row__text {
      margin-inline-start: auto;
    }
  }
</style>
