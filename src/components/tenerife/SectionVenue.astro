---
/**
 * VenueSection — the "VENUE" scene.
 *
 * Layout (desktop):
 *   ┌──────────────────────────────────┬──────────────────────────────┐
 *   │  VENUE (sticky title)            │  ┌──────────────────────┐    │
 *   │                                  │  │ Hotel photo          │    │
 *   │  Hotel description paragraph     │  └──────────────────────┘    │
 *   │                                  │  ┌──────────────────────┐    │
 *   │                                  │  │ Hotel photo          │    │
 *   │                                  │  └──────────────────────┘    │
 *   │                                  │  ┌──────────────────────┐    │
 *   │                                  │  │ Hotel photo          │    │
 *   │                                  │  └──────────────────────┘    │
 *   └──────────────────────────────────┴──────────────────────────────┘
 *
 * Left column is sticky — title + the hotel paragraph stay in view
 * while the user scrolls past the vertical photo stack on the right.
 *
 * Mobile: title + paragraph stacked, then the photo stack flows
 * underneath as a single column.
 *
 * Photo slots are named: drop `hotel.jpg`, `hotel-terrace.jpg`,
 * `hotel-room.jpg`, etc. into `src/assets/tenerife/venue/` to fill
 * the slots. Missing slots render as gradient placeholders so the
 * layout reads as intentional even before all photos land.
 */

import { Picture } from "astro:assets";
import type { ImageMetadata } from "astro";
import SectionTitle from "@/components/tenerife/SectionTitle.astro";
import { useTenerifeTranslations, type Language } from "@/i18n/tenerife";

// Eager-glob every venue photo so we can look one up by filename.
const photoModules = import.meta.glob<{ default: ImageMetadata }>(
  "@/assets/tenerife/venue/*.{jpg,jpeg,png,webp,avif}",
  { eager: true },
);
const photos: Record<string, ImageMetadata> = {};
for (const [path, mod] of Object.entries(photoModules)) {
  const filename = path.split("/").pop() ?? "";
  const key = filename.replace(/\.[^.]+$/, "");
  photos[key] = mod.default;
}

export interface Props {
  /** Locale for this render. */
  locale: Language;
  /** Tenerife theme palette to apply via `data-theme`. */
  theme?: "orange" | "blue" | "yellow" | "neutral";
}

const { locale, theme = "yellow" } = Astro.props;

const t = useTenerifeTranslations(locale);
const photoSlots = t.venue.photoSlots;
---

<div class="scene" data-scene data-scene-index="6">
  <section
    class="section scene__layer scene__layer--tilt venue"
    data-theme={theme}
  >
    <div class="venue__layout">
      <!-- LEFT — sticky title + hotel paragraph. Stays in view as
           the user scrolls through the photo stack on the right. -->
      <div class="venue__intro">
        <SectionTitle lines={[t.venue.title]} />
        <p class="font-body venue__intro-copy">{t.venue.copy}</p>
      </div>

      <!-- Vertical centreline divider — own grid track between the
           two content columns, `align-self: stretch` so it spans
           the full section height regardless of the sticky left
           column's max-height. Same convention as Story / Team. -->
      <div class="venue__divider" aria-hidden="true"></div>

      <!-- RIGHT — vertical scrollable stack of hotel photos.
           Each tile keeps its configured aspect ratio; the column
           grows naturally with the photo count. -->
      <ol class="venue__photos">
        {photoSlots.map((slot) => (
          <li class="venue-photo" style={`aspect-ratio: ${slot.aspect};`}>
            {slot.key && photos[slot.key] ? (
              <Picture
                class="venue-photo__img"
                src={photos[slot.key]}
                alt={slot.alt}
                formats={["avif", "webp"]}
                widths={[480, 720, 960, 1280]}
                sizes="(min-width: 768px) 45vw, 90vw"
                loading="lazy"
              />
            ) : (
              <span class="venue-photo__label" aria-hidden="true">{slot.alt}</span>
            )}
          </li>
        ))}
        <li class="venue-photo venue-photo--map" style="aspect-ratio: 4 / 3;">
          <iframe
            class="venue-photo__map"
            src="https://www.google.com/maps?q=Hotel+Concordia+Playa+Puerto+de+la+Cruz+Tenerife&output=embed"
            title={t.venue.mapTitle}
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            allowfullscreen></iframe>
        </li>
      </ol>
    </div>
  </section>
</div>

<style>
  /* Section grows with the scrolling photo column. Floor at one
   * viewport so the sticky left column always has somewhere to
   * stick to. */
  .venue {
    min-height: 100lvh;
  }

  .venue__layout {
    display: grid;
    /* Mobile: single-column collapse — intro, divider (hidden),
     * photos all stack. Desktop promotes to 3-column grid below. */
    grid-template-columns: minmax(0, 1fr);
    gap: var(--space-2xl);
  }

  @media (min-width: 768px) {
    .venue__layout {
      grid-template-columns: minmax(0, 1fr) auto minmax(0, 1fr);
      column-gap: var(--space-2xl);
    }
  }

  /* ── LEFT: sticky title + hotel paragraph ────────────────────── */
  .venue__intro {
    display: flex;
    flex-direction: column;
    /* Consistent intro gap across every section (Story, Tracks,
     * Team, Pricing, FAQ) — keeps the title→paragraph rhythm
     * uniform on mobile. */
    gap: var(--space-xl);
  }

  .venue__intro-copy {
    margin: 0;
    max-width: 48ch;
  }

  @media (min-width: 768px) {
    .venue__intro {
      position: sticky;
      top: var(--sticky-top);
      align-self: start;
      max-height: calc(100lvh - var(--sticky-top));
    }
  }

  /* Vertical divider — same convention as Story / Team. */
  .venue__divider {
    display: none;
  }

  @media (min-width: 768px) {
    .venue__divider {
      display: block;
      width: 1px;
      background: var(--border);
      align-self: stretch;
    }
  }

  /* ── RIGHT: vertical photo stack ─────────────────────────────── */
  .venue__photos {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-l);
  }

  /* Each photo cell holds its own aspect ratio (set inline via
   * `style="aspect-ratio: …"`). Width fills the column; the cell
   * crops the image so portrait + landscape entries can mix
   * cleanly inside the stack. */
  .venue-photo {
    width: 100%;
    border-radius: 8px;
    overflow: hidden;
    background:
      linear-gradient(
        135deg,
        var(--foreground-muted) 0%,
        var(--foreground-muted) 100%
      );
    display: grid;
    place-items: center;
    color: var(--foreground-muted);
    /* The cell already has aspect-ratio + grid place-items: center.
     * The grid track itself fills with both `1fr` rows/cols, but
     * children only stretch when sized "stretch" — `place-items:
     * center` actually shrinks them to intrinsic size, which is
     * what produced the white stripe on the hotel photo (the img's
     * intrinsic ratio differed from the cell's, leaving a gap). The
     * rule on the inner img/picture below forces both to fill the
     * cell explicitly so cover-cropping does its job. */
    position: relative;
  }

  /* Picture wrapper + inner img both pinned to the cell. With
   * `display: contents` set globally on .tenerife-camp-v2 picture,
   * the img is the visible child here; we also keep an explicit
   * absolute-fill on the picture as a belt-and-braces guard for
   * any rendering path that escapes display: contents. */
  .venue-photo > picture {
    position: absolute;
    inset: 0;
    display: block;
  }

  .venue-photo__img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
  }

  .venue-photo__map {
    width: 100%;
    height: 100%;
    display: block;
    border: 0;
  }

  .venue-photo__label {
    font-family: var(--font-headings, var(--font-display));
    font-weight: 600;
    font-size: clamp(1rem, 2vw, 1.5rem);
    letter-spacing: -0.02em;
    padding: var(--space-m);
    text-align: center;
  }
</style>
