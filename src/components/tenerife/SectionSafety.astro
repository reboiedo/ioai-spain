---
/**
 * SafetySection — narrative scene mirroring SectionStory.
 *
 * Layout (desktop):
 *   ┌──────────────────────────────────────┬──────────────────────────┐
 *   │  Intro lede                          │                          │
 *   │  …                                   │   ╔══════════════╗        │
 *   │  Pillar cards (2×2)                  │   ║  SAFETY       ║       │
 *   │  …                                   │   ║              ║        │
 *   │  Supervisors grid                    │   ║  ┌────────┐  ║        │
 *   │                                      │   ║  │ photo  │  ║        │
 *   │                                      │   ║  └────────┘  ║        │
 *   │                                      │   ║  FIRST       ║        │
 *   │                                      │   ╚══════════════╝        │
 *   └──────────────────────────────────────┴──────────────────────────┘
 *
 * Right column is sticky — the giant 2-line title and the overlapping
 * tilted safety photo stay in view while the user scrolls past the
 * left column's intro / pillar cards / supervisors grid.
 *
 * Mobile: title + photo block on top, then intro lede, then pillar
 * cards (2×2), then supervisors grid (2-up).
 */

import { Image, type ImageMetadata } from "astro:assets";
import HeroTitleStack from "@/components/tenerife/HeroTitleStack.astro";
import safetyImage from "@/assets/tenerife/safety/safety.jpg";
import safetyIcon from "@/assets/tenerife/safety/safety.svg";
import { useTenerifeTranslations, type Language } from "@/i18n/tenerife";

// Eager-glob future supervisor portraits — same convention as
// SectionTeam. Drop `name.jpg` (or .png/.webp) into
// `src/assets/tenerife/safety/supervisors/` and reference by basename
// via the `imageKey` field below; missing keys fall back to a
// gradient placeholder with initials.
const supervisorModules = import.meta.glob<{ default: ImageMetadata }>(
  "@/assets/tenerife/safety/supervisors/*.{jpg,jpeg,png,webp,avif}",
  { eager: true },
);
const supervisorPhotos: Record<string, ImageMetadata> = {};
for (const [path, mod] of Object.entries(supervisorModules)) {
  const filename = path.split("/").pop() ?? "";
  const key = filename.replace(/\.[^.]+$/, "");
  supervisorPhotos[key] = mod.default;
}

export interface Props {
  /** Locale for this render. */
  locale: Language;
  /** Tenerife theme palette to apply via `data-theme`. */
  theme?: "orange" | "blue" | "yellow" | "neutral";
}

const { locale, theme = "orange" } = Astro.props;
const t = useTenerifeTranslations(locale);
const pillars = t.safety.pillars;
const supervisors = t.safety.supervisors;
---

<div class="scene" data-scene data-scene-index="7">
  <section
    class="section scene__layer scene__layer--tilt safety"
    data-theme={theme}
  >
    <div class="safety__layout">
      <!-- LEFT — scrolling content. Plain block flow on desktop so
           it scrolls with the page; the right column is sticky and
           stays in view as the user passes by. -->
      <div class="safety__content">
        <div class="safety__intro">
          <p class="font-body-l safety__lede">{t.safety.lede}</p>
        </div>

        <!-- Pillar cards. 2×2 grid, surface cards with title + body
             on each. No flip — the right column already gives the
             section breathing room, so descriptions stay visible. -->
        <ol class="safety__pillars">
          {pillars.map((p, i) => (
            <li class="safety-pillar">
              <span class="font-caption safety-pillar__num">
                {String(i + 1).padStart(2, "0")}
              </span>
              <h3 class="font-h4 safety-pillar__title">{p.title}</h3>
              <p class="font-body-s safety-pillar__desc">{p.description}</p>
            </li>
          ))}
        </ol>

        <!-- Supervisors grid. Same card pattern as SectionTeam, but
             with portrait-on-top + name underneath. Missing portraits
             fall back to a gradient tile with initials. -->
        <div class="safety__supervisors-block">
          <h3 class="font-h3 safety__supervisors-title">{t.safety.supervisorsTitle}</h3>
          <p class="font-body safety__supervisors-copy">{t.safety.supervisorsCopy}</p>
          <ul class="safety__supervisors">
            {supervisors.map((s) => (
              <li class="supervisor-card">
                <div class="supervisor-card__portrait">
                  {s.imageKey && supervisorPhotos[s.imageKey] ? (
                    <Image
                      class="supervisor-card__photo"
                      src={supervisorPhotos[s.imageKey]}
                      alt={s.name}
                      widths={[120, 180, 240]}
                      sizes="(min-width: 768px) 12vw, 30vw"
                      loading="lazy"
                    />
                  ) : (
                    <span class="supervisor-card__initials" aria-hidden="true">
                      {s.initials}
                    </span>
                  )}
                </div>
                <div class="supervisor-card__meta">
                  <span class="font-body-s supervisor-card__name">{s.name}</span>
                  {s.role && (
                    <span class="font-caption supervisor-card__role">{s.role}</span>
                  )}
                </div>
              </li>
            ))}
          </ul>
        </div>
      </div>

      <!-- Vertical centreline divider — own grid track between the
           two content columns, `align-self: stretch` so it spans
           the full section height regardless of the sticky right
           column's max-height. -->
      <div class="safety__divider" aria-hidden="true"></div>

      <!-- RIGHT — sticky big-title stack + overlapping tilted safety
           photo. `HeroTitleStack` sizes each line so the shorter
           line's letters match the longer line's height. -->
      <div class="safety__right">
        <div class="safety__title">
          <HeroTitleStack
            lines={[
              { text: t.safety.titleLine1, noStretch: true },
              { text: t.safety.titleLine2 },
            ]}
            defaultAlign="right"
            gap="var(--space-s)"
            maxWidth="80%"
          />
          <!-- Decorative safety icon — sits to the left of the
               word SAFETY, vertically centred on that line. Same
               stepped tilt animation as the testimonials chat
               bubble. -->
          <img
            class="safety__title-icon"
            src={safetyIcon.src}
            width={safetyIcon.width}
            height={safetyIcon.height}
            alt=""
            aria-hidden="true"
            loading="lazy"
            decoding="async"
          />
          <!-- Handwritten eyebrow — absolutely positioned between
               the two title lines, on the right side (where the
               title is anchored). Same script font + -6deg tilt +
               primary colour as the original
               `eyebrowPosition="between"` SectionTitle variant. -->
          <span class="safety__title-eyebrow" aria-hidden="true">{t.safety.titleEyebrow}</span>
        </div>

        <!-- Tilted photograph — sits between the two title lines
             (overlapping both visually). Static image, no click. -->
        <div class="safety__photo">
          <Image
            class="safety__photo-img"
            src={safetyImage}
            alt={t.safety.photoAlt}
            widths={[480, 720, 960]}
            sizes="(min-width: 768px) 30vw, 70vw"
            loading="lazy"
          />
        </div>
      </div>
    </div>
  </section>
</div>

<style>
  /* Section grows with the scrolling left column. Floor at one
   * viewport so short copy doesn't make the right column's sticky
   * window collapse to nothing. */
  .safety {
    min-height: 100lvh;
  }

  /* Three-column grid on desktop; single-column stack on mobile.
   * Mobile order is overridden so the title + photo block appears
   * FIRST — DOM order has content first for desktop layout, but
   * mobile flips it via grid order so the giant title leads. */
  .safety__layout {
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    gap: var(--space-2xl);
  }

  @media (max-width: 767.98px) {
    .safety__content {
      order: 2;
    }
    .safety__divider {
      order: 1;
    }
    .safety__right {
      order: 0;
    }
  }

  @media (min-width: 768px) {
    .safety__layout {
      grid-template-columns: minmax(0, 1fr) auto minmax(0, 1fr);
      column-gap: var(--space-2xl);
    }
  }

  .safety__divider {
    display: none;
  }

  @media (min-width: 768px) {
    .safety__divider {
      display: block;
      width: 1px;
      background: var(--border);
      align-self: stretch;
    }
  }

  /* ── LEFT: scrolling content column ──────────────────────────── */
  .safety__content {
    display: flex;
    flex-direction: column;
    gap: var(--space-3xl);
  }

  .safety__intro {
    max-width: 60ch;
  }

  .safety__lede {
    margin: 0;
  }

  /* Pillars — 2×2 surface cards. Number top, title, description. */
  .safety__pillars {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: var(--space-s);
  }

  .safety-pillar {
    background: var(--primary);
    color: var(--primary-foreground);
    padding: var(--space-m);
    border-radius: 4px;
    display: flex;
    flex-direction: column;
    gap: var(--space-2xs);
    aspect-ratio: 4 / 5;
  }

  @media (min-width: 768px) {
    .safety-pillar {
      aspect-ratio: 1 / 1;
    }
  }

  .safety-pillar__num {
    margin: 0;
    opacity: 0.55;
    letter-spacing: 0.08em;
  }

  .safety-pillar__title {
    margin: 0;
    line-height: 1.05;
    text-wrap: balance;
  }

  .safety-pillar__desc {
    margin: 0;
    opacity: 0.85;
    text-wrap: pretty;
  }

  /* Supervisors block — heading + copy + grid of cards. */
  .safety__supervisors-block {
    display: flex;
    flex-direction: column;
    gap: var(--space-m);
  }

  .safety__supervisors-title {
    margin: 0;
  }

  .safety__supervisors-copy {
    margin: 0;
    opacity: 0.85;
    max-width: 60ch;
  }

  /* Supervisor cards — portrait on top (1:1), name + role below.
   * 2 columns on mobile, 3 columns ≥768, 4 columns ≥1280 so the
   * thumbnails stay a comfortable size on the wide layout. */
  .safety__supervisors {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: var(--space-m);
  }

  @media (min-width: 768px) {
    .safety__supervisors {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  @media (min-width: 1280px) {
    .safety__supervisors {
      grid-template-columns: repeat(4, minmax(0, 1fr));
    }
  }

  .supervisor-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-2xs);
  }

  .supervisor-card__portrait {
    width: 100%;
    aspect-ratio: 1 / 1;
    border-radius: 4px;
    overflow: hidden;
    background: var(--surface);
    display: grid;
    place-items: center;
    color: var(--foreground-muted);
  }

  .supervisor-card__photo {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
  }

  .supervisor-card__initials {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: clamp(1.5rem, 3vw, 2rem);
    letter-spacing: -0.02em;
  }

  .supervisor-card__meta {
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
  }

  .supervisor-card__name {
    margin: 0;
  }

  .supervisor-card__role {
    margin: 0;
    opacity: 0.7;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  /* ── RIGHT: sticky title + tilted photo ─────────────────────── */
  .safety__right {
    /* `position: relative` makes this the containing block for the
     * absolutely-positioned photo below. Photo uses % units relative
     * to this column so it scales proportionally. */
    position: relative;
  }

  @media (min-width: 768px) {
    .safety__right {
      position: sticky;
      top: var(--sticky-top);
      align-self: start;
      max-height: calc(100lvh - var(--sticky-top));
    }
  }

  .safety__title {
    display: block;
    /* Containing block for the absolutely-positioned eyebrow. */
    position: relative;
  }

  /* Handwritten "always" eyebrow floating between SAFETY and FIRST.
   * Anchored vertically at the midpoint of the title block (where
   * the gap between the two HeroTitle SVG lines lives) and on the
   * right edge of the title's `maxWidth` band. Sized with `clamp`
   * so it scales gracefully across breakpoints — purely a visual
   * accent, no layout impact (`pointer-events: none`). */
  .safety__title-eyebrow {
    position: absolute;
    top: 50%;
    right: 8%;
    transform: translate(0, -50%) rotate(-6deg);
    transform-origin: center;
    font-family: var(--font-script);
    font-weight: var(--weight-regular);
    /* Shared script-eyebrow size — matches SectionActivities's
     * "Daily" eyebrow and SectionTitle's overlap/between
     * eyebrows so all script accents read at the same scale. */
    font-size: clamp(1.75rem, 3.5vw, 3rem);
    line-height: 1;
    color: var(--primary);
    pointer-events: none;
    z-index: 3;
  }

  /* Decorative safety icon — sits to the left of the SAFETY word
   * (the top title line), vertically centred on it. SAFETY is the
   * longest line in the stack, right-aligned within the 80% maxWidth
   * band — so its left edge lands ~20% from the title's left edge.
   * The icon parks just inside that, scaled to track the line height.
   *
   * Stepped tilt: same `steps(6)` choppy hand-drawn loop as the
   * testimonials chat bubble. */
  .safety__title-icon {
    position: absolute;
    /* Vertical centre of SAFETY — the top line in a two-line stack
     * with a small gap. Roughly a quarter of the way down. */
    top: 25%;
    left: 4%;
    width: clamp(3rem, 8vw, 7rem);
    height: auto;
    transform-origin: 50% 50%;
    animation: safety-icon-tilt 2s steps(6) infinite;
    pointer-events: none;
    z-index: 3;
  }

  @keyframes safety-icon-tilt {
    0%, 100% { transform: translateY(-50%) rotate(-4deg); }
    50% { transform: translateY(-50%) rotate(3deg); }
  }

  @media (prefers-reduced-motion: reduce) {
    .safety__title-icon {
      animation: none;
      transform: translateY(-50%) rotate(-2deg);
    }
  }

  @media (max-width: 767.98px) {
    .safety__title-icon {
      /* Keep it visible on mobile but a touch smaller. */
      width: clamp(2.25rem, 14vw, 4rem);
    }
  }

  /* Tilted safety photo — fixed 4:5 aspect ratio, sized as a % of
   * its containing block. `-8deg` tilt matches the Story video
   * tile so the two scenes feel like a pair. Anchored absolute
   * over the upper-left of the column so it sits BETWEEN SAFETY
   * (top, right-aligned) and FIRST (bottom, right-aligned)
   * without overlapping the FIRST glyphs. */
  .safety__photo {
    display: block;
    position: absolute;
    width: 28%;
    bottom: 28%;
    left: 6%;
    aspect-ratio: 4 / 5;
    margin: 0;
    transform: rotate(-8deg);
    z-index: 2;
    border-radius: 4px;
    overflow: hidden;
    box-shadow: 0 12px 32px rgba(0, 0, 0, 0.22);
    background: var(--card);
  }

  .safety__photo-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
</style>
