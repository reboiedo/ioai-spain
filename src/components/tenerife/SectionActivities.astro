---
/**
 * ActivitiesSection — the "Daily ADVENTURES" scene.
 *
 * Layout:
 *   1. Hero block — full-width "Daily" script eyebrow + giant
 *      ADVENTURES `HeroTitle` with the stretch-on-load animation.
 *      Intro paragraph beneath.
 *   2. Activity browser — single 100svh frame split left/right.
 *      LEFT: activity name (top half) + description (bottom half).
 *      RIGHT: full-bleed photo.
 *      Bottom-right corner: prev / next arrows + index counter.
 *
 * The user can scroll past the browser at their own pace — only one
 * activity is in view at a time, and arrows (or keyboard ←/→) cycle
 * through the 15 days. No more 15-viewport-tall pin window.
 *
 * Photo files in `src/assets/tenerife/activities/` are matched to
 * activities by index after a `01-…`, `02-…` filename sort.
 */

import { Image, type ImageMetadata } from "astro:assets";
import HeroTitle from "@/components/tenerife/HeroTitle.astro";

const photoModules = import.meta.glob<{ default: ImageMetadata }>(
  "@/assets/tenerife/activities/*.{jpg,jpeg,png,webp,avif}",
  { eager: true },
);
const photos: ImageMetadata[] = Object.entries(photoModules)
  .sort(([a], [b]) => a.localeCompare(b))
  .map(([, mod]) => mod.default);

export interface Props {
  /** Tenerife theme palette to apply via `data-theme`. */
  theme?: "orange" | "blue" | "yellow" | "neutral";
}

const { theme = "blue" } = Astro.props;

interface Activity {
  day: number;
  title: string;
  description: string;
}

const activities: Activity[] = [
  {
    day: 1,
    title: "Welcome & getting to know each other",
    description:
      "The camp kicks off with a walk along the seafront of Puerto de la Cruz, finishing at the historic Plaza del Charco. Along the way, campers take part in a simple but effective icebreaker — sharing their name, something they love, and their plans for the future. By the end of the evening, the group already feels like a group.",
  },
  {
    day: 2,
    title: "Historic Puerto de la Cruz",
    description:
      "Campers explore the old town on a guided cultural walk that brings local history to life. Highlights include the 17th-century Church of Nuestra Señora de la Peña de Francia, the town's historic fishing pier — once used to export Malvasia wine — Playa Jardín designed by celebrated Canarian artist César Manrique, and the Castle of San Felipe, a coastal fortress built to defend against pirates. The walk ends back at the iconic Lago Martiánez pool complex.",
  },
  {
    day: 3,
    title: "Beach sports",
    description:
      "A full afternoon at Playa Jardín with volleyball, football, tennis and frisbee. Campers rotate through activities in small groups, keeping it social, competitive and fun.",
  },
  {
    day: 4,
    title: "Yoga workshop & beach",
    description:
      "A more mindful afternoon. While some campers enjoy the beach, others take part in a yoga workshop designed to balance the physical intensity of the week with self-care and reflection. Every camper gets their session.",
  },
  {
    day: 5,
    title: "Rambla de Castro coastal trail",
    description:
      "A scenic coastal hike through one of Tenerife's most beautiful natural routes. The group passes black-sand coves, a historic 1903 steam-engine pumping station, a wooden bridge over a ravine, an 18th-century coastal fort, and arrives at Mirador de San Pedro — a clifftop viewpoint with sweeping ocean views.",
  },
  {
    day: 6,
    title: "Traditional Canarian games",
    description:
      "Back at Playa Jardín for an afternoon of traditional games from the Canary Islands: crab races, tug-of-war and the handkerchief game. Loud, fun, and a genuine window into local culture.",
  },
  {
    day: 7,
    title: "Zip-line park at Forestal Park",
    description:
      "A special day at Forestal Park Tenerife, a high-altitude adventure park in the forests of Monte de La Esperanza. Before heading in, the group takes part in a short session on emotions — naming them, noticing them, and letting go of the negative ones through a dreamcatcher activity afterward. Lunch is a picnic in the forest.",
  },
  {
    day: 8,
    title: "Teide National Park & Observatory",
    description:
      "A full-day excursion to the top of Tenerife. One group visits the Teide Observatory, home to leading European solar telescopes. The other explores the El Portillo Visitor Centre, with exhibitions on volcanic geology, a botanical garden of native species and a simulated volcanic tube. Both groups then meet at Roques de García for lunch and a breathing and nature connection activity, surrounded by one of the most dramatic landscapes in Europe.",
  },
  {
    day: 9,
    title: "La Orotava cultural walk",
    description:
      "A guided tour through the beautifully preserved historic town of La Orotava. Campers visit a neo-Gothic chapel, a 19th-century French garden with panoramic views, the iconic Casa de los Balcones with its carved wooden architecture, and a traditional gofio mill — a staple of Canarian food culture.",
  },
  {
    day: 10,
    title: "Surfing at Playa Martiánez",
    description:
      "Just five minutes from the hotel, campers try surfing for the first time (or build on what they know) in small groups with professional instructors. While half surf, the other half enjoy the beach or the hotel pool.",
  },
  {
    day: 11,
    title: "Painting workshop & beach",
    description:
      "An afternoon combining creativity with sunshine. Campers take a guided painting workshop on the beach, turning their impressions of the trip into their own artwork. A quieter, more reflective counterpoint to the more active days.",
  },
  {
    day: 12,
    title: "Surfing, round two",
    description:
      "Another session in the water, with extended surf classes for all participants. More time in the sea, more time to progress.",
  },
  {
    day: 13,
    title: "Farewell beach games",
    description:
      "The last beach afternoon: handball, beach paddles, gymkhana obstacle courses and relay races. Before leaving, the whole group gathers in a circle to share their favourite memory of Tenerife.",
  },
  {
    day: 14,
    title: "Loro Parque",
    description:
      "The final special-day excursion takes campers to Loro Parque, one of Europe's most celebrated wildlife parks. The visit is designed not just as a fun day out, but as a meaningful encounter with animal welfare and biodiversity conservation — themes that connect to the broader values of the camp.",
  },
  {
    day: 15,
    title: "Farewell & the jar of messages",
    description:
      "The last day brings the group together for a final activity: the jar of messages. Each camper writes a note — a reflection, an encouragement, a memory — folds it up and adds it to a shared jar. It's a simple, powerful way to close two weeks of shared experience. The day ends with a collective farewell discussion and the kind of goodbyes that usually involve promises to stay in touch.",
  },
];

const total = activities.length;
---

<div class="scene" data-scene>
  <section
    class="section scene__layer scene__layer--tilt adv"
    data-theme={theme}
  >
    <!-- ── Hero block ──────────────────────────────────────────── -->
    <header class="adv__hero">
      <div class="adv__title-block">
        <HeroTitle>ADVENTURES</HeroTitle>
        <!-- "Daily" eyebrow absolutely centred over ADVENTURES
             (both axes) so it reads as a stamp on top of the
             giant word rather than a separate line above it. -->
        <span class="adv__eyebrow" aria-hidden="true">Daily</span>
      </div>
      <p class="font-body-l adv__intro">
        Outside of study hours, campers have a full schedule of
        activities across Tenerife — beaches, national parks,
        historic towns, and cultural workshops. Two weeks of
        afternoons and evenings, planned but never crammed.
      </p>
    </header>

    <!-- ── Activity browser ────────────────────────────────────── -->
    <div class="adv__browser" data-adv-browser>
      <div class="adv__split">
        <!-- LEFT column.
             TOP half:
               · Title row (activity name on the left, "Day X"
                 label on the top-right corner).
               · Arrows + full-width progress ruler at the bottom.
                 Arrows sit ABOVE the ruler.
             BOTTOM half:
               · Description, pinned to top of the half. -->
        <div class="adv__text">
          <div class="adv__top">
            <div class="adv__name-slot">
              {activities.map((a, i) => (
                <div
                  class="adv__name-card"
                  data-adv-slot="name"
                  data-adv-index={i}
                  data-active={i === 0 ? "true" : undefined}
                >
                  <p class="font-body adv__day-label">Day {a.day}</p>
                  <h3 class="font-h2 adv__name">{a.title}</h3>
                </div>
              ))}
            </div>

            <div class="adv__indicator">
              <div class="adv__arrows">
                <button
                  type="button"
                  class="adv__nav-btn"
                  data-adv-prev
                  aria-label="Previous activity"
                >
                  <svg viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <circle class="adv__nav-bg" cx="12" cy="12" r="11" />
                    <path class="adv__nav-arrow" d="M14 8 L10 12 L14 16" fill="none" stroke-width="1.5" />
                  </svg>
                </button>
                <button
                  type="button"
                  class="adv__nav-btn"
                  data-adv-next
                  aria-label="Next activity"
                >
                  <svg viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <circle class="adv__nav-bg" cx="12" cy="12" r="11" />
                    <path class="adv__nav-arrow" d="M10 8 L14 12 L10 16" fill="none" stroke-width="1.5" />
                  </svg>
                </button>
              </div>
              <ol class="adv__progress" aria-hidden="true">
                {/* Dense ruler: 5 ticks per activity step (1
                    major + 4 minor between two activities). Major
                    ticks fall at multiples of 5; minor ticks fill
                    the gaps. JS sets `data-state` to "past" up to
                    and including the active major tick, "future"
                    beyond — the bar fills primary as the user
                    steps through. */}
                {Array.from({ length: (total - 1) * 5 + 1 }, (_, ti) => {
                  const isMajor = ti % 5 === 0;
                  return (
                    <li
                      class:list={[
                        "adv__tick",
                        isMajor ? "adv__tick--major" : "adv__tick--minor",
                      ]}
                      data-adv-tick={ti}
                      data-state={ti === 0 ? "past" : "future"}
                      data-active={ti === 0 ? "true" : undefined}
                    ></li>
                  );
                })}
              </ol>
            </div>
          </div>

          <hr class="adv__text-divider" aria-hidden="true" />

          <div class="adv__content">
            {activities.map((a, i) => (
              <p
                class="font-body adv__desc"
                data-adv-slot="desc"
                data-adv-index={i}
                data-active={i === 0 ? "true" : undefined}
              >
                {a.description}
              </p>
            ))}
          </div>
        </div>

        <!-- Vertical divider track — same convention as Story /
             Team. Hidden on mobile. -->
        <div class="adv__split-divider" aria-hidden="true"></div>

        <!-- RIGHT: photo. Same crossfade pattern — every photo is
             stacked, only `data-active="true"` is opaque. -->
        <div class="adv__photo">
          {activities.map((a, i) => (
            <div
              class="adv__photo-frame"
              data-adv-slot="photo"
              data-adv-index={i}
              data-active={i === 0 ? "true" : undefined}
            >
              {photos[i] ? (
                <Image
                  class="adv__photo-img"
                  src={photos[i]}
                  alt={a.title}
                  widths={[640, 960, 1280, 1600]}
                  sizes="(min-width: 768px) 50vw, 100vw"
                  loading={i < 2 ? "eager" : "lazy"}
                />
              ) : (
                <div class="adv__photo-placeholder" aria-hidden="true">
                  Day {a.day}
                </div>
              )}
            </div>
          ))}
        </div>
      </div>

    </div>
  </section>
</div>

<style>
  /* ── Section frame ──────────────────────────────────────────── */
  .adv {
    /* Section grows naturally — hero + browser stack vertically.
     * The browser is the 100svh part; the hero adds whatever its
     * intrinsic content needs on top. */
    min-height: 100lvh;
    display: flex;
    flex-direction: column;
    gap: var(--space-3xl);
    /* Drop the section's default bottom padding so the activity
     * browser's bottom edge sits flush against the scene bottom.
     * When the scene pins (data-scene → bottom-bottom), this
     * means the browser fills the visible viewport below the nav
     * exactly — no slack, no clipping. */
    padding-block-end: 0;
  }

  /* ── Hero block ─────────────────────────────────────────────── */
  .adv__hero {
    display: flex;
    flex-direction: column;
    gap: var(--space-4xl);
  }

  /* Title block — relative containing block for the absolutely-
   * centred "Daily" eyebrow that floats over ADVENTURES. */
  .adv__title-block {
    position: relative;
  }

  /* "Daily" handwritten eyebrow stacked on the centre of the
   * giant ADVENTURES word — both axes. Same script font + primary
   * colour treatment as the SectionTitle eyebrow on other
   * scenes. `pointer-events: none` so it never intercepts clicks
   * meant for the title beneath. */
  .adv__eyebrow {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%) rotate(-4deg);
    transform-origin: center;
    font-family: var(--font-script);
    font-weight: var(--weight-regular);
    color: var(--primary);
    line-height: 1;
    /* Shared script-eyebrow size — matches SectionSafety's
     * "always" eyebrow and SectionTitle's overlap/between
     * eyebrows so all script accents read at the same scale. */
    font-size: clamp(1.75rem, 3.5vw, 3rem);
    pointer-events: none;
    z-index: 2;
  }

  .adv__intro {
    margin: 0;
    max-width: 60ch;
  }

  /* ── Activity browser ────────────────────────────────────────── */
  .adv__browser {
    /* Browser fills exactly one viewport MINUS the fixed nav so
     * nothing clips behind the nav strip when the section comes
     * into view. `--nav-height` is JS-synced to the nav's actual
     * rendered height (see installNavBg in TenerifeCampV2Layout). */
    height: calc(100svh - var(--nav-height));
    max-height: calc(100svh - var(--nav-height));
    /* Horizontal rule above the browser — separates the intro
     * paragraph from the activity-by-activity content. Matching
     * `padding-block-end` mirrors the top spacing so the vertical
     * divider, photo, and nav controls all keep the same breathing
     * room from the section's bottom edge as they have from the
     * top horizontal rule. `box-sizing: border-box` ensures the
     * padding is absorbed inside the 100svh-navH height — no
     * extra scroll. */
    border-block-start: 1px solid var(--border);
    padding-block: var(--space-l);
    box-sizing: border-box;
  }

  .adv__split {
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    gap: var(--space-l);
    min-height: 0;
    height: 100%;
  }

  .adv__split-divider {
    display: none;
  }

  @media (min-width: 768px) {
    .adv__split {
      grid-template-columns: minmax(0, 1fr) auto minmax(0, 1fr);
      column-gap: var(--space-2xl);
    }
    .adv__split-divider {
      display: block;
      width: 1px;
      background: var(--border);
      align-self: stretch;
    }
  }

  /* ── Left text column ───────────────────────────────────────── */
  /* No extra inline padding — the .adv__split column-gap
   * (`var(--space-2xl)`) already provides the breathing room
   * between the text and the vertical divider, matching the
   * Story / Team layout convention. */
  .adv__text {
    display: flex;
    flex-direction: column;
    min-height: 0;
    height: 100%;
  }

  /* Top half — title above, arrows + ruler at the bottom.
   * `position: relative` so the absolutely-positioned Day label
   * can pin to the top-right corner without taking horizontal
   * space from the title beneath it. */
  .adv__top {
    flex: 1;
    min-height: 0;
    position: relative;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    padding-block-end: var(--space-m);
    gap: var(--space-m);
  }

  .adv__name-slot {
    position: relative;
    width: 100%;
    /* Reserve room for the day label + a 2-line title so the
     * indicator beneath doesn't shift between activities. */
    min-height: calc(
      var(--type-step-1) * var(--leading-normal, 1.5)
      + 2 * var(--leading-tight, 1.15) * var(--type-step-4)
      + var(--space-2xs)
    );
  }

  /* Each activity's title card stacks the day label above the
   * activity title. Cards are absolutely positioned over each
   * other and crossfaded via `data-active`. */
  .adv__name-card {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-2xs);
    opacity: 0;
    transition: opacity 320ms ease;
    pointer-events: none;
  }

  .adv__name-card[data-active="true"] {
    opacity: 1;
    pointer-events: auto;
  }

  /* Day label sits above the title — same column, foreground-muted
   * body text. Reads as a small caption rather than a separate
   * stamp in the corner. */
  .adv__day-label {
    margin: 0;
    color: var(--foreground-muted);
  }

  /* Indicator block (arrows above ruler), pushed to the bottom
   * of the top half so it sits flush above the horizontal
   * divider. */
  .adv__indicator {
    display: flex;
    flex-direction: column;
    gap: var(--space-s);
  }

  .adv__arrows {
    display: flex;
    align-items: center;
    gap: var(--space-2xs);
  }

  /* Horizontal progress ruler — full width, two tiers of hash
   * marks. Major ticks (1 per activity) and minor ticks (4 in
   * between each pair of majors) for fine ruler density. All
   * hashes share the same baseline (`align-items: flex-end`) so
   * shorter ones extend up from the bottom rather than centring. */
  .adv__progress {
    width: 100%;
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 0;
    min-width: 0;
    height: 18px;
  }

  .adv__tick {
    flex: 0 0 auto;
    width: 1.5px;
    transition: background 220ms ease;
  }

  .adv__tick--major {
    height: 18px;
  }

  .adv__tick--minor {
    height: 8px;
    width: 1px;
  }

  .adv__tick[data-state="past"] {
    background: var(--primary);
  }

  .adv__tick[data-state="future"] {
    background: var(--foreground-muted);
  }

  /* Horizontal rule separating the top bar from the activity
   * content (name + description). Theme-coloured rule. */
  .adv__text-divider {
    border: 0;
    border-block-start: 1px solid var(--border);
    margin: 0;
  }

  /* Title flows in the card under the day label. `max-width:
   * 16ch` + `text-wrap: balance` evens the wrap to ~2 lines. */
  .adv__name {
    margin: 0;
    max-width: 16ch;
    text-wrap: balance;
  }

  .adv__name[data-active="true"] {
    opacity: 1;
    pointer-events: auto;
  }

  /* Content (description) area below the divider — bottom half
   * of the column. Relative containing block for the absolutely-
   * stacked description entries. */
  .adv__content {
    flex: 1;
    position: relative;
    min-height: 0;
    padding-block-start: var(--space-m);
  }

  .adv__desc {
    position: absolute;
    inset: 0;
    margin: 0;
    padding-block-start: var(--space-m);
    font-size: var(--type-step-1);
    line-height: 1.45;
    max-width: 50ch;
    overflow-y: auto;
    overscroll-behavior: contain;
    opacity: 0;
    transition: opacity 320ms ease;
    pointer-events: none;
  }

  .adv__desc[data-active="true"] {
    opacity: 1;
    pointer-events: auto;
  }

  /* ── Right photo column ─────────────────────────────────────── */
  /* Slightly smaller than its grid cell so the photo doesn't
   * dominate the section. Centered vertically and horizontally
   * inside its half — the surrounding breathing room visually
   * balances the empty space below the description / arrows on
   * the left column. */
  .adv__photo {
    position: relative;
    width: 92%;
    height: 88%;
    align-self: center;
    justify-self: center;
    border-radius: 8px;
    overflow: hidden;
    background: var(--surface);
  }


  .adv__photo-frame {
    position: absolute;
    inset: 0;
    opacity: 0;
    transition: opacity 320ms ease;
  }

  .adv__photo-frame[data-active="true"] {
    opacity: 1;
  }

  .adv__photo-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .adv__photo-placeholder {
    width: 100%;
    height: 100%;
    display: grid;
    place-items: center;
    font-family: var(--font-display);
    font-weight: 800;
    font-size: clamp(2rem, 6vw, 5rem);
    color: var(--foreground-muted);
  }

  /* ── Nav arrow buttons (in the top bar) ─────────────────────── */
  .adv__nav-btn {
    appearance: none;
    border: 0;
    background: transparent;
    padding: 0;
    width: 1.75rem;
    height: 1.75rem;
    cursor: pointer;
    display: inline-grid;
    place-items: center;
    transition: transform 220ms ease;
  }

  .adv__nav-btn:hover {
    transform: translateY(-1px);
  }

  .adv__nav-btn:disabled {
    cursor: not-allowed;
    opacity: 0.4;
  }

  .adv__nav-btn svg {
    width: 100%;
    height: 100%;
    display: block;
  }

  .adv__nav-bg {
    fill: var(--primary);
  }

  .adv__nav-arrow {
    stroke: var(--primary-foreground);
  }
</style>

<script>
  /**
   * Activity browser — prev / next state machine.
   *
   * `data-active="true"` on the matching slot for each track
   * (name / desc / photo) drives the visual state via CSS
   * transitions. Buttons + keyboard arrows advance the index.
   *
   * Wraps around at the ends so the user can step continuously
   * through all 15 activities. (Could be clamp-with-disabled later
   * — leaving wrap as the simpler default.)
   */

  type Slot = 'name' | 'desc' | 'photo';

  // Subdivisions per activity step on the progress ruler — must
  // match the `(total - 1) * 5 + 1` length used in the template.
  const TICK_SUBDIVISIONS = 5;

  function init() {
    const browser = document.querySelector<HTMLElement>('[data-adv-browser]');
    if (!browser) return;

    const prevBtn = browser.querySelector<HTMLButtonElement>('[data-adv-prev]');
    const nextBtn = browser.querySelector<HTMLButtonElement>('[data-adv-next]');

    const slots: Record<Slot, HTMLElement[]> = {
      name: Array.from(browser.querySelectorAll<HTMLElement>('[data-adv-slot="name"]')),
      desc: Array.from(browser.querySelectorAll<HTMLElement>('[data-adv-slot="desc"]')),
      photo: Array.from(browser.querySelectorAll<HTMLElement>('[data-adv-slot="photo"]')),
    };

    const ticks = Array.from(browser.querySelectorAll<HTMLElement>('.adv__tick'));

    const total = slots.name.length;
    if (total === 0) return;

    let active = 0;

    function show(i: number) {
      const next = ((i % total) + total) % total;
      if (next === active) return;
      (Object.keys(slots) as Slot[]).forEach((kind) => {
        slots[kind].forEach((el, idx) => {
          if (idx === next) el.dataset.active = 'true';
          else delete el.dataset.active;
        });
      });
      // Active major tick lives at `next * TICK_SUBDIVISIONS`.
      // Ticks 0..activeTickIdx fill as "past" (primary); the
      // rest stay "future" (muted). The active tick keeps its
      // own height — no scale animation, just a colour swap.
      const activeTickIdx = next * TICK_SUBDIVISIONS;
      ticks.forEach((tick) => {
        const ti = parseInt(tick.dataset.advTick || '0', 10);
        tick.dataset.state = ti <= activeTickIdx ? 'past' : 'future';
        if (ti === activeTickIdx) tick.dataset.active = 'true';
        else delete tick.dataset.active;
      });
      active = next;
    }

    if (prevBtn) prevBtn.onclick = () => show(active - 1);
    if (nextBtn) nextBtn.onclick = () => show(active + 1);

    // Keyboard ←/→ when the browser panel is in viewport. Skips
    // when the user is typing in an input so we don't hijack form
    // navigation elsewhere on the page.
    function onKey(e: KeyboardEvent) {
      const tag = (e.target as HTMLElement)?.tagName;
      if (tag === 'INPUT' || tag === 'TEXTAREA' || (e.target as HTMLElement)?.isContentEditable) return;
      const rect = browser!.getBoundingClientRect();
      const inView = rect.bottom > 0 && rect.top < window.innerHeight;
      if (!inView) return;
      if (e.key === 'ArrowLeft') show(active - 1);
      else if (e.key === 'ArrowRight') show(active + 1);
    }
    window.addEventListener('keydown', onKey);
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init, { once: true });
  } else {
    init();
  }
  document.addEventListener('astro:page-load', init);
</script>
