---
/**
 * ActivitiesSection — the "Daily ADVENTURES" scene.
 *
 * Layout:
 *   1. Hero block — full-width "Daily" script eyebrow + giant
 *      ADVENTURES `HeroTitle` with the stretch-on-load animation.
 *      Intro paragraph beneath.
 *   2. Activity browser — single 100svh frame split left/right.
 *      LEFT: activity name (top half) + description (bottom half).
 *      RIGHT: full-bleed photo.
 *      Bottom-right corner: prev / next arrows + index counter.
 *
 * The user can scroll past the browser at their own pace — only one
 * activity is in view at a time, and arrows (or keyboard ←/→) cycle
 * through the 15 days. No more 15-viewport-tall pin window.
 *
 * Photo files in `src/assets/tenerife/activities/` are matched to
 * activities by index after a `01-…`, `02-…` filename sort.
 */

import { Image, type ImageMetadata } from "astro:assets";
import HScrollMobile from "@/components/tenerife/HScrollMobile.astro";
import HeroTitle from "@/components/tenerife/HeroTitle.astro";
import { useTenerifeTranslations, type Language } from "@/i18n/tenerife";

const photoModules = import.meta.glob<{ default: ImageMetadata }>(
  "@/assets/tenerife/activities/*.{jpg,jpeg,png,webp,avif}",
  { eager: true },
);
const photos: ImageMetadata[] = Object.entries(photoModules)
  .sort(([a], [b]) => a.localeCompare(b))
  .map(([, mod]) => mod.default);

export interface Props {
  /** Locale for this render. */
  locale: Language;
  /** Tenerife theme palette to apply via `data-theme`. */
  theme?: "orange" | "blue" | "yellow" | "neutral";
}

const { locale, theme = "blue" } = Astro.props;
const t = useTenerifeTranslations(locale);
const activities = t.activities.items;
const total = activities.length;
---

<div class="scene" data-scene data-scene-index="5">
  <section
    class="section scene__layer scene__layer--tilt adv"
    data-theme={theme}
  >
    <!-- ── Hero block ──────────────────────────────────────────── -->
    <header class="adv__hero">
      <div class="adv__title-block">
        <HeroTitle>{t.activities.title}</HeroTitle>
        <!-- Eyebrow absolutely centred over the title (both axes)
             so it reads as a stamp on top of the giant word
             rather than a separate line above it. -->
        <span class="adv__eyebrow" aria-hidden="true">{t.activities.eyebrow}</span>
      </div>
      <p class="font-body-l adv__intro">{t.activities.intro}</p>
    </header>

    <!-- ── Activity browser ────────────────────────────────────── -->
    <div class="adv__browser" data-adv-browser>
      <div class="adv__split">
        <!-- LEFT column.
             TOP half:
               · Title row (activity name on the left, "Day X"
                 label on the top-right corner).
               · Arrows + full-width progress ruler at the bottom.
                 Arrows sit ABOVE the ruler.
             BOTTOM half:
               · Description, pinned to top of the half. -->
        <div class="adv__text">
          <div class="adv__top">
            <div class="adv__name-slot">
              {activities.map((a, i) => (
                <div
                  class="adv__name-card"
                  data-adv-slot="name"
                  data-adv-index={i}
                  data-active={i === 0 ? "true" : undefined}
                >
                  <p class="font-body adv__day-label">{t.activities.dayLabel} {a.day}</p>
                  <h3 class="font-h2 adv__name">{a.title}</h3>
                </div>
              ))}
            </div>

            <div class="adv__indicator">
              <div class="adv__arrows">
                <button
                  type="button"
                  class="adv__nav-btn"
                  data-adv-prev
                  aria-label={t.activities.prevAriaLabel}
                >
                  <svg viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <circle class="adv__nav-bg" cx="12" cy="12" r="11" />
                    <path class="adv__nav-arrow" d="M14 8 L10 12 L14 16" fill="none" stroke-width="1.5" />
                  </svg>
                </button>
                <button
                  type="button"
                  class="adv__nav-btn"
                  data-adv-next
                  aria-label={t.activities.nextAriaLabel}
                >
                  <svg viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <circle class="adv__nav-bg" cx="12" cy="12" r="11" />
                    <path class="adv__nav-arrow" d="M10 8 L14 12 L10 16" fill="none" stroke-width="1.5" />
                  </svg>
                </button>
              </div>
              <ol class="adv__progress" aria-hidden="true">
                {/* Dense ruler: 5 ticks per activity step (1
                    major + 4 minor between two activities). Major
                    ticks fall at multiples of 5; minor ticks fill
                    the gaps. JS sets `data-state` to "past" up to
                    and including the active major tick, "future"
                    beyond — the bar fills primary as the user
                    steps through. */}
                {Array.from({ length: (total - 1) * 5 + 1 }, (_, ti) => {
                  const isMajor = ti % 5 === 0;
                  return (
                    <li
                      class:list={[
                        "adv__tick",
                        isMajor ? "adv__tick--major" : "adv__tick--minor",
                      ]}
                      data-adv-tick={ti}
                      data-state={ti === 0 ? "past" : "future"}
                      data-active={ti === 0 ? "true" : undefined}
                    ></li>
                  );
                })}
              </ol>
            </div>
          </div>

          <hr class="adv__text-divider" aria-hidden="true" />

          <div class="adv__content">
            {activities.map((a, i) => (
              <p
                class="font-body adv__desc"
                data-adv-slot="desc"
                data-adv-index={i}
                data-active={i === 0 ? "true" : undefined}
              >
                {a.description}
              </p>
            ))}
          </div>
        </div>

        <!-- Vertical divider track — same convention as Story /
             Team. Hidden on mobile. -->
        <div class="adv__split-divider" aria-hidden="true"></div>

        <!-- RIGHT: photo column. A three.js film-reel sits over a
             stack of static <Image> frames. The fallback frames are
             always in the DOM — they're the texture source for
             three.js AND the visual fallback if WebGL fails or
             reduced-motion is set. The canvas reveals over them
             after first render via `data-canvas-active="1"`. -->
        <div class="adv__photo" data-adv-film>
          <canvas class="adv__film-canvas" data-adv-film-canvas></canvas>
          <div class="adv__film-fallback" data-adv-film-fallback>
            {activities.map((a, i) => (
              <div
                class="adv__photo-frame"
                data-adv-slot="photo"
                data-adv-index={i}
                data-active={i === 0 ? "true" : undefined}
              >
                {photos[i] ? (
                  <Image
                    class="adv__photo-img"
                    src={photos[i]}
                    alt={a.title}
                    widths={[640, 960, 1280, 1600]}
                    sizes="(min-width: 768px) 50vw, 100vw"
                    loading={i < 2 ? "eager" : "lazy"}
                  />
                ) : (
                  <div class="adv__photo-placeholder" aria-hidden="true">
                    {t.activities.dayLabel} {a.day}
                  </div>
                )}
              </div>
            ))}
          </div>
        </div>
      </div>

    </div>

    <!-- ── Mobile polaroid stack ─────────────────────────────────
         On <768px the desktop activity-browser is hidden and this
         block takes over: a horizontal-snap row of polaroid cards.
         Tap a card to flip its bottom row from photo → description.
         Same card pattern as the original v1 mobile experience. -->
    <div class="adv__mobile">
      <HScrollMobile itemWidth="min(80%, 320px)">
        {activities.map((a, i) => (
          <button
            type="button"
            class="ap-card"
            aria-expanded="false"
            data-ap-card
            aria-label={`${t.activities.dayLabel} ${a.day}: ${a.title} — ${t.activities.cardTapHint}`}
          >
            <div class="ap-card__photo">
              {photos[i] && (
                <Image
                  class="ap-card__img"
                  src={photos[i]}
                  alt={a.title}
                  widths={[320, 480, 640]}
                  sizes="80vw"
                  loading="lazy"
                />
              )}
            </div>
            <div class="ap-card__head">
              <p class="font-caption ap-card__day">{t.activities.dayLabel} {a.day}</p>
              <h3 class="font-caption-script ap-card__title">{a.title}</h3>
            </div>
            <div class="ap-card__body">
              <p class="font-body-s ap-card__description">{a.description}</p>
            </div>
            <span class="ap-card__cue" aria-hidden="true"></span>
          </button>
        ))}
      </HScrollMobile>
    </div>
  </section>
</div>

<style>
  /* ── Section frame ──────────────────────────────────────────── */
  .adv {
    /* Section grows naturally — hero + browser stack vertically.
     * The browser is the 100svh part; the hero adds whatever its
     * intrinsic content needs on top. */
    min-height: 100lvh;
    display: flex;
    flex-direction: column;
    gap: var(--space-3xl);
    /* Drop the section's default bottom padding so the activity
     * browser's bottom edge sits flush against the scene bottom.
     * When the scene pins (data-scene → bottom-bottom), this
     * means the browser fills the visible viewport below the nav
     * exactly — no slack, no clipping. */
    padding-block-end: 0;
  }

  /* ── Hero block ─────────────────────────────────────────────── */
  .adv__hero {
    display: flex;
    flex-direction: column;
    gap: var(--space-4xl);
  }

  /* Title block — relative containing block for the absolutely-
   * centred "Daily" eyebrow that floats over ADVENTURES. */
  .adv__title-block {
    position: relative;
  }

  /* "Daily" handwritten eyebrow stacked on the centre of the
   * giant ADVENTURES word — both axes. Same script font + primary
   * colour treatment as the SectionTitle eyebrow on other
   * scenes. `pointer-events: none` so it never intercepts clicks
   * meant for the title beneath. */
  .adv__eyebrow {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%) rotate(-4deg);
    transform-origin: center;
    font-family: var(--font-script);
    font-weight: var(--weight-regular);
    color: var(--primary);
    line-height: 1;
    /* Shared script-eyebrow size — matches SectionSafety's
     * "always" eyebrow and SectionTitle's overlap/between
     * eyebrows so all script accents read at the same scale. */
    font-size: clamp(1.75rem, 3.5vw, 3rem);
    pointer-events: none;
    z-index: 2;
  }

  .adv__intro {
    margin: 0;
    max-width: 60ch;
  }

  /* ── Mobile / desktop swap ──────────────────────────────────────
   * `.adv__browser` (the unified single-frame browser) is the desktop
   * presentation; `.adv__mobile` (the polaroid h-scroll) is the
   * mobile presentation. They never coexist — each one is hidden on
   * the other breakpoint. The `.adv__browser` block-level rules
   * below still apply on desktop; they're overridden to `display:
   * none` on mobile by the rule right below. */
  .adv__mobile {
    display: block;
  }

  @media (max-width: 767.98px) {
    .adv__browser {
      display: none !important;
    }
    /* Runway below the polaroid row so the sticky Join CTA pinned
     * to the viewport bottom doesn't crash into the last card. */
    .adv__mobile {
      padding-block-end: var(--space-3xl);
    }
  }

  @media (min-width: 768px) {
    .adv__mobile {
      display: none;
    }
  }

  /* ── Activity browser (desktop) ──────────────────────────────── */
  .adv__browser {
    /* Browser fills exactly one viewport MINUS the fixed nav so
     * nothing clips behind the nav strip when the section comes
     * into view. `--nav-height` is JS-synced to the nav's actual
     * rendered height (see installNavBg in TenerifeCampV2Layout). */
    height: calc(100svh - var(--nav-height));
    max-height: calc(100svh - var(--nav-height));
    /* Horizontal rule above the browser — separates the intro
     * paragraph from the activity-by-activity content. Matching
     * `padding-block-end` mirrors the top spacing so the vertical
     * divider, photo, and nav controls all keep the same breathing
     * room from the section's bottom edge as they have from the
     * top horizontal rule. `box-sizing: border-box` ensures the
     * padding is absorbed inside the 100svh-navH height — no
     * extra scroll. */
    border-block-start: 1px solid var(--border);
    padding-block: var(--space-l);
    box-sizing: border-box;
  }

  .adv__split {
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    gap: var(--space-l);
    min-height: 0;
    height: 100%;
  }

  .adv__split-divider {
    display: none;
  }

  @media (min-width: 768px) {
    .adv__split {
      grid-template-columns: minmax(0, 1fr) auto minmax(0, 1fr);
      column-gap: var(--space-2xl);
    }
    .adv__split-divider {
      display: block;
      width: 1px;
      background: var(--border);
      align-self: stretch;
    }
  }

  /* ── Left text column ───────────────────────────────────────── */
  /* No extra inline padding — the .adv__split column-gap
   * (`var(--space-2xl)`) already provides the breathing room
   * between the text and the vertical divider, matching the
   * Story / Team layout convention. */
  .adv__text {
    display: flex;
    flex-direction: column;
    min-height: 0;
    height: 100%;
  }

  /* Top half — title above, arrows + ruler at the bottom.
   * `position: relative` so the absolutely-positioned Day label
   * can pin to the top-right corner without taking horizontal
   * space from the title beneath it. */
  .adv__top {
    flex: 1;
    min-height: 0;
    position: relative;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    padding-block-end: var(--space-m);
    gap: var(--space-m);
  }

  .adv__name-slot {
    position: relative;
    width: 100%;
    /* Reserve room for the day label + a 2-line title so the
     * indicator beneath doesn't shift between activities. */
    min-height: calc(
      var(--type-step-1) * var(--leading-normal, 1.5)
      + 2 * var(--leading-tight, 1.15) * var(--type-step-4)
      + var(--space-2xs)
    );
  }

  /* Each activity's title card stacks the day label above the
   * activity title. Cards are absolutely positioned over each
   * other and crossfaded via `data-active`. */
  .adv__name-card {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-2xs);
    opacity: 0;
    transition: opacity 320ms ease;
    pointer-events: none;
  }

  .adv__name-card[data-active="true"] {
    opacity: 1;
    pointer-events: auto;
  }

  /* Day label sits above the title — same column, foreground-muted
   * body text. Reads as a small caption rather than a separate
   * stamp in the corner. */
  .adv__day-label {
    margin: 0;
    color: var(--foreground-muted);
  }

  /* Indicator block (arrows above ruler), pushed to the bottom
   * of the top half so it sits flush above the horizontal
   * divider. */
  .adv__indicator {
    display: flex;
    flex-direction: column;
    gap: var(--space-s);
  }

  .adv__arrows {
    display: flex;
    align-items: center;
    gap: var(--space-2xs);
  }

  /* Horizontal progress ruler — full width, two tiers of hash
   * marks. Major ticks (1 per activity) and minor ticks (4 in
   * between each pair of majors) for fine ruler density. All
   * hashes share the same baseline (`align-items: flex-end`) so
   * shorter ones extend up from the bottom rather than centring. */
  .adv__progress {
    width: 100%;
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 0;
    min-width: 0;
    height: 18px;
  }

  .adv__tick {
    flex: 0 0 auto;
    width: 1.5px;
    transition: background 220ms ease;
  }

  .adv__tick--major {
    height: 18px;
  }

  .adv__tick--minor {
    height: 8px;
    width: 1px;
  }

  .adv__tick[data-state="past"] {
    background: var(--primary);
  }

  .adv__tick[data-state="future"] {
    background: var(--foreground-muted);
  }

  /* Horizontal rule separating the top bar from the activity
   * content (name + description). Theme-coloured rule. */
  .adv__text-divider {
    border: 0;
    border-block-start: 1px solid var(--border);
    margin: 0;
  }

  /* Title flows in the card under the day label. `max-width:
   * 16ch` + `text-wrap: balance` evens the wrap to ~2 lines. */
  .adv__name {
    margin: 0;
    max-width: 16ch;
    text-wrap: balance;
  }

  .adv__name[data-active="true"] {
    opacity: 1;
    pointer-events: auto;
  }

  /* Content (description) area below the divider — bottom half
   * of the column. Relative containing block for the absolutely-
   * stacked description entries. */
  .adv__content {
    flex: 1;
    position: relative;
    min-height: 0;
    padding-block-start: var(--space-m);
  }

  .adv__desc {
    position: absolute;
    inset: 0;
    margin: 0;
    padding-block-start: var(--space-m);
    font-size: var(--type-step-1);
    line-height: 1.45;
    max-width: 50ch;
    overflow-y: auto;
    overscroll-behavior: contain;
    opacity: 0;
    transition: opacity 320ms ease;
    pointer-events: none;
  }

  .adv__desc[data-active="true"] {
    opacity: 1;
    pointer-events: auto;
  }

  /* ── Right photo column ─────────────────────────────────────── */
  /* Fills the full right column top-to-bottom so the three.js
   * film reel can extend across the whole 100svh-nav viewport.
   * No background — the strip's own off-black film body shows
   * through; the section bg is visible only at the very edges. */
  .adv__photo {
    position: relative;
    width: 100%;
    height: 100%;
    overflow: hidden;
  }

  /* On wider viewports, the photo column escapes the browser's
   * top/bottom padding (and the 1px border-block-start) by using
   * negative vertical margins, so the film strip's first and last
   * sprocket columns reach the very top/bottom edges of the
   * 100svh-nav frame — no slack inside the section. */
  @media (min-width: 768px) {
    .adv__photo {
      margin-block-start: calc(-1 * var(--space-l) - 1px);
      margin-block-end: calc(-1 * var(--space-l));
      height: calc(100% + 2 * var(--space-l) + 1px);
    }
  }


  /* Three.js film-reel canvas — covers the photo column, sits
   * above the fallback DOM frames. Hidden (slid down + faded out)
   * until the scene reports its first render via
   * `data-canvas-active="1"` on the parent. */
  .adv__film-canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    display: block;
    opacity: 0;
    transform: translateY(8%);
    transition:
      opacity 520ms ease,
      transform 640ms cubic-bezier(0.22, 0.9, 0.25, 1);
    pointer-events: none;
  }

  .adv__photo[data-canvas-active="1"] .adv__film-canvas {
    opacity: 1;
    transform: translateY(0);
  }

  /* Fallback frame stack lives behind the canvas. Visible by
   * default; faded out once the canvas takes over. Reduced-
   * motion / WebGL-fail leaves it visible. */
  .adv__film-fallback {
    position: absolute;
    inset: 0;
    transition: opacity 320ms ease;
  }

  .adv__photo[data-canvas-active="1"] .adv__film-fallback {
    opacity: 0;
  }

  .adv__photo-frame {
    position: absolute;
    inset: 0;
    opacity: 0;
    transition: opacity 320ms ease;
  }

  .adv__photo-frame[data-active="true"] {
    opacity: 1;
  }

  .adv__photo-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .adv__photo-placeholder {
    width: 100%;
    height: 100%;
    display: grid;
    place-items: center;
    font-family: var(--font-display);
    font-weight: 800;
    font-size: clamp(2rem, 6vw, 5rem);
    color: var(--foreground-muted);
  }

  /* ── Nav arrow buttons (in the top bar) ─────────────────────── */
  .adv__nav-btn {
    appearance: none;
    border: 0;
    background: transparent;
    padding: 0;
    width: 1.75rem;
    height: 1.75rem;
    cursor: pointer;
    display: inline-grid;
    place-items: center;
    transition: transform 220ms ease;
  }

  .adv__nav-btn:hover {
    transform: translateY(-1px);
  }

  .adv__nav-btn:disabled {
    cursor: not-allowed;
    opacity: 0.4;
  }

  .adv__nav-btn svg {
    width: 100%;
    height: 100%;
    display: block;
  }

  .adv__nav-bg {
    fill: var(--primary);
  }

  .adv__nav-arrow {
    stroke: var(--primary-foreground);
  }

  /* ── Mobile polaroid card ───────────────────────────────────────
   * 3-row grid (photo / head / body). Closed: photo dominates with
   * the day + title strip beneath it. Open: photo collapses to 0fr
   * and body expands to 1fr — the head sits between them and rides
   * up as the photo collapses. `grid-template-rows` is animated. */
  .ap-card {
    appearance: none;
    background: #f4efe7;
    color: #1a1a1a;
    border: 0;
    padding: var(--space-m);
    margin: 0;
    font: inherit;
    cursor: pointer;
    text-align: left;
    width: 100%;
    aspect-ratio: 4 / 5;
    border-radius: 4px;
    box-shadow: 0 6px 18px rgba(0, 0, 0, 0.16);
    overflow: hidden;
    position: relative;
    display: grid;
    grid-template-rows: 1fr auto 0fr;
    gap: var(--space-s);
    transition: grid-template-rows 0.55s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .ap-card[aria-expanded="true"] {
    grid-template-rows: 0fr auto 1fr;
  }

  .ap-card:focus-visible {
    outline: 2px solid var(--foreground);
    outline-offset: 4px;
  }

  .ap-card__photo,
  .ap-card__head,
  .ap-card__body {
    min-height: 0;
    overflow: hidden;
  }

  .ap-card__photo {
    border-radius: 2px;
    transition: opacity 0.4s ease;
  }
  .ap-card[aria-expanded="true"] .ap-card__photo {
    opacity: 0;
  }

  .ap-card__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .ap-card__head {
    display: flex;
    flex-direction: column;
    gap: 0.15em;
  }
  .ap-card__day {
    margin: 0;
    opacity: 0.55;
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    line-height: 1;
  }
  .ap-card__title {
    margin: 0;
    line-height: 1.2;
  }

  .ap-card__body {
    opacity: 0;
    transition: opacity 0.35s ease 0.1s;
  }
  .ap-card[aria-expanded="true"] .ap-card__body {
    opacity: 1;
    overflow-y: auto;
    overscroll-behavior: contain;
  }
  .ap-card__description {
    margin: 0;
    opacity: 0.85;
  }

  /* `+` corner cue rotates to `×` when card is open. */
  .ap-card__cue {
    position: absolute;
    bottom: var(--space-s);
    right: var(--space-s);
    width: 1.25rem;
    height: 1.25rem;
    pointer-events: none;
    color: rgba(0, 0, 0, 0.55);
    z-index: 1;
  }
  .ap-card__cue::before,
  .ap-card__cue::after {
    content: '';
    position: absolute;
    inset: 50% 0 auto 0;
    height: 1.5px;
    background: currentColor;
    transform-origin: center;
    transition: transform 280ms cubic-bezier(0.22, 1, 0.36, 1);
  }
  .ap-card__cue::after {
    transform: rotate(90deg);
  }
  .ap-card[aria-expanded="true"] .ap-card__cue::before {
    transform: rotate(45deg);
  }
  .ap-card[aria-expanded="true"] .ap-card__cue::after {
    transform: rotate(-45deg);
  }
</style>

<script>
  /**
   * Activity browser — prev / next state machine.
   *
   * `data-active="true"` on the matching slot for each track
   * (name / desc / photo) drives the visual state via CSS
   * transitions. Buttons + keyboard arrows advance the index.
   *
   * Wraps around at the ends so the user can step continuously
   * through all 15 activities.
   *
   * The right photo column is upgraded to a three.js film-reel
   * scene (see `initFilm`). The reel is gated by an
   * IntersectionObserver + requestIdleCallback so the three.module
   * chunk only loads when the activities scene is within ~1
   * viewport of the user.
   */

  // Type-only import — no runtime cost. Three is dynamic-imported
  // inside `initFilm` so its chunk is split out of the activities
  // bundle.
  import type * as THREE_NS from 'three';
  import { gsap } from 'gsap';

  type Slot = 'name' | 'desc' | 'photo';

  // Subdivisions per activity step on the progress ruler — must
  // match the `(total - 1) * 5 + 1` length used in the template.
  const TICK_SUBDIVISIONS = 5;

  // Module-level cache so the three module loads exactly once
  // even if init runs again (Astro view transitions).
  let threePromise: Promise<typeof THREE_NS> | null = null;
  function loadThree(): Promise<typeof THREE_NS> {
    if (!threePromise) threePromise = import('three');
    return threePromise;
  }

  interface FilmController {
    setActive(i: number): void;
    /**
     * Register a listener that fires when the drag-scrub crosses
     * into a different frame OR when a drag-release snaps to a
     * frame. The outer DOM (name / desc / ruler) reacts to this
     * without re-issuing a tween on the film itself.
     */
    onActiveChange(cb: (i: number) => void): void;
    destroy(): void;
  }

  let activeFilm: FilmController | null = null;

  /**
   * Build the three.js film-reel scene. A long vertical strip
   * (off-black film body with sprocket-hole pattern) extends top
   * to bottom of the right column. Photo planes for each activity
   * sit on top of the strip body in their respective frames. The
   * whole group translates Y to centre the active frame; during
   * the tween a vertex shader adds a wave displacement so the
   * strip looks like real film — a soft horizontal twist + depth
   * curve as it slides past, settling flat when motion stops.
   *
   * Bails out (returns null) and lets the static <Image> fallback
   * carry the column when:
   *   - prefers-reduced-motion: reduce
   *   - WebGLRenderer constructor throws
   *   - the canvas / fallback elements aren't in the DOM
   */

  // Vertex shader: deforms a flat plane into a slight helical
  // ribbon. The strip's parametric position along its length is
  // `t = position.y / uStripLen + uOffset`. The centerline of the
  // helix at `t` is (R sin θ, t * uStripLen, -R (1 - cos θ)) where
  // θ = t * 2π * uTurns. The strip's local "right" vector also
  // rotates around Y by θ — that's the TWIST: as you go up, the
  // strip pirouettes. Sliding `uOffset` from one frame to the next
  // makes the film travel along the fixed helical path.
  const FILM_VERT = /* glsl */ `
    uniform float uOffset;
    uniform float uStripLen;
    uniform float uPathAmp;
    uniform float uPathFreq;
    uniform float uPathPhase;
    varying vec2 vUv;
    void main() {
      vUv = uv;
      float t = position.y / uStripLen + uOffset;

      // Centerline lives on a fixed planar S-curve in world space:
      // x = sin(worldY * freq) * amp, with a small z bulge for
      // depth. The path is keyed off worldY (= t * stripLen), NOT
      // off the strip-local position.y. That distinction is the
      // whole point: as uOffset slides, the strip's vertices flow
      // *through* the fixed shape — the path doesn't move with
      // them. The active frame (t = 0 → worldY = 0) always sits
      // at the path's origin node.
      float worldY = t * uStripLen;
      float pathPhase = worldY * uPathFreq + uPathPhase;
      vec3 center = vec3(
        sin(pathPhase) * uPathAmp,
        worldY,
        cos(pathPhase * 0.7) * uPathAmp * 0.4
      );

      // Strip width runs along world X — the strip is a flat
      // planar ribbon, no twist, no axial rotation.
      vec3 right = vec3(1.0, 0.0, 0.0);
      vec3 wp = center + right * position.x;

      gl_Position = projectionMatrix * viewMatrix * modelMatrix * vec4(wp, 1.0);
    }
  `;

  // Fragment shader — sample the composite strip texture; discard
  // fully-transparent pixels (the punched sprocket holes) so the
  // page background shows through cleanly.
  const FILM_FRAG = /* glsl */ `
    uniform sampler2D uTex;
    varying vec2 vUv;
    void main() {
      vec4 c = texture2D(uTex, vUv);
      if (c.a < 0.02) discard;
      gl_FragColor = c;
    }
  `;

  /**
   * Wait for an <img> to be fully decoded so it can be safely
   * passed to drawImage at full resolution. Falls back to the
   * load event when img.decode() isn't available.
   */
  function decodeImg(img: HTMLImageElement): Promise<HTMLImageElement> {
    if (img.complete && img.naturalWidth > 0) {
      return img.decode ? img.decode().then(() => img).catch(() => img) : Promise.resolve(img);
    }
    return new Promise((resolve) => {
      const done = () => resolve(img);
      img.addEventListener('load', done, { once: true });
      img.addEventListener('error', done, { once: true });
    });
  }

  /**
   * Build the entire vertical film strip into ONE tall canvas: a
   * black film body for every frame, the activity's photo cropped
   * 2:3 inside its frame, two vertical columns of 8 punched-out
   * sprocket holes on each frame, and the frame number rendered
   * vertically on the strip's outer right edge (top of glyph at the
   * outer edge — like real 35mm stock).
   *
   * The whole strip lives in a single texture, so the strip mesh
   * is also a single plane — there is no z-fighting between body
   * and photo, no per-frame draw call, no compositing seams.
   */
  async function makeStripTexture(
    THREE: typeof THREE_NS,
    imgs: HTMLImageElement[],
    frameAspect: number, // tileH / tileW
    photoFracW: number,  // photo width as fraction of tileW
    photoAspect: number, // photoH / photoW
  ): Promise<THREE_NS.CanvasTexture> {
    const total = imgs.length;
    // Wait for every photo to decode so drawImage gets full
    // resolution, not the placeholder.
    await Promise.all(imgs.map(decodeImg));

    // High-res tile so the holes / numbers / photos don't pixelate
    // at 2x DPR. Cap the canvas's longer axis at 8192 (modern GPU
    // minimum) — if the full strip would exceed that, scale tileW
    // down proportionally. With 8192 cap the strip texture lands
    // well above 1px-per-screen-px on any sane viewport.
    let tileW = 2048;
    let tileH = Math.round(tileW * frameAspect);
    const MAX_AXIS = 8192;
    if (tileH * total > MAX_AXIS) {
      const scale = MAX_AXIS / (tileH * total);
      tileW = Math.floor(tileW * scale);
      tileH = Math.round(tileW * frameAspect);
    }
    const c = document.createElement('canvas');
    c.width = tileW;
    c.height = tileH * total;
    const ctx = c.getContext('2d')!;

    // Off-black film body — covers everything first.
    ctx.fillStyle = '#0a0a0c';
    ctx.fillRect(0, 0, c.width, c.height);

    // Photo geometry inside one tile.
    const photoW = Math.round(tileW * photoFracW);
    const photoH = Math.round(photoW * photoAspect);
    const photoX = Math.round((tileW - photoW) / 2);

    // Sprocket-hole geometry per tile — 8 holes per side.
    const holesPerSide = 8;
    const holeW = Math.round(tileW * 0.06);
    const holeH = Math.round(holeW * 1.4);
    const radius = Math.max(2, Math.round(holeW * 0.3));
    const colInset = Math.round(tileW * 0.03);
    const leftX = colInset;
    const rightX = tileW - colInset - holeW;
    const sideMargin = Math.round(tileH * 0.02);
    const usable = tileH - sideMargin * 2 - holeH;

    function roundRect(x: number, y: number, w: number, h: number, r: number) {
      ctx.beginPath();
      ctx.moveTo(x + r, y);
      ctx.lineTo(x + w - r, y);
      ctx.quadraticCurveTo(x + w, y, x + w, y + r);
      ctx.lineTo(x + w, y + h - r);
      ctx.quadraticCurveTo(x + w, y + h, x + w - r, y + h);
      ctx.lineTo(x + r, y + h);
      ctx.quadraticCurveTo(x, y + h, x, y + h - r);
      ctx.lineTo(x, y + r);
      ctx.quadraticCurveTo(x, y, x + r, y);
      ctx.closePath();
      ctx.fill();
    }

    // For each frame: draw the cropped photo, then the rotated
    // frame number on the outer right edge.
    for (let f = 0; f < total; f++) {
      const yBase = f * tileH;
      const photoY = yBase + Math.round((tileH - photoH) / 2);
      const img = imgs[f];

      // Cover-crop the photo into the frame box. NO ctx.filter —
      // any brightness/contrast/saturate bakes a colour shift into
      // the texture that the GPU pipeline cannot undo. We want the
      // raw sRGB pixels passed through; Three.js's colorSpace
      // round-trip (set on the texture + renderer) handles the
      // sRGB→linear→sRGB conversion losslessly.
      if (img && img.naturalWidth > 0 && img.naturalHeight > 0) {
        const targetAspect = photoW / photoH;
        const imgAspect = img.naturalWidth / img.naturalHeight;
        let sx = 0, sy = 0, sw = img.naturalWidth, sh = img.naturalHeight;
        if (imgAspect > targetAspect) {
          sw = img.naturalHeight * targetAspect;
          sx = (img.naturalWidth - sw) / 2;
        } else {
          sh = img.naturalWidth / targetAspect;
          sy = (img.naturalHeight - sh) / 2;
        }
        ctx.drawImage(img, sx, sy, sw, sh, photoX, photoY, photoW, photoH);
      }

      // Frame number — drawn on BOTH outer edges of the strip,
      // rotated so the TOP of the glyph touches the outer edge
      // and the digits read inward (toward the photo). Positioned
      // vertically in the middle of the frame, between holes 4
      // and 5 from the top (0-indexed slotIdx = 3).
      const slotIdx = 3;
      const slotYTop =
        yBase + sideMargin + (usable * slotIdx) / (holesPerSide - 1) + holeH;
      const slotYBot =
        yBase + sideMargin + (usable * (slotIdx + 1)) / (holesPerSide - 1);
      const slotY = (slotYTop + slotYBot) / 2;
      const num = String(f + 1).padStart(2, '0');
      const numFontSize = Math.round(tileW * 0.034);
      const numColor = '#e9a04a';
      const fontStack = '"Helvetica Neue", Helvetica, Arial, sans-serif';

      // Right edge — rotate +90° so glyph top is at the outer edge.
      ctx.save();
      ctx.translate(tileW - Math.round(tileW * 0.014), slotY);
      ctx.rotate(Math.PI / 2);
      ctx.fillStyle = numColor;
      ctx.font = `700 ${numFontSize}px ${fontStack}`;
      ctx.textAlign = 'center';
      ctx.textBaseline = 'top';
      ctx.fillText(num, 0, 0);
      ctx.restore();

      // Left edge — rotate -90° so the glyph top is at the LEFT
      // outer edge, mirroring the right side.
      ctx.save();
      ctx.translate(Math.round(tileW * 0.014), slotY);
      ctx.rotate(-Math.PI / 2);
      ctx.fillStyle = numColor;
      ctx.font = `700 ${numFontSize}px ${fontStack}`;
      ctx.textAlign = 'center';
      ctx.textBaseline = 'top';
      ctx.fillText(num, 0, 0);
      ctx.restore();
    }

    // Punch sprocket holes — destination-out clears alpha to 0,
    // including over the photo and numbers. The holes are truly
    // transparent in the resulting texture.
    ctx.save();
    ctx.globalCompositeOperation = 'destination-out';
    ctx.fillStyle = '#000';
    for (let f = 0; f < total; f++) {
      const yBase = f * tileH;
      for (let h = 0; h < holesPerSide; h++) {
        const yy = yBase + sideMargin + (usable * h) / (holesPerSide - 1);
        roundRect(leftX, yy, holeW, holeH, radius);
        roundRect(rightX, yy, holeW, holeH, radius);
      }
    }
    ctx.restore();

    const tex = new THREE.CanvasTexture(c);
    tex.wrapS = THREE.ClampToEdgeWrapping;
    tex.wrapT = THREE.ClampToEdgeWrapping;
    tex.minFilter = THREE.LinearMipmapLinearFilter;
    tex.magFilter = THREE.LinearFilter;
    tex.generateMipmaps = true;
    tex.anisotropy = 4;
    // No colorSpace tag — see ColorManagement.enabled = false in
    // initFilm. We pass canvas pixels straight through.
    return tex;
  }

  async function initFilm(container: HTMLElement): Promise<FilmController | null> {
    const canvas = container.querySelector<HTMLCanvasElement>('[data-adv-film-canvas]');
    const fallback = container.querySelector<HTMLElement>('[data-adv-film-fallback]');
    if (!canvas || !fallback) return null;

    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return null;

    const THREE = await loadThree();

    let renderer: THREE_NS.WebGLRenderer;
    try {
      renderer = new THREE.WebGLRenderer({
        canvas,
        alpha: true,
        antialias: true,
      });
    } catch {
      return null;
    }
    renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
    // Color management OFF. Three.js's automatic linear<->sRGB
    // conversions interact badly with custom ShaderMaterials and
    // canvas-2D textures — depending on the codepath you can get
    // double-decode (washed out) or double-encode (cooked). For a
    // pure photo pass-through, the cleanest answer is to disable
    // colour management entirely. Bytes from the 2D canvas land
    // unchanged in the framebuffer; the browser displays them as
    // sRGB (the canvas default). No transforms, no precision loss.
    THREE.ColorManagement.enabled = false;
    renderer.toneMapping = THREE.NoToneMapping;
    renderer.toneMappingExposure = 1.0;
    renderer.setClearColor(0x000000, 0);

    let { w, h } = sizeOf(container);
    renderer.setSize(w, h, false);

    const scene = new THREE.Scene();

    // Frame layout (pixel-space units, mapped 1:1 to canvas px via
    // the perspective camera). Photos are 2:3 portrait — height
    // drives off width. Strip is wider than the photo so two
    // sprocket-hole columns can flank it. `gutter` is the slim
    // black bar between consecutive photos — minimal, like real
    // 35mm stock.
    const PHOTO_ASPECT = 1.25; // height / width — 4:5 portrait
    const STRIP_FACTOR = 0.62; // strip width as fraction of column width
    const PHOTO_WITHIN_STRIP = 0.78; // photo width as fraction of strip width
    const GUTTER_FRACTION = 0.04; // gutter as fraction of frameH
    function computeLayout(width: number, height: number) {
      const stripW = width * STRIP_FACTOR;
      const photoW = stripW * PHOTO_WITHIN_STRIP;
      const photoH = photoW * PHOTO_ASPECT;
      const frameH = photoH / (1 - GUTTER_FRACTION);
      // height isn't actually used to drive frame size — strip
      // length is (frameH * total). Camera distance is derived
      // from `height` so 1 world unit ≈ 1 css px on the y-axis.
      void height;
      return { stripW, photoW, photoH, frameH };
    }
    let { stripW, photoW, photoH, frameH } = computeLayout(w, h);
    void photoW; void photoH;
    const FRAME_ASPECT = frameH / stripW;
    const PHOTO_FRAC_W = PHOTO_WITHIN_STRIP;

    const imgs = Array.from(fallback.querySelectorAll<HTMLImageElement>('img'));
    const total = imgs.length;
    if (total === 0) return null;

    // Perspective camera tuned so 1 unit ≈ 1 px at z=0 (the
    // group's plane). FOV picked so the visible frustum height at
    // z=0 equals the canvas height — same framing as the
    // orthographic version we started with, but now z-displacement
    // in the shader is visible.
    const fov = 35;
    const camDist = h / (2 * Math.tan((fov * Math.PI) / 360));
    const camera = new THREE.PerspectiveCamera(fov, w / h, 0.1, camDist * 4);
    camera.position.z = camDist;
    scene.add(camera);

    const group = new THREE.Group();
    scene.add(group);

    function render() {
      renderer.render(scene, camera);
    }

    // ── Curve / twist parameters ───────────────────────────────
    // The strip is a single plane whose vertex shader bends every
    // vertex along an analytical helix. uOffset slides the strip's
    // parametric position along the curve; the curve itself is
    // fixed in world space.
    //
    // - HELIX_R   — radius of the helix in world (px) units. The
    //               strip's centerline orbits this distance from
    //               the helix axis as it goes up/down.
    // - HELIX_TURNS — full revolutions over the strip's *visible*
    //               span (= total * frameH). 0.5 = strip rotates
    //               half a turn from top to bottom.
    // - HELIX_TWIST — extra rotation factor for the strip's right
    //               vector (the ribbon's flat-face orientation).
    //               1 = ribbon twists 1× along with the helix
    //               position.
    const STRIP_LEN = frameH * total;
    // Path parameters — fixed wavy plane in world space. The
    // strip's vertices flow through this shape as uOffset shifts.
    // - PATH_AMP: peak sideways bulge (world-px). Larger = more
    //   pronounced wave.
    // - PATH_FREQ: spatial frequency (radians per world-y px).
    //   Tuned so ~2 humps span the full strip — gentle, not busy.
    // - PATH_PHASE = 0 puts the active frame (worldY = 0) right at
    //   a wave node, so it sits unshifted at world origin while
    //   adjacent frames bulge to either side.
    let PATH_AMP = stripW * 0.18;
    let PATH_FREQ = (Math.PI * 2 * 2.0) / STRIP_LEN;
    const PATH_PHASE = 0;

    const sharedUniforms = {
      uTex: { value: null as THREE_NS.Texture | null },
      uOffset: { value: 0 },
      uStripLen: { value: STRIP_LEN },
      uPathAmp: { value: PATH_AMP },
      uPathFreq: { value: PATH_FREQ },
      uPathPhase: { value: PATH_PHASE },
    };

    // ── Single mesh: strip body + holes + photos baked together ─
    // High Y-segment count so the helical bend is smooth, not
    // faceted.
    let stripGeom = new THREE.PlaneGeometry(stripW, STRIP_LEN, 1, total * 24);
    const stripMat = new THREE.ShaderMaterial({
      uniforms: sharedUniforms,
      vertexShader: FILM_VERT,
      fragmentShader: FILM_FRAG,
      transparent: true,
      depthWrite: false,
      side: THREE.DoubleSide,
    });
    const strip = new THREE.Mesh(stripGeom, stripMat);
    group.add(strip);

    // Build the composite texture asynchronously. While it loads,
    // the canvas stays hidden (data-canvas-active stays unset)
    // and the static fallback covers the column.
    let stripTex: THREE_NS.CanvasTexture | null = null;
    makeStripTexture(THREE, imgs, FRAME_ASPECT, PHOTO_FRAC_W, PHOTO_ASPECT).then(
      (tex) => {
        stripTex = tex;
        sharedUniforms.uTex.value = tex;
        render();
        requestAnimationFrame(() =>
          requestAnimationFrame(() =>
            setTimeout(() => {
              container.dataset.canvasActive = '1';
            }, 60),
          ),
        );
      },
    );

    // Initial camera framing.
    group.position.set(0, 0, 0);
    group.rotation.set(0, 0, 0);
    render();

    // ── Active-frame mapping ──────────────────────────────────
    // Frame 0 is the TOP of the strip (texture row 0, V≈1).
    // Frame i's center vertex has local Y = +stripLen/2 - (i+0.5)*frameH.
    // For frame i to land at curve param t=0 (camera centre):
    //     uOffset = -(local Y / stripLen) = (i+0.5)/total - 0.5
    function offsetForFrame(i: number) {
      return (i + 0.5) / total - 0.5;
    }

    // Initial offset → frame 0 centred.
    sharedUniforms.uOffset.value = offsetForFrame(0);
    render();

    // Resize: re-compute layout, rebuild the strip geometry to the
    // new size, update the helix radius. The texture aspect is
    // geometric (constant), so we don't need to rebake.
    const resizeObs = new ResizeObserver(() => {
      const next = sizeOf(container);
      if (next.w === w && next.h === h) return;
      w = next.w; h = next.h;
      ({ stripW, photoW, photoH, frameH } = computeLayout(w, h));
      void photoW; void photoH;
      renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
      renderer.setSize(w, h, false);
      const newDist = h / (2 * Math.tan((fov * Math.PI) / 360));
      camera.aspect = w / h;
      camera.position.z = newDist;
      camera.far = newDist * 4;
      camera.updateProjectionMatrix();

      const newStripLen = frameH * total;
      strip.geometry.dispose();
      strip.geometry = new THREE.PlaneGeometry(stripW, newStripLen, 1, total * 24);
      PATH_AMP = stripW * 0.18;
      PATH_FREQ = (Math.PI * 2 * 2.0) / newStripLen;
      sharedUniforms.uStripLen.value = newStripLen;
      sharedUniforms.uPathAmp.value = PATH_AMP;
      sharedUniforms.uPathFreq.value = PATH_FREQ;
      render();
    });
    resizeObs.observe(container);

    let currentActiveIdx = 0;
    let currentTween: gsap.core.Tween | null = null;
    let rafId = 0;

    // RAF loop runs only while a tween is active — the path itself
    // is fixed (no time-based uniform), so at rest one render is
    // enough.
    function startRaf() {
      cancelAnimationFrame(rafId);
      const tick = () => {
        render();
        if (currentTween) rafId = requestAnimationFrame(tick);
      };
      rafId = requestAnimationFrame(tick);
    }

    function setActive(i: number) {
      currentActiveIdx = i;
      if (currentTween) currentTween.kill();
      const targetOffset = offsetForFrame(i);

      // Paint the current state once before the tween starts so
      // there's no blank/stale first frame.
      render();

      currentTween = gsap.to(sharedUniforms.uOffset, {
        value: targetOffset,
        duration: 1.0,
        ease: 'power3.inOut',
        onComplete: () => {
          render();
          currentTween = null;
          cancelAnimationFrame(rafId);
        },
      });
      startRaf();
    }

    let activeChangeCb: ((i: number) => void) | null = null;
    function onActiveChange(cb: (i: number) => void) {
      activeChangeCb = cb;
    }

    // ── Drag-to-scrub ─────────────────────────────────────────
    // Vertical pointer drag on the film container scrubs uOffset
    // directly; on release we snap to the nearest frame with a
    // short tween. While dragging, every time the nearest frame
    // changes we notify the outer DOM so name/desc/ruler track
    // the strip in real time.
    const minOffset = offsetForFrame(0);
    const maxOffset = offsetForFrame(total - 1);
    const offsetSpan = maxOffset - minOffset;

    function offsetToIdx(o: number) {
      const t = (o - minOffset) / offsetSpan; // 0..1
      const idx = Math.round(t * (total - 1));
      return Math.max(0, Math.min(total - 1, idx));
    }

    let dragging = false;
    let dragPointerId: number | null = null;
    let dragStartY = 0;
    let dragStartOffset = 0;
    // px of vertical drag required to walk through the entire
    // strip — keep it generous so each frame is precise.
    const DRAG_FULL_PX = 1200;

    function onPointerDown(e: PointerEvent) {
      if (e.pointerType === 'mouse' && e.button !== 0) return;
      dragging = true;
      dragPointerId = e.pointerId;
      dragStartY = e.clientY;
      dragStartOffset = sharedUniforms.uOffset.value;
      if (currentTween) {
        currentTween.kill();
        currentTween = null;
      }
      try { canvas.setPointerCapture(e.pointerId); } catch {}
      canvas.style.cursor = 'grabbing';
      e.preventDefault();
      // Keep RAF ticking for the duration of the drag — set a
      // sentinel tween so startRaf doesn't bail.
      startRaf();
      currentTween = { kill() {}, progress() { return 0; } } as unknown as gsap.core.Tween;
    }
    function onPointerMove(e: PointerEvent) {
      if (!dragging || e.pointerId !== dragPointerId) return;
      const dy = e.clientY - dragStartY;
      // Drag DOWN moves the film toward later frames (offset
      // increases). Drag UP toward earlier frames.
      let next = dragStartOffset + (dy / DRAG_FULL_PX) * offsetSpan;
      if (next < minOffset) next = minOffset + (next - minOffset) * 0.25;
      if (next > maxOffset) next = maxOffset + (next - maxOffset) * 0.25;
      sharedUniforms.uOffset.value = next;
      const idx = offsetToIdx(Math.max(minOffset, Math.min(maxOffset, next)));
      if (idx !== currentActiveIdx) {
        currentActiveIdx = idx;
        activeChangeCb?.(idx);
      }
    }
    function onPointerUp(e: PointerEvent) {
      if (!dragging || e.pointerId !== dragPointerId) return;
      dragging = false;
      dragPointerId = null;
      try { canvas.releasePointerCapture(e.pointerId); } catch {}
      canvas.style.cursor = '';
      // Snap to the nearest frame.
      const cur = sharedUniforms.uOffset.value;
      const idx = offsetToIdx(Math.max(minOffset, Math.min(maxOffset, cur)));
      const target = offsetForFrame(idx);
      currentTween = gsap.to(sharedUniforms.uOffset, {
        value: target,
        duration: 0.45,
        ease: 'power3.out',
        onComplete: () => {
          render();
          currentTween = null;
          cancelAnimationFrame(rafId);
        },
      });
      currentActiveIdx = idx;
      activeChangeCb?.(idx);
      startRaf();
    }

    canvas.style.touchAction = 'none';
    canvas.style.cursor = 'grab';
    canvas.addEventListener('pointerdown', onPointerDown);
    window.addEventListener('pointermove', onPointerMove);
    window.addEventListener('pointerup', onPointerUp);
    window.addEventListener('pointercancel', onPointerUp);

    function destroy() {
      if (currentTween) currentTween.kill();
      cancelAnimationFrame(rafId);
      resizeObs.disconnect();
      canvas.removeEventListener('pointerdown', onPointerDown);
      window.removeEventListener('pointermove', onPointerMove);
      window.removeEventListener('pointerup', onPointerUp);
      window.removeEventListener('pointercancel', onPointerUp);
      group.traverse((c) => {
        const m = c as THREE_NS.Mesh;
        m.geometry?.dispose?.();
        const mat = m.material as THREE_NS.Material | undefined;
        if (mat) {
          if ('uniforms' in mat) {
            const u = (mat as THREE_NS.ShaderMaterial).uniforms;
            const tex = u?.uTex?.value as THREE_NS.Texture | undefined;
            tex?.dispose?.();
          }
          mat.dispose?.();
        }
      });
      stripTex?.dispose();
      renderer.dispose();
      delete container.dataset.canvasActive;
    }

    return { setActive, onActiveChange, destroy };
  }

  function sizeOf(el: HTMLElement) {
    const r = el.getBoundingClientRect();
    return { w: Math.max(1, Math.round(r.width)), h: Math.max(1, Math.round(r.height)) };
  }

  function init() {
    const browser = document.querySelector<HTMLElement>('[data-adv-browser]');
    if (!browser) return;

    const prevBtn = browser.querySelector<HTMLButtonElement>('[data-adv-prev]');
    const nextBtn = browser.querySelector<HTMLButtonElement>('[data-adv-next]');

    const slots: Record<Slot, HTMLElement[]> = {
      name: Array.from(browser.querySelectorAll<HTMLElement>('[data-adv-slot="name"]')),
      desc: Array.from(browser.querySelectorAll<HTMLElement>('[data-adv-slot="desc"]')),
      photo: Array.from(browser.querySelectorAll<HTMLElement>('[data-adv-slot="photo"]')),
    };

    const ticks = Array.from(browser.querySelectorAll<HTMLElement>('.adv__tick'));

    const total = slots.name.length;
    if (total === 0) return;

    let active = 0;

    function applyDom(next: number) {
      (Object.keys(slots) as Slot[]).forEach((kind) => {
        slots[kind].forEach((el, idx) => {
          if (idx === next) el.dataset.active = 'true';
          else delete el.dataset.active;
        });
      });
      const activeTickIdx = next * TICK_SUBDIVISIONS;
      ticks.forEach((tick) => {
        const ti = parseInt(tick.dataset.advTick || '0', 10);
        tick.dataset.state = ti <= activeTickIdx ? 'past' : 'future';
        if (ti === activeTickIdx) tick.dataset.active = 'true';
        else delete tick.dataset.active;
      });
      active = next;
    }

    function show(i: number) {
      const next = ((i % total) + total) % total;
      if (next === active) return;
      applyDom(next);
      // Tween the film reel to the active frame. Falls through
      // gracefully if the canvas hasn't been initialised yet
      // (still loading three or fired pre-idle).
      activeFilm?.setActive(next);
    }

    if (prevBtn) prevBtn.onclick = () => show(active - 1);
    if (nextBtn) nextBtn.onclick = () => show(active + 1);

    // Keyboard ←/→ when the browser panel is in viewport. Skips
    // when the user is typing in an input so we don't hijack form
    // navigation elsewhere on the page.
    function onKey(e: KeyboardEvent) {
      const tag = (e.target as HTMLElement)?.tagName;
      if (tag === 'INPUT' || tag === 'TEXTAREA' || (e.target as HTMLElement)?.isContentEditable) return;
      const rect = browser!.getBoundingClientRect();
      const inView = rect.bottom > 0 && rect.top < window.innerHeight;
      if (!inView) return;
      if (e.key === 'ArrowLeft') show(active - 1);
      else if (e.key === 'ArrowRight') show(active + 1);
    }
    window.addEventListener('keydown', onKey);

    // ── Film-reel: gated init + cleanup ─────────────────────
    // Tear down a previously-initialised reel before booting a
    // fresh one (Astro view transitions / re-init paths).
    if (activeFilm) {
      activeFilm.destroy();
      activeFilm = null;
    }

    const filmContainer = browser.querySelector<HTMLElement>('[data-adv-film]');
    if (filmContainer) {
      type IdleCb = (cb: () => void, opts?: { timeout?: number }) => number;
      const ric: IdleCb =
        (window as unknown as { requestIdleCallback?: IdleCb }).requestIdleCallback ??
        ((cb) => window.setTimeout(cb, 1) as unknown as number);

      const startFilm = () => {
        ric(async () => {
          const film = await initFilm(filmContainer);
          if (film) {
            activeFilm = film;
            // Sync to whatever activity is currently active in
            // case the user already advanced before init landed.
            activeFilm.setActive(active);
            // Drag-scrub on the film: when the user drags the
            // strip the controller emits the new frame index for
            // each frame the drag crosses; we update the DOM in
            // sync without re-tweening the strip itself.
            activeFilm.onActiveChange((idx) => {
              if (idx !== active) applyDom(idx);
            });
          }
        }, { timeout: 2000 });
      };

      const obs = new IntersectionObserver(
        (entries) => {
          if (entries[0].isIntersecting) {
            obs.disconnect();
            startFilm();
          }
        },
        { rootMargin: '100% 0px' },
      );
      obs.observe(filmContainer);
    }
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init, { once: true });
  } else {
    init();
  }
  document.addEventListener('astro:page-load', init);

  /**
   * Mobile polaroid flip — toggle each `[data-ap-card]` between
   * photo-dominant (closed) and description-dominant (open) by
   * flipping its `aria-expanded`. The CSS animates the
   * `grid-template-rows` between `1fr auto 0fr` and `0fr auto 1fr`,
   * so the photo collapses and the body fills the freed space.
   * Tap anywhere on the card to flip; tapping again restores.
   */
  function initPolaroidFlip() {
    const cards = document.querySelectorAll<HTMLButtonElement>(
      '[data-ap-card]',
    );
    cards.forEach((card) => {
      card.addEventListener('click', () => {
        const open = card.getAttribute('aria-expanded') === 'true';
        card.setAttribute('aria-expanded', open ? 'false' : 'true');
      });
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initPolaroidFlip, { once: true });
  } else {
    initPolaroidFlip();
  }
  document.addEventListener('astro:page-load', initPolaroidFlip);
</script>
