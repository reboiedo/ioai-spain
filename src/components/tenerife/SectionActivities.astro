---
/**
 * ActivitiesSection — the "ACTIVITIES" scene.
 *
 * Layout: split column.
 *   LEFT (sticky): SectionTitle on top, image below. The image is
 *     swapped as the user scrolls past the right-hand list — the
 *     activity row currently centered in the viewport drives which
 *     image is shown.
 *   RIGHT: vertical list of activity rows, separated by horizontal
 *     borders. Each row: day number, title, description.
 *
 * Content sourced from the Tenerife Content Notion page's
 * activities database (15 days). Move to a content collection when
 * copy goes bilingual.
 */

import { Image, type ImageMetadata } from "astro:assets";
import SectionTitle from "@/components/tenerife/SectionTitle.astro";
import HScrollMobile from "@/components/tenerife/HScrollMobile.astro";

// Eager-glob every activity photo. Files use a `01-…`, `02-…` prefix
// so the alphabetical sort lines up with the activity day index —
// activity[i] pairs with the i-th file. Drop in additional days by
// adding a new file with the next prefix.
const photoModules = import.meta.glob<{ default: ImageMetadata }>(
  "@/assets/tenerife/activities/*.{jpg,jpeg,png,webp,avif}",
  { eager: true },
);
const photos: ImageMetadata[] = Object.entries(photoModules)
  .sort(([a], [b]) => a.localeCompare(b))
  .map(([, mod]) => mod.default);

export interface Props {
  /** Tenerife theme palette to apply via `data-theme`. */
  theme?: "orange" | "blue" | "yellow" | "neutral";
}

const { theme = "blue" } = Astro.props;

interface Activity {
  day: number;
  title: string;
  description: string;
}

const activities: Activity[] = [
  {
    day: 1,
    title: "Welcome & getting to know each other",
    description:
      "The camp kicks off with a walk along the seafront of Puerto de la Cruz, finishing at the historic Plaza del Charco. Along the way, campers take part in a simple but effective icebreaker — sharing their name, something they love, and their plans for the future. By the end of the evening, the group already feels like a group.",
  },
  {
    day: 2,
    title: "Historic Puerto de la Cruz",
    description:
      "Campers explore the old town on a guided cultural walk that brings local history to life. Highlights include the 17th-century Church of Nuestra Señora de la Peña de Francia, the town's historic fishing pier — once used to export Malvasia wine — Playa Jardín designed by celebrated Canarian artist César Manrique, and the Castle of San Felipe, a coastal fortress built to defend against pirates. The walk ends back at the iconic Lago Martiánez pool complex.",
  },
  {
    day: 3,
    title: "Beach sports",
    description:
      "A full afternoon at Playa Jardín with volleyball, football, tennis and frisbee. Campers rotate through activities in small groups, keeping it social, competitive and fun.",
  },
  {
    day: 4,
    title: "Yoga workshop & beach",
    description:
      "A more mindful afternoon. While some campers enjoy the beach, others take part in a yoga workshop designed to balance the physical intensity of the week with self-care and reflection. Every camper gets their session.",
  },
  {
    day: 5,
    title: "Rambla de Castro coastal trail",
    description:
      "A scenic coastal hike through one of Tenerife's most beautiful natural routes. The group passes black-sand coves, a historic 1903 steam-engine pumping station, a wooden bridge over a ravine, an 18th-century coastal fort, and arrives at Mirador de San Pedro — a clifftop viewpoint with sweeping ocean views.",
  },
  {
    day: 6,
    title: "Traditional Canarian games",
    description:
      "Back at Playa Jardín for an afternoon of traditional games from the Canary Islands: crab races, tug-of-war and the handkerchief game. Loud, fun, and a genuine window into local culture.",
  },
  {
    day: 7,
    title: "Zip-line park at Forestal Park",
    description:
      "A special day at Forestal Park Tenerife, a high-altitude adventure park in the forests of Monte de La Esperanza. Before heading in, the group takes part in a short session on emotions — naming them, noticing them, and letting go of the negative ones through a dreamcatcher activity afterward. Lunch is a picnic in the forest.",
  },
  {
    day: 8,
    title: "Teide National Park & Observatory",
    description:
      "A full-day excursion to the top of Tenerife. One group visits the Teide Observatory, home to leading European solar telescopes. The other explores the El Portillo Visitor Centre, with exhibitions on volcanic geology, a botanical garden of native species and a simulated volcanic tube. Both groups then meet at Roques de García for lunch and a breathing and nature connection activity, surrounded by one of the most dramatic landscapes in Europe.",
  },
  {
    day: 9,
    title: "La Orotava cultural walk",
    description:
      "A guided tour through the beautifully preserved historic town of La Orotava. Campers visit a neo-Gothic chapel, a 19th-century French garden with panoramic views, the iconic Casa de los Balcones with its carved wooden architecture, and a traditional gofio mill — a staple of Canarian food culture.",
  },
  {
    day: 10,
    title: "Surfing at Playa Martiánez",
    description:
      "Just five minutes from the hotel, campers try surfing for the first time (or build on what they know) in small groups with professional instructors. While half surf, the other half enjoy the beach or the hotel pool.",
  },
  {
    day: 11,
    title: "Painting workshop & beach",
    description:
      "An afternoon combining creativity with sunshine. Campers take a guided painting workshop on the beach, turning their impressions of the trip into their own artwork. A quieter, more reflective counterpoint to the more active days.",
  },
  {
    day: 12,
    title: "Surfing, round two",
    description:
      "Another session in the water, with extended surf classes for all participants. More time in the sea, more time to progress.",
  },
  {
    day: 13,
    title: "Farewell beach games",
    description:
      "The last beach afternoon: handball, beach paddles, gymkhana obstacle courses and relay races. Before leaving, the whole group gathers in a circle to share their favourite memory of Tenerife.",
  },
  {
    day: 14,
    title: "Loro Parque",
    description:
      "The final special-day excursion takes campers to Loro Parque, one of Europe's most celebrated wildlife parks. The visit is designed not just as a fun day out, but as a meaningful encounter with animal welfare and biodiversity conservation — themes that connect to the broader values of the camp.",
  },
  {
    day: 15,
    title: "Farewell & the jar of messages",
    description:
      "The last day brings the group together for a final activity: the jar of messages. Each camper writes a note — a reflection, an encouragement, a memory — folds it up and adds it to a shared jar. It's a simple, powerful way to close two weeks of shared experience. The day ends with a collective farewell discussion and the kind of goodbyes that usually involve promises to stay in touch.",
  },
];
---

<div class="scene" data-scene>
  <section
    class="section split scene__layer scene__layer--tilt activities"
    data-theme={theme}
  >
    <!-- DESKTOP layout (≥768px): sticky polaroid stack + scrollable
         row list. Hidden on mobile via the `.activities__desktop`
         rule in the <style> block below. -->
    <div class="activities__desktop">
    <!-- LEFT (50%): sticky pane — same pattern as SectionTeam. -->
    <div class="activities__left">
      <SectionTitle lines={["ACTIVITIES"]} />

      <p class="font-body-l activities__intro">
        Outside of study hours, campers have a full schedule of
        activities across Tenerife — beaches, national parks,
        historic towns, and cultural workshops. Two weeks of
        afternoons and evenings, planned but never crammed.
        Here's the day-by-day.
      </p>
    </div>

    <!-- Vertical centreline divider. -->
    <div class="activities__divider" aria-hidden="true"></div>

    <!-- RIGHT (50%): vertical stream of polaroid cards. Same
         click-to-expand polaroid pattern as the mobile column —
         photo collapses, head rides up, description fades in.
         For now they scroll naturally; the eventual goal is to
         pin them so each card stacks over the previous on
         scroll. -->
    <ol class="activities__stream">
      {activities.map((a, i) => (
        <li class="activity-row" data-activity-index={String(i)}>
          <button
            type="button"
            class="ap-card"
            aria-expanded="false"
            data-ap-card
            aria-label={`Day ${a.day}: ${a.title} — tap to read description`}
          >
            <div class="ap-card__photo">
              {photos[i] && (
                <Image
                  class="ap-card__img"
                  src={photos[i]}
                  alt={a.title}
                  widths={[320, 480, 640]}
                  sizes="(min-width: 768px) 40vw, 70vw"
                  loading="lazy"
                />
              )}
            </div>
            <div class="ap-card__head">
              <p class="font-caption ap-card__day">Day {a.day}</p>
              <h3 class="font-caption-script ap-card__title">{a.title}</h3>
            </div>
            <div class="ap-card__body">
              <p class="font-body-s ap-card__description">{a.description}</p>
            </div>
            <span class="ap-card__cue" aria-hidden="true"></span>
          </button>
        </li>
      ))}
    </ol>
    </div>

    <!-- MOBILE layout (<768px): title + intro stack vertically
         (no sticky), followed by a horizontal-scroll of flippable
         polaroids. Click a card to flip it and reveal the
         description on the back. Hidden on desktop. -->
    <div class="activities__mobile">
      <SectionTitle lines={["ACTIVITIES"]} />
      <p class="font-body-l activities__mobile-intro">
        Outside of study hours, campers have a full schedule of
        activities across Tenerife — beaches, national parks,
        historic towns, and cultural workshops. Tap a polaroid to
        read what's on for that day.
      </p>

      <HScrollMobile itemWidth="min(80%, 320px)">
        {activities.map((a, i) => (
          <button
            type="button"
            class="ap-card"
            aria-expanded="false"
            data-ap-card
            aria-label={`Day ${a.day}: ${a.title} — tap to read description`}
          >
            <!-- Photo. Visible by default; collapses on open. -->
            <div class="ap-card__photo">
              {photos[i] && (
                <Image
                  class="ap-card__img"
                  src={photos[i]}
                  alt={a.title}
                  widths={[320, 480, 640]}
                  sizes="80vw"
                  loading="lazy"
                />
              )}
            </div>
            <!-- Head — day + title. Sits at the bottom of the card
                 in the closed state; rides up to the top when the
                 photo collapses on open. -->
            <div class="ap-card__head">
              <p class="font-caption ap-card__day">Day {a.day}</p>
              <h3 class="font-caption-script ap-card__title">{a.title}</h3>
            </div>
            <!-- Body — description. Hidden by default (zero-height
                 row); fades in and fills the freed space on open. -->
            <div class="ap-card__body">
              <p class="font-body-s ap-card__description">{a.description}</p>
            </div>
            <!-- Signifier — small `+` that rotates to `×` when the
                 card is open. Lives in the corner, never moves. -->
            <span class="ap-card__cue" aria-hidden="true"></span>
          </button>
        ))}
      </HScrollMobile>
    </div>
  </section>
</div>

<style>
  .activities {
    align-items: start;
  }

  /* Centreline divider — hidden by default (mobile collapses to
   * single column); revealed at ≥768px as its own grid track. */
  .activities__divider {
    display: none;
  }

  @media (min-width: 768px) {
    /* Half-and-half split with a divider between: 1fr | auto | 1fr. */
    .activities {
      grid-template-columns: minmax(0, 1fr) auto minmax(0, 1fr);
      column-gap: var(--space-xl);
    }

    .activities__divider {
      display: block;
      width: 1px;
      background: var(--border);
      align-self: stretch;
    }
  }

  /* ── Desktop / mobile layout swap ───────────────────────────────
   * The desktop layout uses the section's own `.split` grid (sticky
   * polaroid stack on the left, scrollable list on the right). The
   * mobile layout is a single-column block.
   *
   * `display: contents` makes the wrapper transparent to layout so
   * the section's `.split` grid still sees `.activities__left` and
   * `.activities__column` as its DIRECT children — without it, the
   * split would be looking at one wrapper child and collapse to a
   * single column on desktop.
   *
   * `install()` (the IntersectionObserver) is a no-op when its
   * targets are display: none (no layout box → no intersection
   * events) so it doesn't need a code-side branch. */
  .activities__desktop {
    display: contents;
  }

  .activities__mobile {
    display: none;
  }

  @media (max-width: 767.98px) {
    .activities__desktop {
      display: none;
    }
    .activities__mobile {
      display: grid;
      gap: var(--space-l);
    }
    /* The section's `.split` rule is irrelevant when only one
     * column is rendered — collapse it back to a single column so
     * the mobile block doesn't inherit half-width sizing. */
    .activities {
      display: block;
    }
  }

  .activities__mobile-intro {
    margin: 0;
    max-width: 52ch;
  }

  /* ── Flip polaroid (mobile only) ───────────────────────────────
   * 3D card flip on click. The button is the perspective host; the
   * `__inner` div carries the rotateY transition; each face is
   * absolutely positioned with `backface-visibility: hidden` so the
   * non-active face disappears mid-flip. */
  /* Activities mobile card.
   *
   * Layout is a 3-row grid (photo / head / body). When the card is
   * closed, the body row is collapsed (0fr) so the photo dominates
   * with the day + title strip beneath it. When the card is open,
   * the photo row collapses to 0fr and the body expands to 1fr;
   * the head sits between them and "rides up" naturally as the
   * photo collapses.
   *
   * `grid-template-rows` is animated — supported in Chrome 116+,
   * Firefox 121+, Safari 17.5+. Older browsers will snap between
   * states (acceptable graceful degradation). */
  .ap-card {
    appearance: none;
    background: #f4efe7;
    color: #1a1a1a;
    border: 0;
    padding: var(--space-m);
    margin: 0;
    font: inherit;
    cursor: pointer;
    text-align: left;
    width: 100%;
    aspect-ratio: 4 / 5;
    border-radius: 4px;
    box-shadow: 0 6px 18px rgba(0, 0, 0, 0.16);
    overflow: hidden;
    position: relative;
    display: grid;
    grid-template-rows: 1fr auto 0fr;
    gap: var(--space-s);
    transition: grid-template-rows 0.55s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .ap-card[aria-expanded="true"] {
    grid-template-rows: 0fr auto 1fr;
  }

  .ap-card:focus-visible {
    outline: 2px solid var(--foreground);
    outline-offset: 4px;
  }

  /* Each row is a flex container so its content can shrink to 0
   * height inside a `0fr` track without the intrinsic content
   * width forcing it open. */
  .ap-card__photo,
  .ap-card__head,
  .ap-card__body {
    min-height: 0;
    overflow: hidden;
  }

  .ap-card__photo {
    border-radius: 2px;
    transition: opacity 0.4s ease;
  }
  .ap-card[aria-expanded="true"] .ap-card__photo {
    opacity: 0;
  }

  .ap-card__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* Head — day above title. Stays anchored to the photo's bottom
   * edge in the closed state; rides up to the top when the photo
   * collapses. */
  .ap-card__head {
    display: flex;
    flex-direction: column;
    gap: 0.15em;
  }
  .ap-card__day {
    margin: 0;
    opacity: 0.55;
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    line-height: 1;
  }
  .ap-card__title {
    margin: 0;
    line-height: 1.2;
  }

  /* Body — fades in once the row has space to grow into. */
  .ap-card__body {
    opacity: 0;
    transition: opacity 0.35s ease 0.1s;
  }
  .ap-card[aria-expanded="true"] .ap-card__body {
    opacity: 1;
    overflow-y: auto;
    overscroll-behavior: contain;
  }
  .ap-card__description {
    margin: 0;
    opacity: 0.85;
  }

  /* Signifier — small "+" in the corner that rotates to "×" when
   * the card is open. Same pattern as the FAQ accordion icon. */
  .ap-card__cue {
    position: absolute;
    bottom: var(--space-s);
    right: var(--space-s);
    width: 1.25rem;
    height: 1.25rem;
    pointer-events: none;
    color: rgba(0, 0, 0, 0.55);
    z-index: 1;
  }
  .ap-card__cue::before,
  .ap-card__cue::after {
    content: '';
    position: absolute;
    inset: 50% 0 auto 0;
    height: 1.5px;
    background: currentColor;
    transform-origin: center;
    transition: transform 280ms cubic-bezier(0.22, 1, 0.36, 1);
  }
  .ap-card__cue::after {
    transform: rotate(90deg);
  }
  .ap-card[aria-expanded="true"] .ap-card__cue::before {
    transform: rotate(45deg);
  }
  .ap-card[aria-expanded="true"] .ap-card__cue::after {
    transform: rotate(-45deg);
  }

  /* LEFT column — sticky title + intro. Same pattern as
   * `.team__intro` in SectionTeam. The column itself is what's
   * sticky; the right column's tall photo stream provides the
   * scroll runway. */
  .activities__left {
    position: sticky;
    top: var(--sticky-top);
    align-self: start;
    display: flex;
    flex-direction: column;
    gap: var(--space-l);
    max-height: calc(100lvh - var(--sticky-top));
  }

  .activities__intro {
    margin: 0;
    max-width: 48ch;
  }

  /* Right column — vertical stream of polaroid `.ap-card`s. Cards
   * are full column-width, 4:5 aspect, with comfortable gaps so
   * each polaroid reads as its own moment. The polaroid card style
   * itself is shared with the mobile column (`.ap-card` rules
   * below), so this is just the layout wrapper. */
  .activities__stream {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-l);
    /* Extra runway below the last card so its sticky pin window
     * extends past its natural position — without it, the last
     * polaroid releases as soon as it reaches the centre because
     * the parent's bottom edge is right beneath it. The padding
     * gives every card the same "dwell at centre" time. */
    padding-block-end: max(
      0px,
      calc(50svh - 262.5px - var(--section-block))
    );
  }

  /* Stacking polaroids.
   *
   * Each row is `position: sticky` pinned to the same viewport
   * line — the vertical centre. As the user scrolls, every
   * polaroid scrolls up until its top edge reaches that line,
   * then pins. The next card slides up over it (later DOM order
   * = higher paint order, so the new card naturally sits on top
   * of the pile).
   *
   * The pin position is `50svh - half-card-height`. Worst-case
   * card height is `420 * 5/4 = 525px` so half-height = 262.5px.
   * On narrower columns the pin lands a hair below true centre,
   * which actually reads better — the bottom of the stack peeks
   * a touch above where you'd think it should.
   *
   * The flex `gap` on `.activities__stream` is the scroll runway
   * between pin events — a smaller gap means cards stack faster
   * (less scroll between each landing); a larger gap means more
   * scroll per card. `var(--space-l)` is the current default;
   * we'll tune by feel.
   *
   * `width: min(100%, 420px)` caps each row and the parent's
   * `align-items: center` centres it horizontally. */
  .activities__stream .activity-row {
    position: sticky;
    top: calc(50svh - 262.5px);
    width: min(100%, 420px);
  }

  /* Push the first card down so it lands at the viewport vertical
   * centre when the user scrolls into the section, rather than
   * sitting at the section-content top edge. Without this, the
   * sticky pin point exists but the first card has no scroll
   * runway to "rise" into it — the user sees the stack start
   * above centre and only converge once they've scrolled far
   * enough. The math mirrors the sticky `top` value, minus the
   * section's own block padding (already applied above). */
  .activities__stream .activity-row:first-child {
    margin-block-start: max(
      0px,
      calc(50svh - 262.5px - var(--section-block) - var(--nav-height))
    );
  }

  /* Subtle polaroid-pile feel: each card sits at a tiny rotation,
   * alternating left/right by index. The natural DOM stacking
   * order means the topmost (most recently pinned) card paints
   * over the rest, so you see the pile's edges fanning out
   * underneath.
   *
   * Kept small (±1.5°) so text stays readable; bump if you want
   * a more chaotic feel. */
  /* GSAP owns the polaroid rotation (per-card alternating tilt).
   * `will-change` hints the compositor; cursor is the default
   * pointer since hover toggles the drawer rather than grabbing. */
  .activities__stream .ap-card {
    will-change: transform;
  }

  /* Polaroid stack frame.
   *
   * Sized by whichever constraint hits first:
   *   - 800px   — visual cap on very wide viewports
   *   - 100%    — column width (sticky left column on desktop)
   *   - available column height × 4/5 — so the polaroid never
   *     overflows the sticky column on short viewports (16" laptop,
   *     landscape iPad, etc).
   *
   * `--activities-title-h` is a rough reservation for the
   * SectionTitle above the stack — display-l line height + gap.
   * Tuning by feel; doesn't need to be exact since the `min()`
   * picks the smallest of three guesses anyway. */
  .activities__stack {
    --activities-title-h: 8rem;
    position: relative;
    width: min(
      800px,
      100%,
      calc(
        (100svh - var(--sticky-top) - var(--activities-title-h) - var(--space-2xl))
          * 4 / 5
      )
    );
    aspect-ratio: 4 / 5;
    margin-inline: auto;
  }

  /* Inner wrapper holds the polaroids and the mouse CSS vars. The
   * vars (--mouse-dx / --mouse-dy) cascade down to each polaroid,
   * which uses them in its transform multiplied by its own
   * `--polaroid-mouse-mult`. Defaults to 0 so SSR / no-JS shows a
   * flat stack. */
  .activities__stack-inner {
    position: absolute;
    inset: 0;
    --mouse-dx: 0px;
    --mouse-dy: 0px;
  }

  @media (prefers-reduced-motion: reduce) {
    .activities__stack-inner {
      --mouse-dx: 0px !important;
      --mouse-dy: 0px !important;
    }
  }

  /* Each polaroid is absolutely positioned, all inside the stack
   * box. Rotation, offset and z-index come from inline custom
   * properties set in the template (deterministic per index, so
   * the pile looks random but stays stable across renders). */
  .polaroid {
    position: absolute;
    inset: 0;
    margin: auto;
    width: 78%;
    /* Polaroid card aspect: image area is square, plus a thicker
     * bottom strip for the caption. Roughly 4 : 5 overall. */
    aspect-ratio: 4 / 5;
    background: #f4efe7;
    color: #1a1a1a;
    /* Even inline padding top/left/right; the bottom strip is
     * sized by the grid row below so the caption has room to
     * actually centre inside the white area. */
    padding: 6% 6% 0;
    border-radius: 2px;
    /* Soft single-layer drop. Light enough that a stack of 15
     * doesn't read as muddy, dark enough to lift each card off
     * the theme background. */
    box-shadow: 0 6px 18px rgba(0, 0, 0, 0.16);
    /* Two rows: the photo area sized by its own square aspect
     * ratio, then a fixed-proportion white strip for the caption.
     * `18%` of the card height gives the classic polaroid feel —
     * a meaningful white band, not a thin sliver. */
    display: grid;
    grid-template-rows: 1fr 18%;
    z-index: var(--polaroid-z, 0);
    /* Hidden + slightly down/scaled by default; snaps into the
     * pile when `[data-active]` is set. Snappy back-out easing so
     * each card lands with a tiny overshoot — feels like it's
     * being tossed onto the table. */
    opacity: 0;
    transform:
      translate(0%, -4%)
      rotate(0deg)
      scale(0.92);
    transition:
      opacity 180ms ease-out,
      transform 320ms cubic-bezier(0.34, 1.4, 0.64, 1);
    pointer-events: none;
  }

  .polaroid[data-active="true"] {
    opacity: 1;
    /* Single centred polaroid — no pile. Per-card offsets +
     * mouse-shift removed so each active polaroid lands in the
     * exact same spot, and the swap reads as a clean crossfade. */
    transform: translate(0, 0) rotate(0deg) scale(1);
  }

  /* Photo area — square instant-photo crop. The placeholder gradient
   * shows through when no `<Image>` is present (graceful fallback for
   * any future activity that hasn't been photographed yet). */
  .polaroid__photo {
    position: relative;
    aspect-ratio: 1 / 1;
    background:
      linear-gradient(
        135deg,
        color-mix(in oklab, var(--accent, #999) 70%, white) 0%,
        color-mix(in oklab, var(--accent, #999) 90%, black) 100%
      );
    display: grid;
    place-items: center;
    overflow: hidden;
  }

  /* Real photo fills the square; the day badge stays on top of it. */
  .polaroid__img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
  }

  /* Bump the day badge above the photo and give it a soft scrim so
   * it stays readable against any image colour. */
  .polaroid__day {
    position: relative;
    z-index: 1;
    padding: 0.25em 0.6em;
    background: rgba(0, 0, 0, 0.35);
    border-radius: 999px;
    backdrop-filter: blur(2px);
  }

  /* Typography comes from `.font-caption-script` on both the day
   * badge and the caption strip — that utility wires Rock Salt via
   * `--font-script`. These rules only carry per-element tweaks
   * (color, sizing to fit the polaroid, centering). */
  .polaroid__day {
    color: rgba(255, 255, 255, 0.9);
    /* Scale down from the token default so it fits the photo area
     * at small polaroid widths. */
    font-size: clamp(1rem, 1.6vw, 1.5rem);
  }

  .polaroid__caption {
    margin: 0;
    /* Fill the white strip and centre the caption both ways. */
    display: grid;
    place-items: center;
    text-align: center;
    padding-inline: 6%;
    font-size: clamp(0.8rem, 1vw, 1rem);
    /* Rock Salt is tall — default caption-script `leading-none`
     * leaves no room between wrapped lines. Nudge it up a bit. */
    line-height: 1.25;
  }

  @media (prefers-reduced-motion: reduce) {
    .polaroid {
      transition: opacity 200ms ease;
      transform:
        translate(var(--polaroid-x, 0%), var(--polaroid-y, 0%))
        rotate(var(--polaroid-rotate, 0deg));
    }
  }

  /* List-item reset — `.activity-row` is the `<li>` that wraps each
   * polaroid in the desktop stream. */
  .activity-row {
    list-style: none;
    margin: 0;
    padding: 0;
    border: 0;
  }

</style>

<script>
  /**
   * Activity polaroid card click toggle. Used on both the desktop
   * stream and the mobile horizontal scroll. Delegated from
   * document so we don't need per-card listeners and the handler
   * survives Astro view transitions. Toggling `aria-expanded` is
   * enough — the CSS morphs the grid template via
   * `[aria-expanded="true"]`.
   */
  function installApCard() {
    if ((window as any).__apCardHooked) return;
    (window as any).__apCardHooked = true;
    document.addEventListener('click', (e) => {
      const card = (e.target as HTMLElement | null)?.closest<HTMLButtonElement>(
        '[data-ap-card]',
      );
      if (!card) return;
      const open = card.getAttribute('aria-expanded') === 'true';
      card.setAttribute('aria-expanded', String(!open));
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', installApCard, { once: true });
  } else {
    installApCard();
  }
  document.addEventListener('astro:page-load', () => {
    (window as any).__apCardHooked = false;
    installApCard();
  });

  /**
   * Polaroid stack — alternating tilt + ease-in landing.
   *
   * Each row pins to the viewport vertical centre via CSS sticky.
   * GSAP layers two things on top:
   *
   *   1. Deterministic ±1.5° tilt per card so the pile fans out a
   *      touch as new cards land on top.
   *   2. Scroll-scrubbed Y offset that decelerates as the card
   *      approaches its pin point — `power3.out` easing on the
   *      tween + 0.6s scrub smoothing. Gives the impression of a
   *      polaroid drifting down and settling onto the pile rather
   *      than snapping into position the moment sticky engages.
   *
   * The Y translate doesn't fight sticky positioning — translate
   * is a transform; sticky is still based on the layout box top.
   * They compose, with the visible card painted at translate(y)
   * relative to its sticky-anchored box.
   */
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  let stackTriggers: ScrollTrigger[] = [];

  function teardownStack() {
    stackTriggers.forEach((t) => t.kill());
    stackTriggers = [];
  }

  // Per-card physics variation. Every card draws from these
  // tables by index — deterministic so layout stays stable across
  // renders, but each card lands with a slightly different feel,
  // breaking the "sausage" effect of every polaroid moving in
  // lockstep with its neighbours.
  const DROP_DISTANCES = [55, 90, 40, 75, 50, 95, 60, 80];
  const ROTATE_DELTAS = [4, -3.5, 5, -2.5, 3, -5, 2.5, -4];
  const EASES = [
    'power3.out',
    'power2.out',
    'back.out(1.3)',
    'power4.out',
    'expo.out',
    'circ.out',
  ];
  const SCRUBS = [0.45, 0.7, 0.55, 0.8, 0.5, 0.65];

  function installStack() {
    teardownStack();
    const rows = gsap.utils.toArray<HTMLElement>(
      '.activities__stream .activity-row',
    );
    rows.forEach((row, i) => {
      const card = row.querySelector<HTMLElement>('.ap-card');
      if (!card) return;

      const baseRotation = i % 2 === 0 ? -1.5 : 1.5;
      const drop = DROP_DISTANCES[i % DROP_DISTANCES.length];
      const rotateDelta = ROTATE_DELTAS[i % ROTATE_DELTAS.length];
      const ease = EASES[i % EASES.length];
      const scrub = SCRUBS[i % SCRUBS.length];

      gsap.set(card, { transformOrigin: 'center center' });

      // Each card settles from `drop` px below + a few degrees off
      // its final tilt, easing into the resting pose. Different
      // ease curves (some smooth, some with a slight overshoot via
      // `back.out`) plus varied scrub smoothing make every card
      // feel like its own physical object — drifting at its own
      // rate, snapping into the pile at its own time.
      const tween = gsap.fromTo(
        card,
        {
          y: drop,
          rotate: baseRotation + rotateDelta,
        },
        {
          y: 0,
          rotate: baseRotation,
          ease,
          scrollTrigger: {
            trigger: row,
            start: 'top bottom',
            end: () => `top ${window.innerHeight * 0.5 - 262.5}px`,
            scrub,
            invalidateOnRefresh: true,
          },
        },
      );
      if (tween.scrollTrigger) stackTriggers.push(tween.scrollTrigger);
    });

    ScrollTrigger.refresh();
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', installStack, { once: true });
  } else {
    installStack();
  }
  document.addEventListener('astro:page-load', installStack);
  document.addEventListener('astro:before-swap', teardownStack);
</script>
