---
/**
 * TracksSection — the "TRACKS" scene.
 *
 * Layout: split with sticky title + intro on the left, two stacked
 * dark cards on the right. Each card (Beginner / Advanced) contains
 * a title, a short description, and an expandable list of Course
 * drawers — click a course name to reveal its description and
 * outcomes.
 *
 * Content sourced from the Tenerife Content Notion page's tracks
 * database. Hardcoded here for now; move to a content collection
 * when copy goes bilingual.
 */

import SectionTitle from "@/components/tenerife/SectionTitle.astro";
import Course from "@/components/tenerife/Course.astro";
import TrackList from "@/components/tenerife/TrackList.astro";
import { useTenerifeTranslations, type Language } from "@/i18n/tenerife";

export interface Props {
  /** Locale for this render. */
  locale: Language;
  /** Tenerife theme palette to apply via `data-theme`. */
  theme?: "orange" | "blue" | "yellow" | "neutral";
}

const { locale, theme = "blue" } = Astro.props;
const t = useTenerifeTranslations(locale);
---

<div class="scene" data-scene data-flow data-scene-index="3">
  <section
    class="section scene__layer scene__layer--tilt tracks"
    data-theme={theme}
  >
    <div class="split tracks__grid">
      <!-- Left: title + paragraph in a single sticky block at the
           top of the column. Natural flow (title above paragraph),
           no 100svh, no bottom pinning. Column height is driven by
           the right-hand card stack. -->
      <div class="tracks__intro">
        <SectionTitle lines={[t.tracks.title]} eyebrow={t.tracks.eyebrow} />
        <p class="font-body section-copy tracks__intro-copy">{t.tracks.copy}</p>
      </div>

      <!-- Right: two stacked dark cards, each a list of course drawers -->
      <div class="tracks__lists">
        <TrackList
          title={t.tracks.beginner.title}
          description={t.tracks.beginner.description}
        >
          {t.tracks.beginner.items.map((item) => (
            <Course name={item.name} description={item.description} outcomes={item.outcomes} />
          ))}
        </TrackList>

        <TrackList
          title={t.tracks.advanced.title}
          description={t.tracks.advanced.description}
        >
          {t.tracks.advanced.items.map((item) => (
            <Course name={item.name} description={item.description} outcomes={item.outcomes} />
          ))}
        </TrackList>

        <!-- Parent-facing fit-check card. Short and reassuring
             — sits at the bottom of the right column after both
             track lists. -->
        <article class="tracks__fit">
          <h3 class="font-h3 tracks__fit-title">{t.tracks.fit.title}</h3>
          <p class="font-body tracks__fit-lede">{t.tracks.fit.lede}</p>
          <ul class="tracks__fit-list">
            {t.tracks.fit.items.map((item) => (
              <li class="tracks__fit-item">
                <span class="tracks__fit-bullet" aria-hidden="true">→</span>
                <span class="font-body">{item.text}</span>
              </li>
            ))}
          </ul>
        </article>
      </div>
    </div>
  </section>
</div>

<style>
  /* Left column — a tight stack of title + paragraph. Sticks to
   * the nav offset on ≥768px so both stay visible while the
   * right-hand card stack scrolls past. */
  .tracks__intro {
    display: flex;
    flex-direction: column;
    gap: var(--space-l);
  }

  .tracks__intro-copy {
    margin: 0;
  }

  @media (min-width: 768px) {
    .tracks__intro {
      position: sticky;
      top: var(--sticky-top);
      align-self: start;
    }
  }

  /* Right column — two dark cards stacked vertically. Larger gap
   * than the inner card padding so the cards read as distinct
   * objects rather than a single long panel. The scene-stack pin
   * adapts to height changes via the ResizeObserver in
   * `initSceneStack` (see `src/pages/tenerife-camp.astro`), so
   * opening a course drawer just lets the section grow and the pin
   * re-anchors at the new bottom — no reserve padding required. */
  .tracks__lists {
    display: grid;
    gap: var(--space-2xl);
    max-width: 680px;
  }

  /* Parent-facing fit-check card. Themed surface (`--surface`
   * resolves to the section's brand tint per `data-theme` —
   * orange-300 / blue-500 / yellow-300) so the card reads as
   * a softer, on-brand anchor at the bottom of the column,
   * distinct from the dark `TrackList` cards above. */
  .tracks__fit {
    background: var(--surface);
    color: var(--foreground);
    border-radius: 8px;
    padding: clamp(var(--space-l), 4vw, var(--space-xl));
    display: flex;
    flex-direction: column;
    gap: var(--space-l);
  }

  .tracks__fit-title {
    margin: 0;
    text-wrap: balance;
    line-height: 1.1;
  }

  .tracks__fit-lede {
    margin: 0;
    max-width: 56ch;
    opacity: 0.85;
  }

  .tracks__fit-label {
    margin: 0;
    margin-block-start: var(--space-s);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    opacity: 0.6;
  }

  .tracks__fit-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-s);
  }

  /* Arrow + text grid — multi-line items wrap with their text
   * indented past the arrow rather than under it. */
  .tracks__fit-item {
    display: grid;
    grid-template-columns: 1.25rem 1fr;
    column-gap: var(--space-s);
    align-items: baseline;
  }

  .tracks__fit-bullet {
    font-weight: 600;
    opacity: 0.6;
  }

  .tracks__fit-footer {
    margin: 0;
    padding-block-start: var(--space-m);
    border-block-start: 1px solid
      var(--foreground-muted);
    opacity: 0.7;
  }
</style>
