---
export interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  ogType?: 'website' | 'article';
  canonical?: string;
}

const {
  title,
  description = 'Join IOAI Spain - An intensive AI program by Harbour.Space University for high school students.',
  ogImage = '/og-image.png',
  ogType = 'website',
  canonical
} = Astro.props;

// Use Astro's native i18n support to get current locale
const locale = Astro.currentLocale || 'en';

// Build canonical URL
const canonicalUrl = canonical || Astro.url.href;

// Build full OG image URL (needs to be absolute for social media)
const fullOgImageUrl = new URL(ogImage, Astro.site || Astro.url.origin).href;

// Site info
const siteName = 'IOAI Spain';
const twitterHandle = '@ioaispain'; // Update with actual Twitter handle if available
---

<head>
  <!-- Charset MUST be in the first 1024 bytes of the document
       (Lighthouse "Best Practices" rule + browser parsing safety).
       Keep it BEFORE the inline GTM bootstrap which used to push
       it past the threshold. -->
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="generator" content={Astro.generator} />

  <!-- Preconnect to the third-party origins we hit on every page so
       the TLS handshake + DNS resolve happen in parallel with the
       HTML parse, instead of serially when the script tags fire.
       Order matters slightly: the highest-impact one (GTM) goes
       first since it's the first script the page actually fetches. -->
  <link rel="preconnect" href="https://www.googletagmanager.com" crossorigin />
  <link rel="preconnect" href="https://www.google-analytics.com" crossorigin />
  <link rel="preconnect" href="https://challenges.cloudflare.com" crossorigin />

  <!-- Google Tag Manager — must run as early as possible so the
       container has a chance to fire page-view events before any
       in-page scripts. Container ID lives on the IOAI Spain GTM
       account (`GTM-PST8FH3P`) and owns Google Ads conversion +
       any future marketing tags for this domain. -->
  <script is:inline>
    (function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
    new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
    j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
    'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
    })(window,document,'script','dataLayer','GTM-PST8FH3P');
  </script>

  <!-- SEO Meta Tags -->
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalUrl} />

  <!-- Favicon -->
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="alternate icon" href="/favicon.svg" />
  <link rel="apple-touch-icon" href="/favicon.svg" />

  <!-- Theme Color for Mobile Browsers -->
  <meta name="theme-color" content="#1a1a1a" />

  <!-- Open Graph / Facebook -->
  <meta property="og:type" content={ogType} />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={fullOgImageUrl} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:site_name" content={siteName} />
  <meta property="og:locale" content={locale === 'es' ? 'es_ES' : 'en_US'} />

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:url" content={canonicalUrl} />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={fullOgImageUrl} />
  {twitterHandle && <meta name="twitter:site" content={twitterHandle} />}

  <!-- Additional Meta Tags -->
  <meta name="robots" content="index, follow" />
  <meta name="author" content="Harbour.Space University" />

  <!-- Google Analytics -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-RV8WTFWNN5" is:inline></script>
  <script is:inline>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-RV8WTFWNN5');
  </script>

  <!-- UTM Tracking Script — `defer` so it doesn't block the parser
       (the script's own logic waits for DOMContentLoaded anyway). -->
  <script src="/scripts/preserveUTM.js" is:inline defer></script>

  <!-- Cloudflare Turnstile (anti-bot) -->
  <script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>

  <!-- Per-layout head injections (e.g. Astro <Font> tags) -->
  <slot />
</head>