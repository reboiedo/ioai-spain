---
import Navigation from '../components/Navigation.astro';
import Head from '../components/Head.astro';
import '@/styles/global.css';

export interface Props {
  title: string;
  description?: string;
  showNavigation?: boolean;
  hideNavItems?: boolean;
  ctaUrlOverride?: string;
  /** Forwarded to Navigation. Replaces the default nav items list. */
  navItems?: { label: string; href: string }[];
  /** Forwarded to Navigation. `'transparent'` swaps in the white wordmark. */
  navTheme?: 'default' | 'transparent';
  ogImage?: string;
  ogType?: 'website' | 'article';
  canonical?: string;
}

const {
  title,
  description,
  showNavigation = true,
  hideNavItems = false,
  ctaUrlOverride,
  navItems,
  navTheme = 'default',
  ogImage,
  ogType,
  canonical
} = Astro.props;

// Use Astro's native i18n support to get current locale
const locale = Astro.currentLocale || 'en';
---

<!DOCTYPE html>
<html lang={locale}>
  <Head
    title={title}
    description={description}
    ogImage={ogImage}
    ogType={ogType}
    canonical={canonical}
  >
    <slot name="head" />
  </Head>
  <body>
    <!-- Google Tag Manager (noscript) — fallback iframe for browsers
         with JS disabled. Pairs with the inline GTM bootstrap in
         Head.astro; container ID `GTM-PST8FH3P`. -->
    <noscript>
      <iframe
        src="https://www.googletagmanager.com/ns.html?id=GTM-PST8FH3P"
        height="0"
        width="0"
        style="display:none;visibility:hidden"
      ></iframe>
    </noscript>
    {showNavigation && <Navigation hideNavItems={hideNavItems} ctaUrlOverride={ctaUrlOverride} navItems={navItems} theme={navTheme} />}
    <main>
      <slot />
    </main>

    <style>
      body {
        background-color: var(--background-primary);
      }
    </style>
  <script>
    import gsap from "gsap";
    import { ScrollTrigger } from "gsap/ScrollTrigger";
    import { SplitText } from "gsap/SplitText";

    gsap.registerPlugin(ScrollTrigger, SplitText);

    // Type-safe window assignments
    (window as any).gsap = gsap;
    (window as any).SplitText = SplitText;
  </script>
  </body>
  </html>