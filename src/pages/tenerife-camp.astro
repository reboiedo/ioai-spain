---
import TenerifeCampV2Layout from '@/layouts/TenerifeCampV2Layout.astro';
import HeroTitle from '@/components/tenerife/HeroTitle.astro';
import SectionTitle from '@/components/tenerife/SectionTitle.astro';
import HoverShaderImage from '@/components/tenerife/HoverShaderImage.astro';
import SectionHero from '@/components/tenerife/SectionHero.astro';
import SectionStory from '@/components/tenerife/SectionStory.astro';
import SectionTeam from '@/components/tenerife/SectionTeam.astro';
import SectionTracks from '@/components/tenerife/SectionTracks.astro';
import SectionActivities from '@/components/tenerife/SectionActivities.astro';
import SectionDayInLife from '@/components/tenerife/SectionDayInLife.astro';
import SectionVenue from '@/components/tenerife/SectionVenue.astro';
import SectionSafety from '@/components/tenerife/SectionSafety.astro';
import SectionFaq from '@/components/tenerife/SectionFaq.astro';
import SectionPricing from '@/components/tenerife/SectionPricing.astro';
import SectionApply from '@/components/tenerife/SectionApply.astro';
import SectionFooter from '@/components/tenerife/SectionFooter.astro';
import SectionTestimonials from '@/components/tenerife/SectionTestimonials.astro';
---

<!-- Inline early to block native scroll restoration BEFORE the browser
     applies it. If set later (inside a module script), the browser has
     already restored scroll and our pins/tilts measure against the
     wrong position. -->
<script is:inline>
  if ('scrollRestoration' in history) {
    history.scrollRestoration = 'manual';
  }
</script>

<TenerifeCampV2Layout
  title="Tenerife Summer Camp - IOAI Spain"
  description="An educational summer camp in Tenerife combining IT and math, creative activities, and outdoor adventure."
>
  <SectionHero theme="blue" />

  <SectionStory theme="orange" />

  <SectionTracks theme="blue" />

  <SectionTeam theme="orange" />

  <SectionActivities theme="blue" />

  <SectionVenue theme="yellow" />

  <SectionSafety theme="orange" />

  <SectionDayInLife theme="blue" />

  <SectionTestimonials theme="yellow" />

  <SectionPricing theme="orange" />

  <SectionFaq theme="blue" />

  <SectionApply theme="orange" />

  <SectionFooter theme="orange" />

</TenerifeCampV2Layout>


<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  import Lenis from 'lenis';

  gsap.registerPlugin(ScrollTrigger);

  // Scroll restoration is already disabled in an inline head script
  // (see top of file). Force scroll to top as a belt-and-braces
  // fallback in case any restoration slipped through.
  window.scrollTo(0, 0);

  // iOS Safari address-bar show/hide triggers viewport resizes that
  // cause ScrollTrigger to refresh and visibly jump pins. Suppress
  // those minor resizes.
  ScrollTrigger.config({ ignoreMobileResize: true });

  let sceneTriggers: ScrollTrigger[] = [];
  let tiltTweens: gsap.core.Tween[] = [];
  let displayAssetTweens: gsap.core.Tween[] = [];
  let lenis: Lenis | null = null;

  function initLenis() {
    if (lenis) return;
    lenis = new Lenis({
      // Slightly slower lerp than the default (0.1) — gives scroll
      // velocity a longer momentum tail so the binary pin moments
      // feel less abrupt. With Lenis smoothing wheel input but
      // ScrollTrigger.pin still being a discrete state change, a
      // longer momentum decay is the only way to soften the
      // perceived "thump" when content goes from scrolling to fixed.
      lerp: 0.075,
    });

    // Drive ScrollTrigger updates from Lenis's scroll event so pins
    // and scroll progress stay in sync with smooth-scrolled position.
    lenis.on('scroll', ScrollTrigger.update);

    // Run Lenis's RAF from GSAP's ticker so both share one animation
    // loop. Multiplied by 1000 because GSAP ticker is in seconds,
    // Lenis expects ms.
    gsap.ticker.add((time) => {
      lenis?.raf(time * 1000);
    });

    // Disable GSAP's lag smoothing — it rounds timing in ways that
    // fight Lenis's interpolation and produce visible stutter.
    gsap.ticker.lagSmoothing(0);
  }

  /**
   * initSceneStack
   *
   * Pin each `[data-scene]` for stack-reveal: the scene holds at vp
   * bottom for one viewport of scroll while the next scene slides up
   * over it. With `pinSpacing: false`, the next sibling's natural
   * position takes over visually.
   *
   * Drawer-bearing scenes opt out via `[data-flow]` (or by containing
   * a `<details>` element). With `pinSpacing: false`, a pinned scene
   * is `position: fixed` and removed from flow — drawer growth inside
   * couldn't push downstream siblings. Flow scenes scroll naturally
   * and the next pinned scene reveals after them.
   *
   * No ResizeObserver here. Drawer toggles do shift downstream pin
   * engagement scrollY, but we accept that staleness — the alternative
   * (firing a global `ScrollTrigger.refresh()` on every drawer toggle)
   * causes visible tilt flashes via `invalidateOnRefresh`, which
   * always reads as broken motion.
   */
  function initSceneStack() {
    sceneTriggers.forEach((t) => t.kill());
    sceneTriggers = [];

    const scenes = gsap.utils.toArray<HTMLElement>('[data-scene]');

    scenes.forEach((scene) => {
      const isFlowScene =
        scene.matches('[data-flow]') ||
        !!scene.querySelector('[data-flow]') ||
        !!scene.querySelector('details');
      if (isFlowScene) return;

      const trigger = ScrollTrigger.create({
        trigger: scene,
        start: 'bottom bottom',
        end: '+=100%',
        pin: true,
        pinSpacing: false,
        anticipatePin: 1,
        invalidateOnRefresh: true,
      });
      sceneTriggers.push(trigger);
    });

    // Late-loading content (fonts, images) can shift scene heights
    // after triggers were created. Force one refresh to re-measure.
    ScrollTrigger.refresh();
  }

  function initTilts() {
    tiltTweens.forEach((t) => t.scrollTrigger?.kill());
    tiltTweens.forEach((t) => t.kill());
    tiltTweens = [];

    const tiltLayers = gsap.utils.toArray<HTMLElement>('.scene__layer--tilt');

    tiltLayers.forEach((layer) => {
      // Scroll-scrubbed "entry tilt" matching follow.art: each section
      // arrives at (15°, responsive xPercent) below the fold, and
      // scrubs to (0°, 0%) as it scrolls up into place. Once flat, it
      // stays flat — follow.art does NOT re-tilt sections as the next
      // one covers them (verified by live-scrubbing their DOM).
      //
      // Trigger window: `top bottom` (section's top at viewport
      // bottom — first frame it appears) to `top top` (section's top
      // at viewport top — pin engages). That's the full entry.
      //
      // `xPercent` is a % of the element's own width. follow.art uses
      // +8.61% on desktop and −12.82% on mobile — different magnitudes
      // AND opposite signs. The sign flip is deliberate: with origin
      // `0 0` a 15° rotation swings the bottom-left corner leftward by
      // ~26% of element height; desktop can afford to pull the section
      // rightward (+8.61%) to keep the top-right inside viewport,
      // while mobile's narrower viewport can't — it lets the bottom
      // corner overflow further left (−12.82%) instead so the
      // top-right doesn't shoot past the right edge.
      //
      // transform-origin is set in CSS (`.scene__layer--tilt`) to
      // `0 0` — top-left corner pivot.
      //
      // `fromTo` + `immediateRender: true` pre-stages every layer at
      // its 15° starting pose, so sections below the fold sit tilted
      // waiting to be scrolled into.
      const tween = gsap.fromTo(
        layer,
        {
          rotation: 15,
          xPercent: () => (window.innerWidth >= 768 ? 8.61 : -12.82),
        },
        {
          rotation: 0,
          xPercent: 0,
          // `power2.out` (quadratic ease-out). Reverse-engineered
          // from follow.art's live DOM. Feel: section straightens
          // quickly off the bottom, then decelerates as it lands at
          // the top. With bidirectional `scrub: true`, scroll-up
          // mirrors this — section enters the top flat, gradually
          // tilts to 15° as it descends to the bottom.
          ease: 'power2.out',
          immediateRender: true,
          scrollTrigger: {
            trigger: layer,
            start: 'top bottom',
            end: 'top top',
            scrub: true,
            invalidateOnRefresh: true,
          },
        },
      );
      tiltTweens.push(tween);
    });

    // One final refresh so newly-created tilt triggers recalculate
    // their start/end against current document layout (pins may have
    // shifted things during init).
    ScrollTrigger.refresh();
  }

  /**
   * initDisplayAssets
   *
   * For each `[data-display-asset]` element inside a `.display-block`,
   * create a scroll-scrubbed animation that brings the asset in over
   * the title as the user scrolls through the block.
   *
   * The asset is positioned by CSS (absolute + centred via its
   * `.display-block__asset-slot` parent). GSAP owns the transform of
   * the inner element — starts translated down + scaled down +
   * transparent, ends at natural position + full scale + opaque. Exact
   * motion is placeholder-level; later this can be replaced with a
   * Three.js canvas + shader for proper distortion.
   *
   * Trigger window: display-block top enters vp bottom → display-block
   * reaches the middle of the viewport. That gives the animation ~1.5
   * viewports of scroll to play out, feeling unhurried.
   */
  function initDisplayAssets() {
    displayAssetTweens.forEach((t) => t.scrollTrigger?.kill());
    displayAssetTweens.forEach((t) => t.kill());
    displayAssetTweens = [];

    const assets = gsap.utils.toArray<HTMLElement>('[data-display-asset]');

    assets.forEach((asset) => {
      const block = asset.closest('.display-block');
      if (!block) return;

      // Parallax-style reveal: the asset passes continuously through
      // the viewport from bottom to top as the user scrolls through
      // the display-block. No scale, no opacity fade — just movement.
      //
      // The trigger window spans 'top bottom' → 'bottom top' (~200svh
      // of scroll), and we translate across a range slightly larger
      // than the natural centring (~±60vh). Net effect: the asset
      // moves FASTER than the page, so it feels foreground-parallax
      // rather than landing-in-place.
      //
      // `y` values are computed as functions so they re-evaluate on
      // resize refresh (vh changes → new travel distance).
      // Asymmetric parallax: asset enters gently from below, exits
      // aggressively toward the top. The end value is much larger
      // than the start so the upward motion is visibly faster than
      // the downward entry. Tune the `1.6` multiplier if you want
      // even more exit speed.
      const tween = gsap.fromTo(
        asset,
        { y: () => window.innerHeight * 0.6 },
        {
          y: () => -window.innerHeight * 1.6,
          ease: 'none',
          immediateRender: true,
          scrollTrigger: {
            trigger: block,
            start: 'top bottom',
            end: 'bottom top',
            scrub: true,
            invalidateOnRefresh: true,
          },
        },
      );
      displayAssetTweens.push(tween);
    });
  }

  function cleanup() {
    sceneTriggers.forEach((t) => t.kill());
    sceneTriggers = [];
    tiltTweens.forEach((t) => t.scrollTrigger?.kill());
    tiltTweens.forEach((t) => t.kill());
    tiltTweens = [];
    displayAssetTweens.forEach((t) => t.scrollTrigger?.kill());
    displayAssetTweens.forEach((t) => t.kill());
    displayAssetTweens = [];
    lenis?.destroy();
    lenis = null;
  }

  function init() {
    initLenis();
    initSceneStack();
    initTilts();
    initDisplayAssets();
  }

  init();
  document.addEventListener('astro:page-load', init);
  document.addEventListener('astro:before-swap', cleanup);
</script>
