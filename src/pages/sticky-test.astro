---
// Sticky-stack prototype.
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Sticky test</title>
  <style is:global>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    html, body { background: #111; color: #fff; font-family: system-ui, sans-serif; }

    /* All scenes are direct siblings of <main>. Each is sticky-top
       inside <main>, so they all compete for top: 0 simultaneously
       — z-index determines which one paints on top. As you scroll,
       a later scene scrolls up from below and covers the previous
       one (its z-index is higher). This is the canonical "stacked
       sticky" pattern follow.art uses. */
    .scene {
      position: sticky;
      /* Short scenes (100vh): stick at vp.top — works as confirmed. */
      top: 0;
      height: 100vh;
      display: flex;
      align-items: flex-end;
      padding: 3rem;
      font: 700 3rem sans-serif;
    }

    .s1 { z-index: 1; background: #c83030; }
    .s2 { z-index: 2; background: #2a8c43; }

    /* Tall scene 3 — overrides the default top:0 with bottom:0 so
     * the upper portion scrolls naturally out of view BEFORE the
     * bottom catches at vp.bottom and locks. This is the "hero
     * scrolls in, then browser pins" pattern. */
    .s3 {
      z-index: 3;
      background: #2858b8;
      height: 150vh;
      top: auto;
      bottom: 0;
    }

    .s4 { z-index: 4; background: #a833a8; }
    .s5 { z-index: 5; background: #b8881e; }
  </style>
</head>
<body>

<main>
  <section class="scene s1">Scene 1 — 100vh</section>
  <section class="scene s2">Scene 2 — 100vh</section>
  <section class="scene s3">Scene 3 — 150vh (taller)</section>
  <section class="scene s4">Scene 4</section>
  <section class="scene s5">Scene 5</section>
</main>

<script>
  import Lenis from 'lenis';
  const lenis = new Lenis({ lerp: 0.075 });
  function raf(time) { lenis.raf(time); requestAnimationFrame(raf); }
  requestAnimationFrame(raf);
</script>

</body>
</html>
